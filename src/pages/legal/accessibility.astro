---
import Layout from '../../components/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout>
  <Header />
  <main>
    <h1>Accessibility Statement</h1>
    <section>
      <h2>Commitment</h2>
      <p>SimpleTrackers.io is committed to strong accessibility compliance. We use semantic HTML, proper landmarks, labeled inputs, visible focus states, keyboard navigation, and sufficient color contrast.</p>
    </section>
    <section>
      <h2>Feedback</h2>
      <p>If you encounter accessibility issues, please contact us at <a href="mailto:support@simpletrackers.io">support@simpletrackers.io</a>.</p>
    </section>
  </main>
  <Footer />
</Layout>