---
import Header from './Header.astro';
import Footer from './Footer.astro';
import SEO from './SEO.astro';
const { seoTitle, seoDescription } = Astro.props;

---
<SEO title={seoTitle} description={seoDescription} />
<html lang="en">
  <head>
    <!-- Astro injects CSS automatically -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-6E8NZ6TNCV"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-6E8NZ6TNCV');
    </script>
  </head>
  <body class="flex flex-col min-h-screen bg-gray-50 text-gray-900 font-sans">
    <Header />
    <main id="main-content" class="flex-1 max-w-4xl mx-auto w-full px-4 py-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  body {
    display: grid;
    grid-template-rows: auto 1fr auto;
    min-height: 100vh;
  }
</style>
