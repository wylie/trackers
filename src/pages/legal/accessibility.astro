---
import Layout from '../../components/Layout.astro';
---

<Layout seoTitle="Accessibility" seoDescription="Accessibility standards and support information for SimpleTrackers.">
  <main class="max-w-3xl mx-auto w-full px-4 py-8">
    <h1 class="text-[30px] leading-[1.2] font-extrabold text-slate-900 mb-2">Accessibility</h1>
    <p class="text-[18px] leading-[1.45] text-slate-600 mb-6">We aim to make SimpleTrackers usable for everyone.</p>

    <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-6">
      <div>
        <h2 class="text-[18px] font-bold text-slate-900 mb-2">Commitment</h2>
        <p class="text-[15px] leading-7 text-slate-600">SimpleTrackers uses semantic HTML, proper landmarks, labeled controls, keyboard support, visible focus states, and color contrast aligned with accessibility best practices.</p>
      </div>
      <div>
        <h2 class="text-[18px] font-bold text-slate-900 mb-2">Feedback</h2>
        <p class="text-[15px] leading-7 text-slate-600">If you encounter accessibility issues, email us at <a href="mailto:support@simpletrackers.io" class="text-blue-700 underline hover:text-blue-800">support@simpletrackers.io</a>.</p>
      </div>
    </section>
  </main>
</Layout>
