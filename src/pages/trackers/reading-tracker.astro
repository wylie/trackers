---
import Layout from '../../components/Layout.astro';
import TrackerPageWrapper from '../../components/TrackerPageWrapper.astro';

import TrackerCard from '../../components/TrackerCard.astro';
import HowToUse from '../../components/sections/HowToUse.astro';
import Benefits from '../../components/sections/Benefits.astro';
import RelatedTrackers from '../../components/sections/RelatedTrackers.astro';
import RelatedCalculators from '../../components/sections/RelatedCalculators.astro';
import SupportButton from '../../components/SupportButton.astro';
import TrackerBadgesCard from '../../components/TrackerBadgesCard.astro';
import { getRelatedCalculators } from '../../data/related-calculators';

const steps = [
  "Enter the book title and pages read.",
  "Click 'Add Entry' to log your reading.",
  "Your data is saved locally in your browser.",
  "No account or login required."
];
const benefits = [
  "Simple, distraction-free interface",
  "Private: your data never leaves your device",
  "No registration or login required",
  "Track progress and stay motivated"
];
const related = [
  { name: "Habit Tracker", url: "/habit-tracker", icon: "check_circle" },
  { name: "Movie Watch Tracker", url: "/movie-watch-tracker", icon: "movie" },
  { name: "Task Tracker", url: "/task-tracker", icon: "assignment" },
  { name: "Custom Tracker", url: "/custom-tracker", icon: "tune" }
];
const relatedCalculators = getRelatedCalculators("reading-tracker");
---

<Layout seoTitle="Reading Tracker" seoDescription="Track your reading habits privately and easily. No login, no accounts, data stays in your browser.">
  <TrackerPageWrapper>
    <main>
      <div class="max-w-6xl mx-auto">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Reading Tracker</h1>
        <p class="text-gray-700 text-lg mb-6">Track your reading habits privately and easily. No login, no accounts, data stays in your browser.</p>
        <section class="rd-layout">
          <div class="rd-main">
            <TrackerCard
              title="Reading Log"
              description="Log your books, progress, and notes."
              storageKey="reading-tracker-entries"
              icon="menu_book"
              itemPlaceholder="Title"
              enableAuthorField={true}
              authorPlaceholder="Author"
              autoPopulateAuthor={true}
              enableReadingProgress={true}
              autoPopulateTotalPages={true}
              autocompleteEndpoint="/api/openlibrary/suggest"
            />
          </div>
          <aside class="rd-side" aria-label="Reading insights">
            <h2 class="rd-side-title">Insights</h2>
            <div class="rd-card">
              <h3 class="rd-title">Progress by Book</h3>
              <div id="rd-progress-bars" class="rd-bars"></div>
            </div>
            <div class="rd-card">
              <h3 class="rd-title">Reading Status</h3>
              <div class="rd-pie-wrap">
                <div id="rd-status-pie" class="rd-pie"></div>
                <div id="rd-status-legend" class="rd-legend"></div>
              </div>
            </div>
            <div id="rd-yearly-challenge" class="rd-card"></div>
            <div class="rd-card">
              <h3 class="rd-title">Last 14 Days</h3>
              <div class="rd-legend-inline">
                <span><i class="rd-legend-swatch rd-legend-swatch--pages"></i>Pages</span>
                <span><i class="rd-legend-swatch rd-legend-swatch--audio"></i>Listened</span>
              </div>
              <div id="rd-14d" class="rd-14d"></div>
              <p class="rd-note">Blue = pages read, green = audiobook time listened.</p>
            </div>
            <TrackerBadgesCard storageKey="reading-tracker-entries" />
            <SupportButton />
          </aside>
        </section>
        <section class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="col-span-1 md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-8">
            <HowToUse steps={steps} />
            <Benefits benefits={benefits} />
          </div>
          <div class="col-span-1 md:col-span-2">
            <RelatedTrackers related={related} />
            <RelatedCalculators calculators={relatedCalculators} />
          </div>
        </section>
      </div>
    </main>
  </TrackerPageWrapper>
</Layout>

<script>
  const STORAGE_KEY = "simpletrackers.io";
  const READING_KEY = "reading-tracker-entries";
  const READING_SETTINGS_KEY = "reading-tracker-settings";

  function parseStore() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY)) || {};
    } catch {
      return {};
    }
  }

  function getReadingEntries() {
    const store = parseStore();
    return Array.isArray(store[READING_KEY]) ? store[READING_KEY] : [];
  }

  function getReadingSettings() {
    const store = parseStore();
    const settings = store?.[READING_SETTINGS_KEY];
    const yearlyGoalBooks = Math.max(0, Number(settings?.yearlyGoalBooks) || 0);
    return { yearlyGoalBooks };
  }

  function saveReadingSettings(nextSettings) {
    const all = parseStore();
    all[READING_SETTINGS_KEY] = {
      yearlyGoalBooks: Math.max(0, Number(nextSettings?.yearlyGoalBooks) || 0)
    };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(all));
  }

  function getYearBounds(year) {
    return {
      start: new Date(year, 0, 1).getTime(),
      end: new Date(year + 1, 0, 1).getTime()
    };
  }

  function parseFinishedTimestamp(entry) {
    const finishedDate = String(entry?.finishedDate || "").trim();
    if (finishedDate) {
      const ts = new Date(`${finishedDate}T12:00:00`).getTime();
      if (Number.isFinite(ts) && ts > 0) return ts;
    }
    const dateTs = entry?.date ? new Date(entry.date).getTime() : 0;
    return Number.isFinite(dateTs) && dateTs > 0 ? dateTs : 0;
  }

  function getFinishedBooksThisYear(entries, year) {
    const { start, end } = getYearBounds(year);
    const latestByBook = new Map();
    for (const entry of entries) {
      if (entry?.currentlyReading) continue;
      const finishedTs = parseFinishedTimestamp(entry);
      if (finishedTs < start || finishedTs >= end) continue;
      const key = `${String(entry?.item || "").trim().toLowerCase()}|${String(entry?.author || "").trim().toLowerCase()}`;
      if (!key || key === "|") continue;
      const existing = latestByBook.get(key);
      if (!existing || finishedTs > existing.ts) {
        latestByBook.set(key, { ts: finishedTs, entry });
      }
    }
    return Array.from(latestByBook.values()).sort((a, b) => b.ts - a.ts);
  }

  function dayProgressInYear(now = new Date()) {
    const year = now.getFullYear();
    const yearStart = new Date(year, 0, 1);
    const nextYear = new Date(year + 1, 0, 1);
    const elapsed = Math.max(1, Math.floor((now.getTime() - yearStart.getTime()) / 86400000) + 1);
    const total = Math.floor((nextYear.getTime() - yearStart.getTime()) / 86400000);
    return { elapsed, total };
  }

  function totalMinutes(hours, minutes) {
    return Math.max(0, Number(hours) || 0) * 60 + Math.max(0, Number(minutes) || 0);
  }

  function getBookProgressPercent(entry) {
    if (entry?.isAudiobook) {
      const total = totalMinutes(entry?.totalHours, entry?.totalMinutes);
      if (total <= 0) return 0;
      const explicitLeft = totalMinutes(entry?.leftHours, entry?.leftMinutes);
      let left = explicitLeft;
      if (!(explicitLeft > 0 || (Number(entry?.leftHours) === 0 && Number(entry?.leftMinutes) === 0))) {
        const legacyCurrent = totalMinutes(entry?.currentHours, entry?.currentMinutes);
        left = Math.max(0, total - Math.min(total, legacyCurrent));
      }
      const listened = Math.max(0, total - Math.min(total, left));
      return Math.min(100, Math.round((listened / total) * 100));
    }
    const current = Math.max(0, Number(entry?.currentPage) || 0);
    const total = Math.max(0, Number(entry?.totalPages) || 0);
    if (total <= 0) return 0;
    return Math.min(100, Math.round((current / total) * 100));
  }

  function latestByBook(entries) {
    const map = new Map();
    for (const entry of entries) {
      const name = String(entry?.item || "").trim();
      if (!name) continue;
      const updatedAt = Number(entry?.updatedAt) || 0;
      const dateTs = entry?.date ? new Date(entry.date).getTime() : 0;
      const ts = Math.max(updatedAt, Number.isFinite(dateTs) ? dateTs : 0);
      const existing = map.get(name);
      if (!existing || ts > existing.ts) {
        map.set(name, { ts, entry });
      }
    }
    return Array.from(map.entries()).map(([name, value]) => ({
      name,
      entry: value.entry,
      percent: getBookProgressPercent(value.entry)
    })).sort((a, b) => b.percent - a.percent);
  }

  function aggregateLast14Days(entries) {
    const today = new Date();
    const start = new Date(today.getFullYear(), today.getMonth(), today.getDate());
    start.setDate(start.getDate() - 13);
    const msPerDay = 86400000;
    const series = Array.from({ length: 14 }, (_, idx) => ({
      day: new Date(start.getTime() + idx * msPerDay),
      pages: 0,
      audioMinutes: 0
    }));
    for (const entry of entries) {
      const totalPages = Math.max(0, Number(entry?.totalPages) || 0);
      const totalAudioMinutes = Math.max(0, totalMinutes(entry?.totalHours, entry?.totalMinutes));
      const history = Array.isArray(entry?.readingActivityHistory) ? entry.readingActivityHistory : [];
      if (history.length) {
        history.forEach((item) => {
          const rawTs = item?.createdAt;
          const directTs = Number(rawTs);
          const ts = Number.isFinite(directTs) && directTs > 0
            ? directTs
            : (rawTs ? new Date(rawTs).getTime() : 0);
          const deltaPercent = Math.max(0, Number(item?.deltaPercent) || 0);
          if (ts <= 0 || deltaPercent <= 0) return;
          const when = new Date(ts);
          if (Number.isNaN(when.getTime())) return;
          const day = new Date(when.getFullYear(), when.getMonth(), when.getDate());
          const idx = Math.floor((day.getTime() - start.getTime()) / msPerDay);
          if (idx < 0 || idx >= series.length) return;
          if (entry?.isAudiobook) {
            const listenedMinutes = totalAudioMinutes > 0
              ? (deltaPercent / 100) * totalAudioMinutes
              : 0;
            series[idx].audioMinutes += Math.max(0, listenedMinutes);
          } else {
            const pages = totalPages > 0
              ? (deltaPercent / 100) * totalPages
              : deltaPercent;
            series[idx].pages += Math.max(0, pages);
          }
        });
        continue;
      }

      const updatedAt = Number(entry?.updatedAt) || 0;
      const when = Number.isFinite(updatedAt) && updatedAt > 0
        ? new Date(updatedAt)
        : (entry?.date ? new Date(entry.date) : null);
      if (!when || Number.isNaN(when.getTime())) continue;
      const day = new Date(when.getFullYear(), when.getMonth(), when.getDate());
      const idx = Math.floor((day.getTime() - start.getTime()) / msPerDay);
      if (idx >= 0 && idx < series.length) {
        if (entry?.isAudiobook) {
          const currentAudioMinutes = Math.max(0, totalMinutes(entry?.currentHours, entry?.currentMinutes));
          const fallbackAudio = totalAudioMinutes > 0
            ? Math.max(1, Math.min(totalAudioMinutes, currentAudioMinutes))
            : Math.max(1, getBookProgressPercent(entry));
          series[idx].audioMinutes += fallbackAudio;
        } else {
          const fallbackPages = totalPages > 0
            ? Math.max(1, Math.min(totalPages, Math.max(0, Number(entry?.currentPage) || 0)))
            : Math.max(1, getBookProgressPercent(entry));
          series[idx].pages += fallbackPages;
        }
      }
    }
    return series;
  }

  function renderReadingInsights() {
    const bars = document.getElementById("rd-progress-bars");
    const pie = document.getElementById("rd-status-pie");
    const legend = document.getElementById("rd-status-legend");
    const trend = document.getElementById("rd-14d");
    const challenge = document.getElementById("rd-yearly-challenge");
    if (!bars || !pie || !legend || !trend) return;

    const entries = getReadingEntries();
    if (challenge) {
      renderYearlyChallenge(challenge, entries);
    }
    if (!entries.length) {
      const empty = "<p class='rd-empty'>No reading data yet.</p>";
      bars.innerHTML = empty;
      pie.innerHTML = "<div class='rd-pie-center'><strong>0</strong><span>Books</span></div>";
      pie.style.background = "#e2e8f0";
      legend.innerHTML = "";
      trend.innerHTML = empty;
      return;
    }

    const allBooks = latestByBook(entries);
    const booksForBars = allBooks.filter((book) => Boolean(book.entry?.currentlyReading)).slice(0, 6);
    bars.innerHTML = booksForBars.length ? booksForBars.map((book) => `
      <div class="rd-row">
        <span class="rd-name" title="${book.name}">${book.name}</span>
        <span class="rd-track"><span class="rd-fill" style="width:${Math.max(2, book.percent)}%"></span></span>
        <span class="rd-metric">${book.percent}%</span>
      </div>
    `).join("") : "<p class='rd-empty'>No currently reading books yet.</p>";

    const currentlyReading = allBooks.filter((book) => Boolean(book.entry?.currentlyReading)).length;
    const finished = Math.max(0, allBooks.length - currentlyReading);
    const total = Math.max(1, allBooks.length);
    const currentDeg = (currentlyReading / total) * 360;
    pie.style.background = `conic-gradient(#2563eb 0deg ${currentDeg}deg, #16a34a ${currentDeg}deg 360deg)`;
    pie.innerHTML = `<div class="rd-pie-center"><strong>${allBooks.length}</strong><span>Books</span></div>`;
    legend.innerHTML = `
      <div class="rd-leg-row"><span class="rd-dot" style="background:#2563eb"></span><span class="rd-leg-name">Currently Reading</span><span class="rd-leg-val">${currentlyReading}</span></div>
      <div class="rd-leg-row"><span class="rd-dot" style="background:#16a34a"></span><span class="rd-leg-name">Finished</span><span class="rd-leg-val">${finished}</span></div>
    `;

    const last14 = aggregateLast14Days(entries);
    const maxPages = Math.max(...last14.map((day) => day.pages), 1);
    const maxAudio = Math.max(...last14.map((day) => day.audioMinutes), 1);
    trend.innerHTML = last14.map((day) => {
      const pages = Math.round(day.pages * 10) / 10;
      const audioMinutes = Math.round(day.audioMinutes);
      const audioLabel = audioMinutes >= 60
        ? `${(audioMinutes / 60).toFixed(1).replace(/\.0$/, "")}h`
        : `${audioMinutes}m`;
      const hPages = day.pages > 0 ? Math.max(8, Math.round((day.pages / maxPages) * 68)) : 0;
      const hAudio = day.audioMinutes > 0 ? Math.max(8, Math.round((day.audioMinutes / maxAudio) * 68)) : 0;
      const d = day.day.toLocaleDateString(undefined, { month: "numeric", day: "numeric" });
      const pageLabel = pages.toFixed(1).replace(/\\.0$/, "");
      return `<div class="rd-day-col"><span class="rd-day-bars" title="${d}: ${pageLabel} pages, ${audioLabel} listened"><span class="rd-day-bar rd-day-bar--pages" style="height:${hPages}px"></span><span class="rd-day-bar rd-day-bar--audio" style="height:${hAudio}px"></span></span><span class="rd-day-label">${d.split("/")[1] || d}</span></div>`;
    }).join("");
  }

  function renderYearlyChallenge(root, entries) {
    if (!root) return;
    const currentYear = new Date().getFullYear();
    const settings = getReadingSettings();
    const finished = getFinishedBooksThisYear(entries, currentYear);
    const completedBooks = finished.length;
    const goal = settings.yearlyGoalBooks;
    const { elapsed, total } = dayProgressInYear(new Date());
    const expectedByNow = goal > 0 ? (goal * (elapsed / total)) : 0;
    const delta = completedBooks - expectedByNow;
    const deltaLabel = goal > 0
      ? (delta >= 0 ? `${Math.round(delta * 10) / 10} ahead of pace` : `${Math.round(Math.abs(delta) * 10) / 10} behind pace`)
      : "Set a goal to track your pace.";
    const progressPct = goal > 0 ? Math.min(100, Math.round((completedBooks / goal) * 100)) : 0;

    root.innerHTML = `
      <div class="rd-challenge-head">
        <div>
          <h3 class="rd-title">Yearly Reading Challenge</h3>
          <p class="rd-note rd-note-tight">${currentYear} completed books</p>
        </div>
      </div>
      <div class="rd-challenge-goal-row">
        <label for="rd-yearly-goal-input" class="sr-only">Books goal for ${currentYear}</label>
        <input id="rd-yearly-goal-input" type="number" min="0" step="1" value="${goal || ""}" placeholder="Books goal" class="rd-goal-input" />
        <button id="rd-yearly-goal-save" type="button" class="rd-goal-btn">Save</button>
      </div>
      <div class="rd-challenge-stats">
        <div class="rd-stat"><span>Read</span><strong>${completedBooks}</strong></div>
        <div class="rd-stat"><span>Goal</span><strong>${goal > 0 ? goal : "-"}</strong></div>
        <div class="rd-stat"><span>Progress</span><strong>${goal > 0 ? `${progressPct}%` : "-"}</strong></div>
      </div>
      <div class="rd-challenge-track">
        <span class="rd-challenge-fill" style="width:${goal > 0 ? Math.max(2, progressPct) : 0}%"></span>
      </div>
      <p class="rd-note rd-note-tight">${deltaLabel}</p>
    `;

    const saveButton = root.querySelector("#rd-yearly-goal-save");
    const goalInput = root.querySelector("#rd-yearly-goal-input");
    const persist = () => {
      const nextGoal = Math.max(0, Number(goalInput?.value || 0));
      saveReadingSettings({ yearlyGoalBooks: nextGoal });
      renderReadingInsights();
    };
    saveButton?.addEventListener("click", persist);
    goalInput?.addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        event.preventDefault();
        persist();
      }
    });
  }

  function initReadingInsights() {
    renderReadingInsights();
  }

  initReadingInsights();
  document.addEventListener("astro:page-load", initReadingInsights);
  document.addEventListener("simpletrackers:entries-updated", (event) => {
    if (event?.detail?.storageKey === READING_KEY) renderReadingInsights();
  });
  window.addEventListener("storage", (event) => {
    if (!event.key || event.key === STORAGE_KEY) renderReadingInsights();
  });
</script>

<style is:global>
  .rd-layout { display: grid; grid-template-columns: 1fr; gap: 1rem; align-items: start; }
  @media (min-width: 1100px) { .rd-layout { grid-template-columns: minmax(0, 4fr) minmax(250px, 1fr); gap: 1.25rem; } }
  .rd-main section[aria-labelledby="tracker-title"] { margin-bottom: 0; }
  .rd-side { display: grid; gap: 0.75rem; }
  @media (min-width: 1100px) { .rd-side { position: sticky; top: 5.25rem; } }
  .rd-side-title { font-size: 1rem; font-weight: 800; color: #0f172a; margin: 0; }
  .rd-card { border: 1px solid #dbe4ef; border-radius: 12px; background: #fff; padding: 0.75rem; box-shadow: 0 10px 28px -24px rgba(15, 23, 42, 0.7); }
  .rd-note-tight { margin-top: 0.2rem; }
  .rd-challenge-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.4rem; }
  .rd-challenge-goal-row { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 0.4rem; margin-bottom: 0.45rem; }
  .rd-goal-input { border: 1px solid #cbd5e1; border-radius: 9px; padding: 0.42rem 0.6rem; font-size: 0.8rem; color: #0f172a; background: #fff; }
  .rd-goal-input:focus { outline: 2px solid #bfdbfe; outline-offset: 1px; border-color: #93c5fd; }
  .rd-goal-btn { border: 1px solid #1d4ed8; border-radius: 9px; background: #2563eb; color: #fff; padding: 0.42rem 0.68rem; font-size: 0.76rem; font-weight: 700; }
  .rd-challenge-stats { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.35rem; margin-bottom: 0.45rem; }
  .rd-stat { border: 1px solid #dbe4ef; border-radius: 8px; background: #f8fafc; padding: 0.3rem 0.35rem; display: grid; gap: 0.02rem; }
  .rd-stat span { color: #64748b; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 700; }
  .rd-stat strong { color: #0f172a; font-size: 0.86rem; font-weight: 800; }
  .rd-challenge-track { height: 8px; border-radius: 999px; background: #e2e8f0; overflow: hidden; margin-bottom: 0.35rem; }
  .rd-challenge-fill { display: block; height: 100%; border-radius: 999px; background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%); }
  .rd-title { font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.04em; color: #475569; font-weight: 700; margin: 0 0 0.6rem 0; }
  .rd-bars { display: grid; gap: 0.45rem; }
  .rd-row { display: grid; grid-template-columns: minmax(0, 1.2fr) minmax(0, 1.7fr) auto; gap: 0.4rem; align-items: center; }
  .rd-name { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 0.75rem; color: #334155; font-weight: 700; }
  .rd-track { display: block; height: 8px; border-radius: 999px; background: #e2e8f0; overflow: hidden; }
  .rd-fill { display: block; height: 100%; border-radius: 999px; background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%); }
  .rd-metric { font-size: 0.72rem; color: #334155; font-weight: 700; min-width: 2.2rem; text-align: right; }
  .rd-pie-wrap { display: grid; grid-template-columns: 92px minmax(0, 1fr); gap: 0.55rem; align-items: center; }
  .rd-pie { width: 92px; height: 92px; border-radius: 999px; border: 1px solid #dbe4ef; position: relative; background: #e2e8f0; }
  .rd-pie-center { position: absolute; inset: 23%; border-radius: 999px; border: 1px solid #e2e8f0; background: #fff; display: flex; flex-direction: column; align-items: center; justify-content: center; line-height: 1.1; text-align: center; }
  .rd-pie-center strong { color: #0f172a; font-size: 0.7rem; font-weight: 800; }
  .rd-pie-center span { color: #64748b; font-size: 0.58rem; }
  .rd-legend { display: grid; gap: 0.25rem; }
  .rd-leg-row { display: grid; grid-template-columns: auto minmax(0, 1fr) auto; gap: 0.35rem; align-items: center; font-size: 0.68rem; }
  .rd-dot { width: 7px; height: 7px; border-radius: 50%; }
  .rd-leg-name { color: #334155; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .rd-leg-val { color: #64748b; font-weight: 700; }
  .rd-14d { height: 96px; display: grid; grid-template-columns: repeat(14, minmax(0, 1fr)); align-items: end; gap: 3px; }
  .rd-day-col { display: flex; flex-direction: column; align-items: center; justify-content: flex-end; gap: 3px; }
  .rd-legend-inline { display: flex; align-items: center; gap: 0.65rem; margin: -0.2rem 0 0.45rem; font-size: 0.62rem; color: #64748b; font-weight: 700; }
  .rd-legend-inline span { display: inline-flex; align-items: center; gap: 0.25rem; }
  .rd-legend-swatch { width: 9px; height: 9px; border-radius: 999px; display: inline-block; }
  .rd-legend-swatch--pages { background: #2563eb; }
  .rd-legend-swatch--audio { background: #16a34a; }
  .rd-day-bars { width: 100%; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 2px; align-items: end; }
  .rd-day-bar { width: 100%; border-radius: 3px 3px 0 0; min-height: 0; }
  .rd-day-bar--pages { background: linear-gradient(180deg, #60a5fa 0%, #2563eb 100%); }
  .rd-day-bar--audio { background: linear-gradient(180deg, #4ade80 0%, #16a34a 100%); }
  .rd-day-label { font-size: 0.58rem; color: #64748b; }
  .rd-empty { margin: 0; font-size: 0.76rem; color: #64748b; }
  .rd-note { margin-top: 0.45rem; font-size: 0.68rem; color: #64748b; }
</style>
