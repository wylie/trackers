<script type="application/json" id="tracker-card-config" set:html={JSON.stringify(trackerCardConfig)}></script>
<script>
  import { initTrackerCard } from "../lib/tracker-card/client.js";

  const configEl = document.getElementById("tracker-card-config");
  if (configEl) {
    try {
      const config = JSON.parse(configEl.textContent || "{}");
      initTrackerCard(config);
    } catch {
      // If parsing fails, leave the form usable without JS enhancements.
    }
  }
</script>
