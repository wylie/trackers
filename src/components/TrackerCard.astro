---
const {
  title,
  description,
  storageKey,
  icon = 'track_changes',
  fieldNames = ["item", "notes"],
  addLabel = "Add New Item",
  itemPlaceholder = "Item",
  enableOmdbAutocomplete = false,
  omdbApiKey = "",
  autocompleteEndpoint = "",
  enableAuthorField = false,
  authorPlaceholder = "Author",
  autoPopulateAuthor = false,
  enableDirectorField = false,
  directorPlaceholder = "Director",
  autoPopulateDirector = false,
  enablePublisherField = false,
  publisherPlaceholder = "Publisher",
  autoPopulatePublisher = false,
  enableCategoryField = false,
  categoryPlaceholder = "Category",
  categoryOptions = [],
  enableReadingProgress = false,
  autoPopulateTotalPages = false
} = Astro.props;
const autocompleteEnabled = enableOmdbAutocomplete || Boolean(autocompleteEndpoint);
const isSleepTracker = storageKey === "sleep-tracker-entries";
const isReadingTracker = storageKey === "reading-tracker-entries";
const isMovieTracker = storageKey === "movie-watch-tracker-entries";
const isVideoGameTracker = storageKey === "video-game-tracker-entries";
const isWorkoutTracker = storageKey === "workout-tracker-entries";
const isTaskTracker = storageKey === "task-tracker-entries";
const isFinanceTracker = storageKey === "finance-tracker-entries";
const isHealthTracker = storageKey === "health-tracker-entries";
const hidesRating = isSleepTracker || isTaskTracker || isFinanceTracker || isHealthTracker;
const sleepHourOptions = Array.from({ length: 25 }, (_, value) => value);
const sleepMinuteOptions = Array.from({ length: 60 }, (_, value) => value);
const sleepSettingsKey = "sleep-tracker-settings";
const progressHourOptions = Array.from({ length: 101 }, (_, value) => value);
const progressMinuteOptions = Array.from({ length: 60 }, (_, value) => value);
const normalizedCategoryOptions = Array.isArray(categoryOptions)
  ? categoryOptions.map((option) => String(option || "").trim()).filter(Boolean)
  : [];
normalizedCategoryOptions.sort((a, b) => a.localeCompare(b));
---

<section aria-labelledby="tracker-title" class="bg-white rounded-lg border border-gray-200 shadow-sm p-6 mb-8">
  <h2 id="tracker-title" class="flex items-center gap-2 text-lg font-semibold mb-2 text-gray-900">
    <span class="material-icons icon-blue">{icon}</span>
    <style>
      .icon-blue {
        color: #2563eb !important;
        font-size: 1.5rem;
        margin-right: 0.5rem;
      }
    </style>
    {title}
  </h2>
  <p class="text-gray-700 mb-4">{description}</p>
  {isSleepTracker && (
    <div class="mb-5 rounded-lg border border-blue-100 bg-blue-50/60 p-4">
      <div class="flex flex-col gap-3">
        <div>
          <h3 class="text-sm font-semibold text-slate-900">Nightly Sleep Goal</h3>
          <p class="text-sm text-slate-600">Set your target once and each sleep entry will be graded against it.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_auto] gap-2 items-end">
          <div class="flex flex-col gap-1">
            <label for="tracker-goal-hours" class="text-sm text-gray-700">Goal Hours</label>
            <div class="relative">
              <select
                id="tracker-goal-hours"
                class="tracker-select border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full"
              >
                {sleepHourOptions.map((value) => (
                  <option value={value}>{value} {value === 1 ? "hour" : "hours"}</option>
                ))}
              </select>
              <span class="tracker-select-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
            </div>
          </div>
          <div class="flex flex-col gap-1">
            <label for="tracker-goal-minutes" class="text-sm text-gray-700">Goal Minutes</label>
            <div class="relative">
              <select
                id="tracker-goal-minutes"
                class="tracker-select border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full"
              >
                {sleepMinuteOptions.map((value) => (
                  <option value={value}>{value.toString().padStart(2, "0")} min</option>
                ))}
              </select>
              <span class="tracker-select-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
            </div>
          </div>
          <button
            id="tracker-save-goal"
            type="button"
            class="px-4 py-2 bg-slate-900 text-white rounded-md font-medium hover:bg-slate-800 transition whitespace-nowrap"
          >
            Save Goal
          </button>
        </div>
        <p id="tracker-goal-summary" class="text-sm text-slate-600"></p>
        <p id="tracker-goal-message" class="hidden text-sm font-medium text-green-700"></p>
      </div>
    </div>
  )}
  <form id="tracker-form" class="flex flex-col gap-2 mb-4">
    <div class="flex flex-col gap-1">
      <label for="tracker-entry-date" class="text-sm text-gray-700">Entry Date</label>
      <input
        type="date"
        id="tracker-entry-date"
        class="tracker-date-input border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 bg-white text-gray-900"
      />
    </div>
    {isSleepTracker ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <div class="flex flex-col gap-1">
          <label for="tracker-sleep-hours" class="text-sm text-gray-700">Hours Slept</label>
          <div class="relative">
            <select
              id="tracker-sleep-hours"
              class="tracker-select border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full"
            >
              {sleepHourOptions.map((value) => (
                <option value={value}>{value} {value === 1 ? "hour" : "hours"}</option>
              ))}
            </select>
            <span class="tracker-select-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
          </div>
        </div>
        <div class="flex flex-col gap-1">
          <label for="tracker-sleep-minutes" class="text-sm text-gray-700">Minutes Slept</label>
          <div class="relative">
            <select
              id="tracker-sleep-minutes"
              class="tracker-select border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full"
            >
              {sleepMinuteOptions.map((value) => (
                <option value={value}>{value.toString().padStart(2, "0")} min</option>
              ))}
            </select>
            <span class="tracker-select-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
          </div>
        </div>
      </div>
    ) : (
      <div class="relative">
        <input
          type="text"
          id="tracker-item"
          placeholder={itemPlaceholder}
          autocomplete={autocompleteEnabled ? "off" : "on"}
          aria-autocomplete={autocompleteEnabled ? "list" : undefined}
          aria-expanded={autocompleteEnabled ? "false" : undefined}
          class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full"
        />
        {autocompleteEnabled && (
          <div
            id="tracker-item-suggestions"
            class="hidden absolute left-0 right-0 top-[calc(100%+0.3rem)] z-20 bg-white border border-gray-200 rounded-md shadow-lg overflow-hidden"
          >
            <ul id="tracker-item-suggestions-list" class="max-h-64 overflow-y-auto py-1"></ul>
          </div>
        )}
      </div>
    )}
    {isTaskTracker && (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <div class="flex flex-col gap-1">
          <label for="tracker-due-date" class="text-sm text-gray-700">Due Date</label>
          <input
            type="date"
            id="tracker-due-date"
            class="tracker-date-input border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 bg-white text-gray-900"
          />
        </div>
      </div>
    )}
    {enableAuthorField && (
      <input
        type="text"
        id="tracker-author"
        placeholder={authorPlaceholder}
        class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200"
      />
    )}
    {enableDirectorField && (
      <input
        type="text"
        id="tracker-director"
        placeholder={directorPlaceholder}
        class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200"
      />
    )}
    {enablePublisherField && (
      <input
        type="text"
        id="tracker-publisher"
        placeholder={publisherPlaceholder}
        class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200"
      />
    )}
    {enableCategoryField && (
      <div class="flex flex-col gap-1">
        <label for="tracker-category" class="text-sm text-gray-700">{categoryPlaceholder}</label>
        <div class="relative">
          <select
            id="tracker-category"
            class="tracker-select border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full"
            required
          >
            <option value="">Select category</option>
            {normalizedCategoryOptions.map((option) => (
              <option value={option}>{option}</option>
            ))}
          </select>
          <span class="tracker-select-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
        </div>
      </div>
    )}
    {isWorkoutTracker && (
      <div id="tracker-workout-metrics" class="hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
        <div id="tracker-workout-duration-wrap" class="flex flex-col gap-1">
          <label class="text-sm text-gray-700">Duration (h:m:s)</label>
          <div class="grid grid-cols-3 gap-2">
            <input type="number" id="tracker-workout-duration-hours" min="0" step="1" placeholder="h" class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
            <input type="number" id="tracker-workout-duration-minutes" min="0" max="59" step="1" placeholder="m" class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
            <input type="number" id="tracker-workout-duration-seconds" min="0" max="59" step="1" placeholder="s" class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
          </div>
        </div>
        <div id="tracker-workout-distance-wrap" class="flex flex-col gap-1">
          <label for="tracker-workout-distance" class="text-sm text-gray-700">Distance (miles)</label>
          <input type="number" id="tracker-workout-distance" min="0" step="0.01" placeholder="Example: 3.04" class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
        </div>
        <div id="tracker-workout-laps-wrap" class="flex flex-col gap-1">
          <label for="tracker-workout-laps" class="text-sm text-gray-700">Laps</label>
          <input type="number" id="tracker-workout-laps" min="0" step="1" placeholder="Example: 20" class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
        </div>
        <div id="tracker-workout-sets-wrap" class="flex flex-col gap-1">
          <label for="tracker-workout-sets" class="text-sm text-gray-700">Sets</label>
          <input type="number" id="tracker-workout-sets" min="0" step="1" placeholder="Example: 5" class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
        </div>
        <div id="tracker-workout-reps-wrap" class="flex flex-col gap-1">
          <label for="tracker-workout-reps" class="text-sm text-gray-700">Reps</label>
          <input type="number" id="tracker-workout-reps" min="0" step="1" placeholder="Example: 10" class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
        </div>
        <div id="tracker-workout-weight-wrap" class="flex flex-col gap-1">
          <label for="tracker-workout-weight" class="text-sm text-gray-700">Weight (lbs)</label>
          <input type="number" id="tracker-workout-weight" min="0" step="1" placeholder="Example: 135" class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
        </div>
      </div>
    )}
    {isVideoGameTracker && (
      <div class="grid grid-cols-1 sm:grid-cols-[minmax(0,1fr)_auto] gap-2 items-end">
        <div class="flex flex-col gap-1">
          <label for="tracker-session-hours" class="text-sm text-gray-700">Hours Played This Session</label>
          <input
            type="number"
            id="tracker-session-hours"
            min="0"
            step="0.25"
            placeholder="Example: 1.5"
            class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200"
          />
        </div>
        <div class="text-sm text-slate-500 pb-2">If the game already exists, this adds time to that game.</div>
      </div>
    )}
    {enableReadingProgress && (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <div class="sm:col-span-2 flex items-center gap-2 mt-1">
          <input type="checkbox" id="tracker-currently-reading" class="h-4 w-4 accent-blue-600" checked />
          <label for="tracker-currently-reading" class="text-sm text-gray-700">Currently reading (not finished)</label>
        </div>
        {isReadingTracker && (
          <div class="sm:col-span-2 flex items-center gap-2">
            <input type="checkbox" id="tracker-is-audiobook" class="h-4 w-4 accent-blue-600" />
            <label for="tracker-is-audiobook" class="text-sm text-gray-700">Audiobook</label>
          </div>
        )}
        <div id="tracker-reading-progress-fields" class="contents lg:grid lg:grid-cols-3 lg:gap-2 lg:sm:col-span-2">
          <div class="flex flex-col gap-1">
            <label for="tracker-started-date" class="text-sm text-gray-700">Started Reading</label>
            <input type="date" id="tracker-started-date" class="tracker-date-input reading-progress-input border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 bg-white text-gray-900" />
          </div>
          <div id="tracker-page-progress-field" class="flex flex-col gap-1">
            <label id="tracker-current-page-label" for="tracker-current-page" class="text-sm text-gray-700">Current Page</label>
            <input type="number" min="0" step="1" id="tracker-current-page" placeholder="0" class="reading-progress-input border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
          </div>
          <div id="tracker-total-page-field" class="flex flex-col gap-1 sm:col-span-2 lg:col-span-1">
            <label id="tracker-total-pages-label" for="tracker-total-pages" class="text-sm text-gray-700">Total Pages</label>
            <input type="number" min="1" step="1" id="tracker-total-pages" placeholder="0" class="reading-progress-input border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
          </div>
          {isReadingTracker && (
            <>
              <div id="tracker-current-audio-field" class="hidden flex flex-col gap-1 lg:col-span-1">
                <label class="text-sm text-gray-700">Time Left</label>
                <div class="grid grid-cols-2 gap-2">
                  <div class="relative">
                    <select id="tracker-current-hours" class="tracker-select border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full">
                      {progressHourOptions.map((value) => (
                        <option value={value}>{value}h</option>
                      ))}
                    </select>
                    <span class="tracker-select-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
                  </div>
                  <div class="relative">
                    <select id="tracker-current-minutes" class="tracker-select border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full">
                      {progressMinuteOptions.map((value) => (
                        <option value={value}>{value.toString().padStart(2, "0")}m</option>
                      ))}
                    </select>
                    <span class="tracker-select-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
                  </div>
                </div>
              </div>
              <div id="tracker-total-audio-field" class="hidden flex flex-col gap-1 sm:col-span-2 lg:col-span-1">
                <label class="text-sm text-gray-700">Total Time</label>
                <div class="grid grid-cols-2 gap-2">
                  <div class="relative">
                    <select id="tracker-total-hours" class="tracker-select border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full">
                      {progressHourOptions.map((value) => (
                        <option value={value}>{value}h</option>
                      ))}
                    </select>
                    <span class="tracker-select-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
                  </div>
                  <div class="relative">
                    <select id="tracker-total-minutes" class="tracker-select border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full">
                      {progressMinuteOptions.map((value) => (
                        <option value={value}>{value.toString().padStart(2, "0")}m</option>
                      ))}
                    </select>
                    <span class="tracker-select-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
                  </div>
                </div>
              </div>
            </>
          )}
        </div>
        <div id="tracker-finished-fields" class="sm:col-span-2">
          <div class="flex flex-col gap-1">
            <label for="tracker-finished-date" class="text-sm text-gray-700">Finished Reading</label>
            <input type="date" id="tracker-finished-date" class="tracker-date-input reading-progress-input border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 bg-white text-gray-900" />
          </div>
        </div>
      </div>
    )}
    <input type="text" id="tracker-notes" placeholder="Notes" class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
    <div id="tracker-rating-row" class:list={["flex items-center gap-2 mb-2", { hidden: hidesRating }]}>
      <label for="tracker-rating" class="text-gray-700">Rating:</label>
      <div id="tracker-rating-stars" class="flex gap-1"></div>
      <input type="hidden" id="tracker-rating" value="0" />
    </div>
    <div class="mt-2 flex items-center gap-2">
      <button id="tracker-submit" type="submit" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-md font-medium hover:bg-blue-700 transition">{addLabel}</button>
      <button id="tracker-cancel-edit" type="button" class="hidden px-4 py-2 bg-gray-200 text-gray-700 rounded-md font-medium hover:bg-gray-300 transition">Cancel</button>
    </div>
  </form>
  {isTaskTracker && (
    <div class="mb-3 grid grid-cols-1 sm:grid-cols-2 gap-2">
      <div class="flex flex-col gap-1">
        <label for="tracker-task-filter" class="text-sm text-gray-700">Filter</label>
        <div class="relative">
          <select id="tracker-task-filter" class="tracker-select border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full">
            <option value="active">Active</option>
            <option value="completed">Completed</option>
            <option value="all">All</option>
          </select>
          <span class="tracker-select-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
        </div>
      </div>
      <div class="flex flex-col gap-1">
        <label for="tracker-task-sort" class="text-sm text-gray-700">Sort</label>
        <div class="relative">
          <select id="tracker-task-sort" class="tracker-select border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full">
            <option value="due-soonest">Due Date (Soonest)</option>
            <option value="due-latest">Due Date (Latest)</option>
            <option value="newest">Newest Added</option>
            <option value="oldest">Oldest Added</option>
            <option value="alpha">Task Name (A-Z)</option>
          </select>
          <span class="tracker-select-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
        </div>
      </div>
    </div>
  )}
  <ul id="tracker-list" class="list-none p-0 mb-4"></ul>
<style>
  :global(.star) {
    font-size: 1.3rem;
    color: #ccc !important;
    cursor: default;
    transition: color 0.2s;
  }
  :global(button.star) {
    width: 1.75rem;
    height: 1.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    padding: 0;
    line-height: 1;
    cursor: pointer;
  }
  :global(button.star:focus) {
    outline: 2px solid #93c5fd;
    outline-offset: 1px;
  }
  :global(.star.active) {
    color: #999 !important;
  }
  :global(.star.hovered) {
    color: #999 !important;
  }
  :global(.star.inactive) {
    color: #999 !important;
  }
  :global(.omdb-option) {
    width: 100%;
    border: 0;
    background: transparent;
    padding: 0.5rem 0.75rem;
    text-align: left;
    color: #1f2937;
    font-size: 0.875rem;
    line-height: 1.25rem;
    cursor: pointer;
  }
  :global(.omdb-option:hover),
  :global(.omdb-option.is-active) {
    background: #eff6ff;
    color: #1d4ed8;
  }
  :global(.omdb-option-subtitle) {
    display: block;
    color: #6b7280;
    font-size: 0.75rem;
    line-height: 1rem;
    margin-top: 0.1rem;
  }
  .reading-progress-input {
    height: 44px;
  }
  .tracker-select {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    background-color: #fff;
    color: #111827;
    height: 44px;
    padding-right: 2.75rem;
  }
  .tracker-select-icon {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: #111827;
    font-size: 1.375rem;
    pointer-events: none;
  }
  .tracker-date-input {
    background-color: #fff;
    color: #111827;
    -webkit-text-fill-color: #111827;
    color-scheme: light;
    opacity: 1;
  }
  .tracker-date-input:disabled {
    background-color: #f1f5f9;
    color: #94a3b8;
    -webkit-text-fill-color: #94a3b8;
    opacity: 1;
  }
  .tracker-date-input::-webkit-date-and-time-value {
    text-align: left;
  }
  .tracker-date-input::-webkit-calendar-picker-indicator {
    opacity: 1;
  }
  :global(.tracker-metric-badges) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.2rem;
  }
  :global(.tracker-metric-pill) {
    display: inline-flex;
    align-items: center;
    border: 1px solid #dbe4ef;
    border-radius: 999px;
    background: #f8fafc;
    color: #334155;
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1;
    padding: 0.26rem 0.48rem;
  }
  :global(.reading-cover-shell) {
    width: calc(100% - 88px);
    max-width: calc(100% - 88px);
    min-width: 0;
    height: 132px;
    border-radius: 0.5rem;
    overflow: hidden;
