---
import Layout from '../../components/Layout.astro';
---

<Layout>
  <main>
    <h1>Privacy Policy</h1>
    <section>
      <h2>Data Storage</h2>
      <p>All tracker data is stored in your browser using localStorage. No accounts, no external database.</p>
    </section>
    <section>
      <h2>Cookies</h2>
      <p>SimpleTrackers.io may use cookies for site functionality and analytics. No personal data is collected.</p>
    </section>
    <section>
      <h2>Ads</h2>
      <p>AdSense placeholders are shown in development. Future ad usage will be disclosed here.</p>
    </section>
    <section>
      <h2>Your Privacy</h2>
      <p>We value your privacy. No login required, no data sent to servers.</p>
    </section>
  </main>
</Layout>