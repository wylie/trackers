---
import StandardTrackerPage from '../../components/tracker-pages/StandardTrackerPage.astro';
import { getRelatedCalculators } from '../../data/related-calculators';

const steps = [
  "Add a new health entry.",
  "Track your health habits.",
  "Edit or delete entries as needed.",
  "Your data is saved locally in your browser.",
  "No account or login required."
];
const benefits = [
  "Simple, distraction-free interface",
  "Private: your data never leaves your device",
  "No registration or login required",
  "Monitor your health trends"
];
const related = [
  { name: "Workout Tracker", url: "/workout-tracker", icon: "fitness_center" },
  { name: "Meal Tracker", url: "/meal-tracker", icon: "restaurant" },
  { name: "Habit Tracker", url: "/habit-tracker", icon: "check_circle" },
  { name: "Finance Tracker", url: "/finance-tracker", icon: "attach_money" }
];
---

<StandardTrackerPage
  seoTitle="Health Tracker"
  seoDescription="Track your health habits privately and easily. No login, no accounts, data stays in your browser."
  pageTitle="Health Tracker"
  pageDescription="Track your health habits privately and easily. No login, no accounts, data stays in your browser."
  storageKey="health-tracker-entries"
  trackerCardProps={{
    title: "Health Log",
    description: "Log your health habits, progress, and notes.",
    icon: "favorite",
    itemPlaceholder: "Health Entry"
  }}
  steps={steps}
  benefits={benefits}
  related={related}
  relatedCalculators={getRelatedCalculators("health-tracker")}
/>
