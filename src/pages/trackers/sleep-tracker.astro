---
import StandardTrackerPage from '../../components/tracker-pages/StandardTrackerPage.astro';
import { getRelatedCalculators } from '../../data/related-calculators';

const steps = [
  "Add a new sleep entry.",
  "Track your sleep patterns.",
  "Edit or delete entries as needed.",
  "Your data is saved locally in your browser.",
  "No account or login required."
];
const benefits = [
  "Simple, distraction-free interface",
  "Private: your data never leaves your device",
  "No registration or login required",
  "Improve your sleep habits"
];
const related = [
  { name: "Habit Tracker", url: "/habit-tracker", icon: "check_circle" },
  { name: "Health Tracker", url: "/health-tracker", icon: "favorite" },
  { name: "Workout Tracker", url: "/workout-tracker", icon: "fitness_center" },
  { name: "Meal Tracker", url: "/meal-tracker", icon: "restaurant" }
];
---

<StandardTrackerPage
  seoTitle="Sleep Tracker"
  seoDescription="Track your sleep patterns privately and easily. No login, no accounts, data stays in your browser."
  pageTitle="Sleep Tracker"
  pageDescription="Track your sleep patterns privately and easily. No login, no accounts, data stays in your browser."
  storageKey="sleep-tracker-entries"
  trackerCardProps={{
    title: "Sleep Log",
    description: "Log your sleep, patterns, and notes.",
    icon: "bed",
    itemPlaceholder: "Sleep"
  }}
  steps={steps}
  benefits={benefits}
  related={related}
  relatedCalculators={getRelatedCalculators("sleep-tracker")}
/>
