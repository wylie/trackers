---
import Layout from '../../components/Layout.astro';
---

<Layout seoTitle="Terms" seoDescription="Terms of service for using SimpleTrackers.">
  <main class="max-w-3xl mx-auto w-full px-4 py-8">
    <h1 class="text-[30px] leading-[1.2] font-extrabold text-slate-900 mb-2">Terms</h1>
    <p class="text-[18px] leading-[1.45] text-slate-600 mb-6">By using SimpleTrackers, you agree to the terms below.</p>

    <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
      <ul class="list-disc pl-5 space-y-2 text-[15px] leading-7 text-slate-600">
        <li>SimpleTrackers is provided as-is, without warranty.</li>
        <li>All data stays in your browser and you are responsible for backups.</li>
        <li>We are not liable for data loss or misuse.</li>
      </ul>
      <p class="mt-4 text-[15px] leading-7 text-slate-600">If you do not agree with these terms, please do not use the site.</p>
    </section>
  </main>
</Layout>
