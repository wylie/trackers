---
import StandardTrackerPage from '../../components/tracker-pages/StandardTrackerPage.astro';
import { getRelatedCalculators } from '../../data/related-calculators';

const steps = [
  "Add a new task.",
  "Mark tasks as complete.",
  "Edit or delete tasks as needed.",
  "Your data is saved locally in your browser.",
  "No account or login required."
];
const benefits = [
  "Simple, distraction-free interface",
  "Private: your data never leaves your device",
  "No registration or login required",
  "Stay organized and productive"
];
const related = [
  { name: "Habit Tracker", url: "/habit-tracker", icon: "check_circle" },
  { name: "Workout Tracker", url: "/workout-tracker", icon: "fitness_center" },
  { name: "Health Tracker", url: "/health-tracker", icon: "favorite" },
  { name: "Meal Tracker", url: "/meal-tracker", icon: "restaurant" }
];
---

<StandardTrackerPage
  seoTitle="Task Tracker"
  seoDescription="Track your tasks privately and easily. No login, no accounts, data stays in your browser."
  pageTitle="Task Tracker"
  pageDescription="Track your tasks privately and easily. No login, no accounts, data stays in your browser."
  storageKey="task-tracker-entries"
  trackerCardProps={{
    title: "Task Log",
    description: "Log your tasks, progress, and notes.",
    icon: "assignment",
    itemPlaceholder: "Task"
  }}
  steps={steps}
  benefits={benefits}
  related={related}
  relatedCalculators={getRelatedCalculators("task-tracker")}
/>
