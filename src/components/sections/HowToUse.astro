---
const { steps } = Astro.props;
---
<section class="bg-white rounded-lg shadow border border-gray-200 p-6">
  <h2 class="text-xl font-bold mb-2 text-gray-900">How to Use</h2>
  <ol class="list-decimal pl-6 text-base text-gray-700">
    {steps.map(step => <li class="mb-1">{step}</li>)}
  </ol>
</section>
