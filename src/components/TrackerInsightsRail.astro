---
import { getTrackerFlags } from '../lib/tracker-flags';
import SupportButton from './SupportButton.astro';
import TrackerBadgesCard from './TrackerBadgesCard.astro';

const { storageKey, heading = "Insights" } = Astro.props;
const idPrefix = `ti-${String(storageKey || "tracker").replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`;
const { isWorkoutTracker } = getTrackerFlags(storageKey);
const trackerInsightsConfig = { storageKey, idPrefix, isWorkoutTracker };
const topItemsTitle = String(storageKey || "") === "finance-tracker-entries"
  ? "Top Logged Categories"
  : "Top Logged Items";
const last14NoteByTracker = {
  "water-tracker-entries": "Hydration logged per day.",
  "sleep-tracker-entries": "Sleep duration per day.",
  "workout-tracker-entries": "Workout duration per day.",
  "video-game-tracker-entries": "Session hours per day."
};
const last14Note = last14NoteByTracker[String(storageKey || "")] || "Days with logged activity.";
---

<aside class="ti-side" aria-label={`${heading} for this tracker`}>
  <h2 class="ti-side-title">{heading}</h2>

  <div id={`${idPrefix}-insights-list`} class="ti-insights-list">
    <div class="ti-insight-item" data-insight-id="overview">
      <span class="ti-insight-grip" aria-hidden="true" title="Drag to reorder">⋮⋮</span>
      <div class="ti-card">
        <h3 class="ti-title">Overview</h3>
        <div id={`${idPrefix}-overview`} class="ti-overview"></div>
      </div>
    </div>

    {isWorkoutTracker && (
      <div class="ti-insight-item" data-insight-id="time-worked-out">
        <span class="ti-insight-grip" aria-hidden="true" title="Drag to reorder">⋮⋮</span>
        <div class="ti-card">
          <h3 class="ti-title">Time Worked Out</h3>
          <div class="ti-range-toggle" id={`${idPrefix}-range-toggle`} role="group" aria-label="Workout time range">
            <button type="button" class="ti-toggle-btn is-active" data-range="day">Day</button>
            <button type="button" class="ti-toggle-btn" data-range="week">Week</button>
            <button type="button" class="ti-toggle-btn" data-range="month">Month</button>
            <button type="button" class="ti-toggle-btn" data-range="year">Year</button>
          </div>
          <div id={`${idPrefix}-workout-total`} class="ti-workout-total"></div>
          <p class="ti-note">Total duration from logged workout entries.</p>
        </div>
      </div>
    )}

    <div class="ti-insight-item" data-insight-id="top-items">
      <span class="ti-insight-grip" aria-hidden="true" title="Drag to reorder">⋮⋮</span>
      <div class="ti-card">
        <h3 class="ti-title">{topItemsTitle}</h3>
        <div id={`${idPrefix}-top-items`} class="ti-bars"></div>
      </div>
    </div>

    <div class="ti-insight-item" data-insight-id="last-14-days">
      <span class="ti-insight-grip" aria-hidden="true" title="Drag to reorder">⋮⋮</span>
      <div class="ti-card">
        <h3 class="ti-title">Last 14 Days</h3>
        <div class="ti-14d-wrap">
          <div id={`${idPrefix}-last-14`} class="ti-14d"></div>
          <div id={`${idPrefix}-last-14-goal-line`} class="ti-goal-line hidden">
            <span id={`${idPrefix}-last-14-goal-label`} class="ti-goal-line-label"></span>
          </div>
        </div>
        <p class="ti-note">{last14Note}</p>
      </div>
    </div>

    <div class="ti-insight-item" data-insight-id="badges">
      <span class="ti-insight-grip" aria-hidden="true" title="Drag to reorder">⋮⋮</span>
      <TrackerBadgesCard storageKey={storageKey} />
    </div>

    <div class="ti-insight-item" data-insight-id="support">
      <span class="ti-insight-grip" aria-hidden="true" title="Drag to reorder">⋮⋮</span>
      <SupportButton />
    </div>
  </div>
</aside>

<script type="application/json" id={`${idPrefix}-insights-config`} set:html={JSON.stringify(trackerInsightsConfig)}></script>
<script>
  import { initTrackerInsightsRail } from "../lib/tracker-insights/client.js";

  const configEl = document.querySelector('[id$="-insights-config"]');
  if (configEl) {
    try {
      const config = JSON.parse(configEl.textContent || "{}");
      initTrackerInsightsRail(config);
    } catch {
      // Keep page functional if config parsing fails.
    }
  }
</script>

<style is:global>
  .tracker-insights-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-items: start;
  }

  @media (min-width: 1100px) {
    .tracker-insights-layout {
      grid-template-columns: minmax(0, 4fr) minmax(250px, 1fr);
      gap: 1.25rem;
    }
  }

  .tracker-insights-main section[aria-labelledby="tracker-title"] {
    margin-bottom: 0;
  }

  .ti-side {
    display: grid;
    gap: 0.75rem;
  }
  .ti-insights-list {
    display: grid;
    gap: 0.75rem;
  }
  .ti-insight-item {
    position: relative;
    cursor: grab;
  }
  .ti-insight-item > *:not(.ti-insight-grip) {
    position: relative;
    z-index: 2;
    transition: box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .ti-insight-item:hover > *:not(.ti-insight-grip) {
    box-shadow: inset 0 1.9rem 0 rgba(241, 245, 249, 0.75), 0 10px 28px -24px rgba(15, 23, 42, 0.7);
  }
  .ti-insight-grip {
    position: absolute;
    top: 0.4rem;
    right: 0.5rem;
    z-index: 4;
    color: #64748b;
    font-size: 0.95rem;
    line-height: 1;
    letter-spacing: -1px;
    font-weight: 700;
    user-select: none;
    pointer-events: none;
    opacity: 0.65;
    transition: opacity 0.18s ease, color 0.18s ease;
  }
  .ti-insight-item:hover .ti-insight-grip {
    opacity: 1;
    color: #475569;
  }
  .ti-insight-item.is-dragging {
    opacity: 0.72;
  }
  .ti-insight-item.is-dragging > *:not(.ti-insight-grip) {
    box-shadow: 0 14px 28px -20px rgba(37, 99, 235, 0.65);
    border-color: #93c5fd;
  }
  .ti-insight-item.is-drop-before::after {
    content: "";
    position: absolute;
    top: -0.4rem;
    left: 0.5rem;
    right: 0.5rem;
    height: 3px;
    border-radius: 999px;
    background: #60a5fa;
    z-index: 3;
    pointer-events: none;
  }
  .ti-insight-item:active {
    cursor: grabbing;
  }

  @media (min-width: 1100px) {
    .ti-side {
      position: sticky;
      top: 5.25rem;
    }
  }

  .ti-side-title {
    font-size: 1rem;
    font-weight: 800;
    color: #0f172a;
    margin: 0;
  }

  .ti-card {
    border: 1px solid #dbe4ef;
    border-radius: 12px;
    background: #fff;
    padding: 0.75rem;
    box-shadow: 0 10px 28px -24px rgba(15, 23, 42, 0.7);
  }

  .ti-title {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #475569;
    font-weight: 700;
    margin: 0 0 0.6rem 0;
  }

  .ti-overview-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.4rem;
  }

  .ti-overview-grid--2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .ti-pill {
    border: 1px solid #dbe4ef;
    border-radius: 9px;
    background: #f8fafc;
    padding: 0.35rem 0.4rem;
    display: grid;
    gap: 0.08rem;
  }

  .ti-pill span {
    font-size: 0.62rem;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 700;
  }

  .ti-pill strong {
    font-size: 0.8rem;
    color: #0f172a;
    font-weight: 800;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ti-bars {
    display: grid;
    gap: 0.45rem;
  }

  .ti-row {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1.7fr) auto;
    gap: 0.4rem;
    align-items: center;
  }

  .ti-name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 0.75rem;
    color: #334155;
    font-weight: 700;
  }

  .ti-track {
    display: block;
    height: 8px;
    border-radius: 999px;
    background: #e2e8f0;
    overflow: hidden;
  }

  .ti-fill {
    display: block;
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%);
  }

  .ti-metric {
    font-size: 0.72rem;
    color: #334155;
    font-weight: 700;
    min-width: 1.3rem;
    text-align: right;
  }

  .ti-14d {
    height: 96px;
    display: grid;
    grid-template-columns: repeat(14, minmax(0, 1fr));
    align-items: end;
    gap: 3px;
  }

  .ti-14d-wrap {
    position: relative;
  }

  .ti-goal-line {
    position: absolute;
    left: 0;
    right: 0;
    border-top: 1px dashed rgba(16, 185, 129, 0.8);
    pointer-events: none;
    z-index: 1;
  }

  .ti-goal-line-label {
    position: absolute;
    left: 0;
    top: -0.78rem;
    font-size: 0.58rem;
    line-height: 1;
    color: #047857;
    background: rgba(236, 253, 245, 0.95);
    border: 1px solid rgba(16, 185, 129, 0.45);
    border-radius: 999px;
    padding: 0.08rem 0.32rem;
  }

  .ti-day-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 3px;
  }

  .ti-day-bar {
    width: 100%;
    border-radius: 3px 3px 0 0;
    background: linear-gradient(180deg, #60a5fa 0%, #2563eb 100%);
    min-height: 0;
  }

  .ti-day-label {
    font-size: 0.58rem;
    color: #64748b;
  }

  .ti-empty {
    margin: 0;
    font-size: 0.76rem;
    color: #64748b;
  }

  .ti-note {
    margin-top: 0.45rem;
    font-size: 0.68rem;
    color: #64748b;
  }

  .ti-range-toggle {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.3rem;
    margin-bottom: 0.55rem;
  }

  .ti-toggle-btn {
    appearance: none;
    border: 1px solid #dbe4ef;
    background: #f8fafc;
    color: #475569;
    border-radius: 8px;
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.3rem 0.2rem;
    line-height: 1.2;
  }

  .ti-toggle-btn.is-active {
    border-color: #93c5fd;
    color: #1d4ed8;
    background: #eff6ff;
  }

  .ti-workout-total {
    min-height: 2rem;
  }
</style>
