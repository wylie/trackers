---
import Layout from '../../components/Layout.astro';
---

<Layout seoTitle="Disclaimer" seoDescription="Important disclaimers for using SimpleTrackers.">
  <main class="max-w-3xl mx-auto w-full px-4 py-8">
    <h1 class="text-[30px] leading-[1.2] font-extrabold text-slate-900 mb-2">Disclaimer</h1>
    <p class="text-[18px] leading-[1.45] text-slate-600 mb-6">Please review these notes before relying on tracker outputs.</p>

    <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-6">
      <div>
        <h2 class="text-[18px] font-bold text-slate-900 mb-2">General Disclaimer</h2>
        <p class="text-[15px] leading-7 text-slate-600">SimpleTrackers is provided for informational purposes only. No warranty is implied. Use at your own risk.</p>
      </div>
      <div>
        <h2 class="text-[18px] font-bold text-slate-900 mb-2">Medical Disclaimer</h2>
        <p class="text-[15px] leading-7 text-slate-600">SimpleTrackers does not provide medical advice. Consult a qualified professional for health-related decisions.</p>
      </div>
    </section>
  </main>
</Layout>
