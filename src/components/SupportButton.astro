---
const {
  title = "Support The Developer",
  compact = false
} = Astro.props;
---

<div class={`support-card ${compact ? "support-card--compact" : ""}`} aria-label="Support The Developer">
  {!compact && <h3 class="support-title">{title}</h3>}
  <div class="support-button-wrap">
    <script
      type="text/javascript"
      src="https://cdnjs.buymeacoffee.com/1.0.0/button.prod.min.js"
      data-name="bmc-button"
      data-slug="Wylie"
      data-color="#ffb703"
      data-emoji="☕"
      data-font="Cookie"
      data-text="Buy me a Coffee"
      data-outline-color="#000000"
      data-font-color="#000000"
      data-coffee-color="#FFDD00"
    ></script>
  </div>
</div>

<style>
  .support-card {
    border: 1px solid #dbe4ef;
    border-radius: 12px;
    background: #fff;
    padding: 0.75rem;
    box-shadow: 0 10px 28px -24px rgba(15, 23, 42, 0.7);
  }

  .support-card--compact {
    padding: 0.55rem 0.6rem;
  }

  .support-title {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #475569;
    font-weight: 700;
    margin: 0 0 0.6rem 0;
  }

  .support-button-wrap {
    min-height: 48px;
    display: flex;
    justify-content: center;
    align-items: center;
  }
</style>
