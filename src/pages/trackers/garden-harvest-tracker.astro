---
import StandardTrackerPage from '../../components/tracker-pages/StandardTrackerPage.astro';
import { getRelatedCalculators } from '../../data/related-calculators';

const steps = [
  "Add a new harvest entry.",
  "Record the type and amount.",
  "Edit or delete entries as needed.",
  "Your data is saved locally in your browser.",
  "No account or login required."
];
const benefits = [
  "Simple, distraction-free interface",
  "Private: your data never leaves your device",
  "No registration or login required",
  "Track your garden's productivity"
];
const related = [
  { name: "Meal Tracker", url: "/meal-tracker", icon: "restaurant" },
  { name: "Health Tracker", url: "/health-tracker", icon: "favorite" },
  { name: "Habit Tracker", url: "/habit-tracker", icon: "check_circle" },
  { name: "Reading Tracker", url: "/reading-tracker", icon: "menu_book" }
];
---

<StandardTrackerPage
  seoTitle="Garden Harvest Tracker"
  seoDescription="Free, private, browser-based garden harvest tracker. No login required."
  pageTitle="Garden Harvest Tracker"
  pageDescription="Free, private, browser-based garden harvest tracker. No login required."
  storageKey="garden-harvest-tracker-entries"
  trackerCardProps={{
    title: "Garden Harvest Log",
    description: "Log your garden harvests, dates, types, and notes.",
    icon: "eco",
    itemPlaceholder: "Produce Item"
  }}
  steps={steps}
  benefits={benefits}
  related={related}
  relatedCalculators={getRelatedCalculators("garden-harvest-tracker")}
/>
