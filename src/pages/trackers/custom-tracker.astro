---
title: "Custom Tracker"
description: "Create your own tracker for any purpose. No login, no accounts, data stays in your browser."
import Layout from '../../components/Layout.astro';
import TrackerPageWrapper from '../../components/TrackerPageWrapper.astro';
import TrackerCard from '../../components/TrackerCard.astro';
import Introduction from '../../components/sections/Introduction.astro';
import HowToUse from '../../components/sections/HowToUse.astro';
import Benefits from '../../components/sections/Benefits.astro';
import FAQ from '../../components/sections/FAQ.astro';
import RelatedTrackers from '../../components/sections/RelatedTrackers.astro';

const steps = [
  "Define your custom fields.",
  "Add new entries.",
  "Edit or delete entries as needed.",
  "Your data is saved locally in your browser.",
  "No account or login required."
];
const benefits = [
  "Flexible and customizable",
  "Private: your data never leaves your device",
  "No registration or login required",
  "Track anything you want"
];
const faqs = [
  { question: "Is my data private?", answer: "Yes, all data is stored locally in your browser." },
  { question: "Do I need an account?", answer: "No, SimpleTrackers.io does not require registration or login." },
  { question: "Can I export my data?", answer: "Export functionality is coming soon!" }
];
const iconMap = {
  'Habit Tracker': 'check_circle',
  'Reading Tracker': 'menu_book',
  'Custom Tracker': 'tune',
  'Finance Tracker': 'attach_money',
  'Health Tracker': 'favorite',
  'Workout Tracker': 'fitness_center',
  'Meal Tracker': 'restaurant',
  'Sleep Tracker': 'bed',
  'Task Tracker': 'assignment',
  'Movie Watch Tracker': 'movie',
  'Garden Harvest Tracker': 'eco',
};
const related = [
  { name: "Habit Tracker", url: "/habit-tracker", icon: "check_circle" },
  { name: "Reading Tracker", url: "/reading-tracker", icon: "menu_book" },
  { name: "Movie Watch Tracker", url: "/movie-watch-tracker", icon: "movie" },
  { name: "Finance Tracker", url: "/finance-tracker", icon: "attach_money" },
  { name: "Health Tracker", url: "/health-tracker", icon: "favorite" },
  { name: "Workout Tracker", url: "/workout-tracker", icon: "fitness_center" },
  { name: "Meal Tracker", url: "/meal-tracker", icon: "restaurant" },
  { name: "Sleep Tracker", url: "/sleep-tracker", icon: "bed" },
  { name: "Task Tracker", url: "/task-tracker", icon: "assignment" }
];
---

<Layout seoTitle="Custom Tracker" seoDescription="Create your own tracker for any purpose. No login, no accounts, data stays in your browser.">
  <TrackerPageWrapper>
    <main>
      <h1 class="text-3xl font-bold text-gray-900 mb-6">Custom Tracker</h1>
      <section>
          <TrackerCard
            title="Custom Log"
            description="Log anything you want: tasks, goals, notes, and more."
            storageKey="custom-tracker-entries"
          />
        <Introduction introduction="Create your own tracker for any purpose. No login, no accounts, data stays in your browser." icon="tune" />
        <HowToUse steps={steps} />
        <Benefits benefits={benefits} />
        <FAQ faqs={faqs} />
        <RelatedTrackers related={related} />
      </section>
    </main>
  </TrackerPageWrapper>
</Layout>
