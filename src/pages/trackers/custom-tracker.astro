---
import StandardTrackerPage from '../../components/tracker-pages/StandardTrackerPage.astro';
import { getRelatedCalculators } from '../../data/related-calculators';

const steps = [
  "Define your custom fields.",
  "Add new entries.",
  "Edit or delete entries as needed.",
  "Your data is saved locally in your browser.",
  "No account or login required."
];
const benefits = [
  "Flexible and customizable",
  "Private: your data never leaves your device",
  "No registration or login required",
  "Track anything you want"
];
const related = [
  { name: "Habit Tracker", url: "/habit-tracker", icon: "check_circle" },
  { name: "Finance Tracker", url: "/finance-tracker", icon: "attach_money" },
  { name: "Health Tracker", url: "/health-tracker", icon: "favorite" },
  { name: "Meal Tracker", url: "/meal-tracker", icon: "restaurant" }
];
---

<StandardTrackerPage
  seoTitle="Custom Tracker"
  seoDescription="Create your own tracker for any purpose. No login, no accounts, data stays in your browser."
  pageTitle="Custom Tracker"
  pageDescription="Create your own tracker for any purpose. No login, no accounts, data stays in your browser."
  storageKey="custom-tracker-entries"
  trackerCardProps={{
    title: "Custom Log",
    description: "Log anything you want: tasks, goals, notes, and more."
  }}
  steps={steps}
  benefits={benefits}
  related={related}
  relatedCalculators={getRelatedCalculators("custom-tracker")}
/>
