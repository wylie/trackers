        <div class="rounded-md border border-slate-200 bg-slate-50 px-3 py-2 flex items-center justify-between gap-3">
          <div class="min-w-0">
            <p class="text-sm font-semibold text-slate-800">${row.label}</p>
            <p class="text-xs text-slate-500">${row.count} ${row.count === 1 ? "entry" : "entries"}</p>
          </div>
          <div class="flex items-center gap-2">
            <button
              type="button"
              data-download-tracker="${row.key}"
              class="px-3 py-1.5 text-xs font-semibold rounded-md border border-blue-300 text-blue-700 bg-white hover:bg-blue-50 transition"
              ${row.count <= 0 ? "disabled" : ""}
            >
              Download CSV
            </button>
            <button
              type="button"
              data-clear-tracker="${row.key}"
              class="px-3 py-1.5 text-xs font-semibold rounded-md border border-red-300 text-red-700 bg-white hover:bg-red-50 transition"
              ${row.count <= 0 ? "disabled" : ""}
            >
              Clear
            </button>
          </div>
        </div>
      `).join("");
    };

    downloadBtn.addEventListener("click", () => {
      const data = getData();
      const blob = new Blob([JSON.stringify(data, null, 2)], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      const date = new Date().toISOString().slice(0, 10);
      a.href = url;
      a.download = `simpletrackers-backup-${date}.json`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
      setMessage("Downloaded local data backup.");
    });

    uploadBtn.addEventListener("click", () => {
      uploadInput.click();
    });

    const setImportMessage = (text, isError = false) => {
      if (!importMessage) {
        setMessage(text, isError);
        return;
      }
      importMessage.textContent = text;
      importMessage.classList.remove("hidden");
      importMessage.className = `mt-3 text-sm ${isError ? "text-red-600" : "text-green-700"}`;
    };

    if (importGoodreadsBtn && importGoodreadsInput && !importGoodreadsBtn.dataset.bound) {
      importGoodreadsBtn.dataset.bound = "1";
      importGoodreadsBtn.addEventListener("click", () => {
        if (typeof importGoodreadsInput.showPicker === "function") {
          importGoodreadsInput.showPicker();
        } else {
          importGoodreadsInput.click();
        }
      });

      importGoodreadsInput.addEventListener("change", async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLInputElement)) return;
        const file = target.files?.[0];
        if (!file) return;
        try {
          const csvText = await file.text();
          const rows = parseCsv(csvText);
          if (!rows.length) {
            setImportMessage("Import failed: CSV appears empty.", true);
            return;
          }
          const importResult = extractGoodreadsRowsToReadingEntries(rows);
          const importedEntries = Array.isArray(importResult?.entries) ? importResult.entries : [];
          const skippedEntries = Math.max(0, Number(importResult?.skipped) || 0);
          if (!importedEntries.length) {
            setImportMessage("Import failed: no valid Goodreads rows with book titles were found.", true);
            return;
          }
          const ok = window.confirm(`Import ${importedEntries.length} Goodreads books into Reading Tracker?`);
          if (!ok) return;
          pushHistorySnapshot(getData(), "settings-import-goodreads");
          const next = getData();
          const existing = Array.isArray(next["reading-tracker-entries"]) ? next["reading-tracker-entries"] : [];
          const dedupKeySet = new Set();
          existing.forEach((entry) => {
            getReadingDedupKeys(entry).forEach((key) => dedupKeySet.add(key));
          });
          const uniqueImported = [];
          let skippedDuplicates = 0;
          importedEntries.forEach((entry) => {
            const keys = getReadingDedupKeys(entry);
            const isDuplicate = keys.length > 0 && keys.some((key) => dedupKeySet.has(key));
            if (isDuplicate) {
              skippedDuplicates += 1;
              return;
            }
            uniqueImported.push(entry);
            keys.forEach((key) => dedupKeySet.add(key));
          });
          next["reading-tracker-entries"] = [...uniqueImported, ...existing];
          localStorage.setItem(STORAGE_KEY, JSON.stringify(next));
          document.dispatchEvent(new CustomEvent("simpletrackers:entries-updated", { detail: { storageKey: "reading-tracker-entries" } }));
          document.dispatchEvent(new CustomEvent("simpletrackers:sync-data-updated"));
          document.dispatchEvent(new CustomEvent("simpletrackers:history-updated"));
          refreshSummary(summary);
          renderHistory();
          const skippedParts = [];
          if (skippedEntries > 0) skippedParts.push(`${skippedEntries} skipped: want-to-read/unshelved`);
          if (skippedDuplicates > 0) skippedParts.push(`${skippedDuplicates} skipped: duplicates`);
          const skippedSuffix = skippedParts.length ? ` (${skippedParts.join("; ")})` : "";
          setImportMessage(`Imported ${uniqueImported.length} Goodreads books into Reading Tracker.${skippedSuffix}`);
        } catch {
          setImportMessage("Import failed: invalid CSV file.", true);
        } finally {
          importGoodreadsInput.value = "";
        }
      });
    }

    if (importWaterminderBtn && importWaterminderInput && !importWaterminderBtn.dataset.bound) {
      importWaterminderBtn.dataset.bound = "1";
      importWaterminderBtn.addEventListener("click", () => {
        if (typeof importWaterminderInput.showPicker === "function") {
          importWaterminderInput.showPicker();
        } else {
          importWaterminderInput.click();
        }
      });

      importWaterminderInput.addEventListener("change", async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLInputElement)) return;
        const file = target.files?.[0];
        if (!file) return;
        try {
          const csvText = await file.text();
          const rows = parseCsv(csvText);
          if (!rows.length) {
            setImportMessage("Import failed: CSV appears empty.", true);
            return;
          }
          const importResult = extractWaterMinderRowsToEntries(rows);
          const importedEntries = Array.isArray(importResult?.entries) ? importResult.entries : [];
          const skippedRows = Math.max(0, Number(importResult?.skipped) || 0);
          if (!importedEntries.length) {
            const sampleHeaders = rows[0] ? Object.keys(rows[0]).slice(0, 8).join(", ") : "none detected";
            setImportMessage(`Import failed: no valid WaterMinder drink rows were found. Headers seen: ${sampleHeaders}`, true);
            return;
          }
          const ok = window.confirm(`Import ${importedEntries.length} WaterMinder day entries into Water Intake Tracker?`);
          if (!ok) return;

          pushHistorySnapshot(getData(), "settings-import-waterminder");
          const next = getData();
          const existing = Array.isArray(next["water-tracker-entries"]) ? next["water-tracker-entries"] : [];
          const merged = mergeWaterEntriesByDay(existing, importedEntries);
          next["water-tracker-entries"] = merged.entries;
          localStorage.setItem(STORAGE_KEY, JSON.stringify(next));
          document.dispatchEvent(new CustomEvent("simpletrackers:entries-updated", { detail: { storageKey: "water-tracker-entries" } }));
          document.dispatchEvent(new CustomEvent("simpletrackers:sync-data-updated"));
          document.dispatchEvent(new CustomEvent("simpletrackers:history-updated"));
          refreshSummary(summary);
          renderHistory();

          const suffixParts = [];
          if (merged.mergedDays > 0) suffixParts.push(`${merged.mergedDays} merged into existing days`);
          if (skippedRows > 0) suffixParts.push(`${skippedRows} skipped rows`);
          const suffix = suffixParts.length ? ` (${suffixParts.join("; ")})` : "";
          setImportMessage(`Imported ${importedEntries.length} WaterMinder day entries into Water Intake Tracker.${suffix}`);
        } catch {
          setImportMessage("Import failed: invalid CSV file.", true);
        } finally {
          importWaterminderInput.value = "";
        }
      });
    }

    uploadInput.addEventListener("change", async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;
      const file = target.files?.[0];
      if (!file) return;

      try {
        const text = await file.text();
        const parsed = JSON.parse(text);
        if (!parsed || typeof parsed !== "object" || Array.isArray(parsed)) {
          setMessage("Upload failed: JSON root must be an object.", true);
          return;
        }

        const uploadModeInput = root.querySelector('input[name="upload-mode"]:checked');
        const uploadMode = uploadModeInput instanceof HTMLInputElement ? uploadModeInput.value : "merge";

        if (uploadMode === "overwrite") {
          const ok = window.confirm("Overwrite all current local tracker data with uploaded data?");
          if (!ok) return;
          pushHistorySnapshot(getData(), "settings-upload-overwrite");
          localStorage.setItem(STORAGE_KEY, JSON.stringify(parsed));
          setMessage("Upload complete: existing data was overwritten.");
        } else {
          const ok = window.confirm("Merge uploaded data with your current local data?");
          if (!ok) return;
          pushHistorySnapshot(getData(), "settings-upload-merge");
          const merged = mergeData(getData(), parsed);
          localStorage.setItem(STORAGE_KEY, JSON.stringify(merged));
          setMessage("Upload complete: data was merged.");
        }

        refreshSummary(summary);
        renderHistory();
      } catch {
        setMessage("Upload failed: invalid JSON file.", true);
      } finally {
        uploadInput.value = "";
      }
    });

    clearBtn.addEventListener("click", () => {
      const ok = window.confirm("Delete all locally saved tracker data from this browser?");
      if (!ok) return;
      pushHistorySnapshot(getData(), "settings-clear-all");
      localStorage.removeItem(STORAGE_KEY);
      refreshSummary(summary);
      renderHistory();
      setMessage("All local tracker data has been cleared.");
    });

    historyList.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const id = target.getAttribute("data-history-restore");
      if (!id) return;
      const history = getHistory();
      const record = history.find((item) => String(item?.id || "") === id);
      if (!record) return;
      const ok = window.confirm(`Restore local data from ${formatHistoryTime(record.at)}?`);
      if (!ok) return;
      try {
        pushHistorySnapshot(getData(), "settings-before-restore");
        const restorePayload = (record.payload && typeof record.payload === "object" && !Array.isArray(record.payload))
          ? record.payload
          : {};
        try {
          localStorage.setItem(STORAGE_KEY, JSON.stringify(restorePayload));
        } catch (error) {
          if (!isQuotaExceededError(error)) throw error;
          // Free restore history space and retry restore once.
          localStorage.removeItem(HISTORY_KEY);
          localStorage.setItem(STORAGE_KEY, JSON.stringify(restorePayload));
        }
        const changedKeys = Object.keys(restorePayload).filter((key) => Array.isArray(restorePayload[key]));
        changedKeys.forEach((key) => {
          document.dispatchEvent(new CustomEvent("simpletrackers:entries-updated", { detail: { storageKey: key } }));
        });
        document.dispatchEvent(new CustomEvent("simpletrackers:sync-data-updated"));
        document.dispatchEvent(new CustomEvent("simpletrackers:history-updated"));
        refreshSummary(summary);
        renderHistory();
        setMessage("Restore complete.");
      } catch (error) {
        setMessage(error instanceof Error ? `Restore failed: ${error.message}` : "Restore failed.", true);
      }
    });

    clearHistoryBtn.addEventListener("click", () => {
      const ok = window.confirm("Clear all restore point history?");
      if (!ok) return;
      setHistory([]);
      renderHistory();
      setMessage("Restore history cleared.");
    });

    clearTrackerList.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const downloadTrackerKey = String(target.getAttribute("data-download-tracker") || "").trim();
      if (downloadTrackerKey) {
        const data = getData();
        const entries = Array.isArray(data[downloadTrackerKey]) ? data[downloadTrackerKey] : [];
        if (!entries.length) return;
        const trackerLabel = humanizeTrackerKey(downloadTrackerKey);
        const csv = entriesToCsv(entries);
        if (!csv) return;
        const blob = new Blob([csv], { type: "text/csv;charset=utf-8" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        const date = new Date().toISOString().slice(0, 10);
        const fileKey = downloadTrackerKey.replace(/[^a-z0-9\-]+/gi, "-").toLowerCase();
        a.href = url;
        a.download = `simpletrackers-${fileKey}-${date}.csv`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
        setMessage(`Downloaded ${trackerLabel} data as CSV.`);
        return;
      }
      const trackerKey = String(target.getAttribute("data-clear-tracker") || "").trim();
      if (!trackerKey) return;
      const data = getData();
      const entries = Array.isArray(data[trackerKey]) ? data[trackerKey] : [];
      if (!entries.length) return;
      const trackerLabel = humanizeTrackerKey(trackerKey);
      const ok = window.confirm(`Clear all ${entries.length} entries from ${trackerLabel}?`);
      if (!ok) return;
      pushHistorySnapshot(data, `settings-clear-${trackerKey}`);
      const next = { ...data };
      delete next[trackerKey];
      localStorage.setItem(STORAGE_KEY, JSON.stringify(next));
      document.dispatchEvent(new CustomEvent("simpletrackers:entries-updated", { detail: { storageKey: trackerKey } }));
      document.dispatchEvent(new CustomEvent("simpletrackers:sync-data-updated"));
      document.dispatchEvent(new CustomEvent("simpletrackers:history-updated"));
      refreshSummary(summary);
      renderHistory();
      renderClearTrackerList();
      setMessage(`Cleared all entries from ${trackerLabel}.`);
    });

    document.addEventListener("simpletrackers:history-updated", renderHistory);

    refreshSummary(summary);
    renderHistory();
    renderClearTrackerList();
  }

  initSettingsPage();
  initCloudSyncSection();
  document.addEventListener("astro:page-load", initSettingsPage);
  document.addEventListener("astro:page-load", initCloudSyncSection);
</script>
