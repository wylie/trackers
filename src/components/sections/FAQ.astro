---
const { faqs = [] } = Astro.props;
---

<section class="mb-8 bg-white rounded-lg shadow border border-gray-200 p-6">
  <h2 class="text-xl font-bold mb-2 text-gray-900">FAQ</h2>
  <dl>
    {faqs && faqs.map(faq => (
      <div class="mb-4">
        <dt class="font-semibold text-gray-900">{faq.question}</dt>
        <dd class="text-gray-700 text-base leading-relaxed">{faq.answer}</dd>
      </div>
    ))}
  </dl>
</section>

<style>
  section {
    margin-bottom: 2rem;
  }
  h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }
  dt {
    font-weight: bold;
    margin-top: 1rem;
  }
  dd {
    margin-left: 1rem;
    margin-bottom: 0.5rem;
  }
</style>
