---
const { related = [] } = Astro.props;
---
<section class="mb-8 bg-white rounded-lg shadow border border-gray-200 p-6">
  <h2 class="text-xl font-bold mb-4 text-gray-900">Related Trackers</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
    {related && Array.isArray(related) && related.length > 0 && (
      related.map(tracker => {
        const icon = tracker && tracker.icon ? tracker.icon : 'track_changes';
        return (
          <a href={tracker.url || '#'} class="flex items-center gap-2 bg-white rounded-lg border border-gray-200 p-4 text-gray-900 font-medium shadow-sm hover:border-blue-600 hover:bg-blue-50 transition">
            <span class="material-icons icon-blue">{icon}</span>
            {tracker && tracker.name ? tracker.name : 'Unknown Tracker'}
          </a>
        );
      })
    )}
  </div>
</section>

<style>
  section {
    margin-bottom: 2rem;
  }
  h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }
  ul {
    padding-left: 1.5rem;
  }
  li {
    margin-bottom: 0.5rem;
  }
  a {
    color: #222;
    text-decoration: none;
    font-weight: 500;
    box-shadow: 0 1px 2px rgba(0,0,0,0.03);
    transition: border-color 0.2s, background 0.2s;
  }
  a:hover {
    border-color: #2563eb;
    background: #eff6ff;
    color: #2563eb;
  }
  .icon-blue {
    color: #2563eb !important;
    font-size: 1.5rem;
    margin-right: 0.5rem;
  }
</style>
