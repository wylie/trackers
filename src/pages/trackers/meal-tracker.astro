---
import StandardTrackerPage from '../../components/tracker-pages/StandardTrackerPage.astro';
import { getRelatedCalculators } from '../../data/related-calculators';

const steps = [
  "Track your nutrition.",
  "Edit or delete meals as needed.",
  "Your data is saved locally in your browser.",
  "No account or login required."
];
const benefits = [
  "Simple, distraction-free interface",
  "Private: your data never leaves your device",
  "No registration or login required",
  "Monitor your eating habits"
];
const related = [
  { name: "Health Tracker", url: "/health-tracker", icon: "favorite" },
  { name: "Workout Tracker", url: "/workout-tracker", icon: "fitness_center" },
  { name: "Finance Tracker", url: "/finance-tracker", icon: "attach_money" },
  { name: "Habit Tracker", url: "/habit-tracker", icon: "check_circle" }
];
---

<StandardTrackerPage
  seoTitle="Meal Tracker"
  seoDescription="Track your meals privately and easily. No login, no accounts, data stays in your browser."
  pageTitle="Meal Tracker"
  pageDescription="Track your meals privately and easily. No login, no accounts, data stays in your browser."
  storageKey="meal-tracker-entries"
  trackerCardProps={{
    title: "Meal Log",
    description: "Log your meals, nutrition, and notes.",
    icon: "restaurant",
    itemPlaceholder: "Meal"
  }}
  steps={steps}
  benefits={benefits}
  related={related}
  relatedCalculators={getRelatedCalculators("meal-tracker")}
/>
