---
import Header from './Header.astro';
import Footer from './Footer.astro';
import SEO from './SEO.astro';
import AdSlot from './AdSlot.astro';
const { seoTitle, seoDescription, noindex = false } = Astro.props;

const SITE_NAME = "SimpleTrackers.io";
const GA_MEASUREMENT_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || "G-6E8NZ6TNCV";
const analyticsEnabled = !import.meta.env.DEV && Boolean(GA_MEASUREMENT_ID);
const site = (Astro.site?.toString() || "https://www.simpletrackers.io").replace(/\/$/, "");
const pathname = Astro.url.pathname;
const canonical = new URL(pathname, `${site}/`).toString();

function formatPathTitle(path: string) {
  if (path === "/") return SITE_NAME;
  const clean = path.replace(/^\/+|\/+$/g, "");
  const segments = clean.split("/");
  const last = segments[segments.length - 1] || "";
  return last
    .split("-")
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
}

const rawTitle = (typeof seoTitle === "string" && seoTitle.trim().length > 0) ? seoTitle.trim() : formatPathTitle(pathname);
const pageTitle = rawTitle === SITE_NAME ? SITE_NAME : `${rawTitle} | ${SITE_NAME}`;
const pageDescription = (typeof seoDescription === "string" && seoDescription.trim().length > 0)
  ? seoDescription.trim()
  : "Simple, private browser-based trackers for everyday life. No login, no accounts, data stays in your browser.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE_NAME,
    url: `${site}/`
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: pageTitle,
    url: canonical,
    description: pageDescription
  }
];

---
<html lang="en">
  <head>
    <SEO
      title={pageTitle}
      description={pageDescription}
      canonical={canonical}
      noindex={noindex}
      siteName={SITE_NAME}
      jsonLd={jsonLd}
    />
    <!-- Astro injects CSS automatically -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    {analyticsEnabled && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>
        <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() {dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_MEASUREMENT_ID, { anonymize_ip: true });
        </script>
      </>
    )}
  </head>
  <body class="flex flex-col min-h-screen bg-gray-50 text-gray-900 font-sans">
    <Header />
    <main id="main-content" class="flex-1 max-w-4xl mx-auto w-full px-4 py-8">
      <div class="mb-2">
        <AdSlot location="Top Banner" />
      </div>
      <slot />
      <div class="mt-2">
        <AdSlot location="Bottom Banner" />
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  body {
    display: grid;
    grid-template-rows: auto 1fr auto;
    min-height: 100vh;
  }
</style>
