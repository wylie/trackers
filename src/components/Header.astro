---
const path = Astro.url.pathname;
const syncApiBase = (import.meta.env.PUBLIC_SYNC_API_BASE || "").replace(/\/$/, "");
const trackerLinks = [
  { label: "Habit Tracker", href: "/trackers/habit-tracker", icon: "check_circle" },
  { label: "Reading Tracker", href: "/trackers/reading-tracker", icon: "menu_book" },
  { label: "Movie Watch Tracker", href: "/trackers/movie-watch-tracker", icon: "movie" },
  { label: "Finance Tracker", href: "/trackers/finance-tracker", icon: "attach_money" },
  { label: "Health Tracker", href: "/trackers/health-tracker", icon: "favorite" },
  { label: "Video Game Tracker", href: "/trackers/video-game-tracker", icon: "sports_esports" },
  { label: "Workout Tracker", href: "/trackers/workout-tracker", icon: "fitness_center" },
  { label: "Meal Tracker", href: "/trackers/meal-tracker", icon: "restaurant" },
  { label: "Water Intake Tracker", href: "/trackers/water-tracker", icon: "water_drop" },
  { label: "Sleep Tracker", href: "/trackers/sleep-tracker", icon: "bed" },
  { label: "Task Tracker", href: "/trackers/task-tracker", icon: "assignment" },
  { label: "Custom Tracker", href: "/trackers/custom-tracker", icon: "tune" }
];

const navClass = (href) => `block px-2 py-2 text-[14px] font-semibold transition md:px-4 md:rounded-md ${
  path === href
    ? "text-blue-700 border-b-2 border-blue-600 md:border-b-0 md:bg-blue-100"
    : "text-slate-600 hover:text-slate-700 md:bg-white md:hover:bg-slate-100"
}`;
---

<header class="sticky top-0 z-40 w-full bg-white border-b border-gray-200 shadow-sm">
  <div class="max-w-5xl mx-auto px-4 py-3 border-b" style="border-color: rgb(241, 245, 249);">
    <div class="flex items-center justify-between md:block">
      <a href="/" data-home-link="true" class="block text-left md:text-center text-[24px] leading-none font-bold text-slate-900 tracking-tight">SimpleTrackers</a>
      <button
        id="mobile-nav-toggle"
        type="button"
        class="md:hidden inline-flex items-center justify-center rounded-md border border-slate-200 px-2.5 py-1.5 text-slate-700"
        aria-expanded="false"
        aria-controls="mobile-nav-panel"
        aria-label="Open navigation menu"
      >
        <span class="material-symbols-outlined text-[22px]" aria-hidden="true">menu</span>
      </button>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 py-2.5 hidden md:block">
    <nav aria-label="Main navigation">
      <ul class="flex flex-wrap justify-center gap-3 sm:gap-4">
        <li><a href="/" data-home-link="true" class={navClass("/")}>Home</a></li>
        <li><a href="/dashboard" class={navClass("/dashboard")}>Dashboard</a></li>
        <li class="relative group desktop-trackers">
          <button class={navClass("/trackers")} type="button">
            Trackers
            <span class="material-icons align-middle text-[18px] ml-0.5">expand_more</span>
          </button>
          <div class="absolute left-1/2 -translate-x-1/2 mt-1 w-72 bg-white border border-gray-200 rounded-lg shadow-lg opacity-0 group-hover:opacity-100 group-hover:pointer-events-auto pointer-events-none transition-opacity z-50">
            <div class="flex flex-col p-2">
              {trackerLinks.map((tracker) => (
                <a href={tracker.href} class="flex items-center gap-2 py-1.5 px-2 text-slate-600 hover:bg-blue-50 rounded">
                  <span class="material-symbols-outlined text-[17px] text-slate-500" aria-hidden="true">{tracker.icon}</span>
                  <span>{tracker.label}</span>
                </a>
              ))}
            </div>
          </div>
        </li>
        <li><a href="/faq" class={navClass("/faq")}>FAQ</a></li>
        <li><a href="/settings" class={navClass("/settings")}>Settings</a></li>
      </ul>
    </nav>
  </div>

  <div id="auth-status-bar" class="hidden border-t border-slate-100 bg-gradient-to-r from-blue-50 to-slate-50">
    <div class="max-w-5xl mx-auto px-4 py-2.5">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between sm:gap-3">
        <div class="min-w-0 inline-flex items-center gap-2 text-[12px] sm:text-sm text-slate-700">
            <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
              <span class="material-symbols-outlined text-[16px]" aria-hidden="true">verified_user</span>
            </span>
            <span class="font-medium whitespace-nowrap">Signed in as</span>
            <span id="auth-status-email" class="font-semibold text-slate-900 truncate max-w-[58vw] sm:max-w-none"></span>
        </div>
        <div class="w-full flex items-center justify-end gap-2 sm:w-auto sm:gap-3">
          <div id="auth-sync-status" class="inline-flex items-center gap-1 rounded-full border border-slate-200 bg-white px-2 py-1 text-[10px] sm:text-[11px] font-medium text-slate-600">
            <span class="material-symbols-outlined text-[13px]" aria-hidden="true">cloud_done</span>
            <span>Sync status unknown</span>
          </div>
          <button
            id="auth-logout-btn"
            type="button"
            class="inline-flex items-center justify-center gap-1.5 rounded-md border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100"
            aria-label="Log out"
            title="Log out"
          >
            <span class="material-symbols-outlined text-[16px]" aria-hidden="true">logout</span>
            <span>Log out</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div id="mobile-nav-panel" class="hidden md:hidden border-t border-slate-100">
    <nav aria-label="Mobile navigation" class="px-4 py-3">
      <ul class="flex flex-col gap-1.5">
        <li><a href="/" data-home-link="true" class="block rounded-md px-3 py-2 text-[15px] font-semibold text-slate-700 hover:bg-slate-100">Home</a></li>
        <li><a href="/dashboard" class="block rounded-md px-3 py-2 text-[15px] font-semibold text-slate-700 hover:bg-slate-100">Dashboard</a></li>
        <li>
          <button
            id="mobile-trackers-toggle"
            type="button"
            class="w-full flex items-center justify-between rounded-md px-3 py-2 text-[15px] font-semibold text-slate-700 hover:bg-slate-100"
            aria-expanded="false"
            aria-controls="mobile-trackers-list"
          >
            <span>Trackers</span>
            <span class="material-icons text-[18px]" aria-hidden="true">expand_more</span>
          </button>
          <div id="mobile-trackers-list" class="hidden pl-2 pt-1">
            <div class="grid grid-cols-1 gap-1">
              {trackerLinks.map((tracker) => (
                <a href={tracker.href} class="flex items-center gap-2 rounded-md px-3 py-1.5 text-[14px] text-slate-600 hover:bg-blue-50">
                  <span class="material-symbols-outlined text-[17px] text-slate-500" aria-hidden="true">{tracker.icon}</span>
                  <span>{tracker.label}</span>
                </a>
              ))}
            </div>
          </div>
        </li>
        <li><a href="/faq" class="block rounded-md px-3 py-2 text-[15px] font-semibold text-slate-700 hover:bg-slate-100">FAQ</a></li>
        <li>
          <a href="/settings" class="flex items-center gap-2 rounded-md px-3 py-2 text-[15px] font-semibold text-slate-700 hover:bg-slate-100">
            <span class="material-symbols-outlined text-[18px]" aria-hidden="true">settings</span>
            <span>Settings</span>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script define:vars={{ syncApiBase }}>
  document.addEventListener("DOMContentLoaded", () => {
    const mobileToggle = document.getElementById("mobile-nav-toggle");
    const mobilePanel = document.getElementById("mobile-nav-panel");
    const mobileTrackersToggle = document.getElementById("mobile-trackers-toggle");
    const mobileTrackersList = document.getElementById("mobile-trackers-list");
    const authStatusBar = document.getElementById("auth-status-bar");
    const authStatusEmail = document.getElementById("auth-status-email");
    const authSyncStatus = document.getElementById("auth-sync-status");
    const logoutButton = document.getElementById("auth-logout-btn");
    const LAST_SYNC_AT_KEY = "simpletrackers:last-sync-at";
    const HOME_NAV_PREF_KEY = "simpletrackers:nav-home-preference";
    const SYNC_AUTH_CACHE_KEY = "simpletrackers:sync-authenticated";
    let isSyncAuthenticated = String(localStorage.getItem(SYNC_AUTH_CACHE_KEY) || "") === "1";

    if (!mobileToggle || !mobilePanel) return;

    function getHomeNavPreference() {
      try {
        const raw = localStorage.getItem(HOME_NAV_PREF_KEY);
        if (!raw) return true;
        const parsed = JSON.parse(raw);
        if (typeof parsed === "boolean") return parsed;
        if (parsed && typeof parsed === "object" && typeof parsed.homeToDashboardWhenSignedIn === "boolean") {
          return parsed.homeToDashboardWhenSignedIn;
        }
      } catch {
        // Fall back to default.
      }
      return true;
    }

    function applyHomeLinkRouting() {
      const prefersDashboardHome = getHomeNavPreference();
      const nextHref = (isSyncAuthenticated && prefersDashboardHome) ? "/dashboard" : "/";
      document.querySelectorAll("a[data-home-link=\"true\"]").forEach((link) => {
        link.setAttribute("href", nextHref);
      });
    }

    function shouldRouteHomeToDashboard() {
      return isSyncAuthenticated && getHomeNavPreference();
    }

    function persistAuthCache(authenticated) {
      try {
        localStorage.setItem(SYNC_AUTH_CACHE_KEY, authenticated ? "1" : "0");
      } catch {
        // Ignore localStorage write failures.
      }
    }

    function setMobileMenu(open) {
      mobilePanel.classList.toggle("hidden", !open);
      mobileToggle.setAttribute("aria-expanded", open ? "true" : "false");
      const icon = mobileToggle.querySelector(".material-symbols-outlined");
      if (icon) icon.textContent = open ? "close" : "menu";
    }

    function setMobileTrackers(open) {
      if (!mobileTrackersToggle || !mobileTrackersList) return;
      mobileTrackersList.classList.toggle("hidden", !open);
      mobileTrackersToggle.setAttribute("aria-expanded", open ? "true" : "false");
      const icon = mobileTrackersToggle.querySelector(".material-icons");
      if (icon) icon.textContent = open ? "expand_less" : "expand_more";
    }

    mobileToggle.addEventListener("click", () => {
      const isOpen = mobileToggle.getAttribute("aria-expanded") === "true";
      setMobileMenu(!isOpen);
    });

    mobileTrackersToggle?.addEventListener("click", () => {
      const isOpen = mobileTrackersToggle.getAttribute("aria-expanded") === "true";
      setMobileTrackers(!isOpen);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        setMobileTrackers(false);
        setMobileMenu(false);
      }
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Node)) return;
      if (!mobilePanel.contains(target) && !mobileToggle.contains(target)) {
        setMobileTrackers(false);
        setMobileMenu(false);
      }
    });

    mobilePanel.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        setMobileTrackers(false);
        setMobileMenu(false);
      });
    });

    async function syncApi(path, options = {}) {
      const method = String(options.method || "GET").toUpperCase();
      const hasBody = Object.prototype.hasOwnProperty.call(options, "body");
      const headers = { ...(options.headers || {}) };
      if (hasBody && !headers["content-type"]) {
        headers["content-type"] = "application/json";
      }
      const response = await fetch(`${syncApiBase}${path}`, {
        credentials: "include",
        ...options,
        method,
        headers
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || data?.ok === false) {
        throw new Error(String(data?.error || `Request failed (${response.status})`));
      }
      return data;
    }

    function hideAuthStatus() {
      isSyncAuthenticated = false;
      persistAuthCache(false);
      authStatusBar?.classList.add("hidden");
      if (authStatusEmail) authStatusEmail.textContent = "";
      applyHomeLinkRouting();
    }

    function getPreviewAuthFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const enabledRaw = String(params.get("previewAuth") || params.get("previewauth") || "").toLowerCase();
      const enabled = enabledRaw === "1" || enabledRaw === "true" || enabledRaw === "yes";
      if (!enabled) return null;
      const email = String(params.get("previewEmail") || params.get("previewemail") || "preview@simpletrackers.io").trim();
      const syncMinutesRaw = String(params.get("previewSyncMinutes") || params.get("previewsyncminutes") || params.get("previewSync") || "").trim();
      const syncAtRaw = String(params.get("previewSyncAt") || params.get("previewsyncat") || "").trim();
      let previewSyncAt = 0;
      if (syncAtRaw) {
        const parsedTs = Number(syncAtRaw);
        if (Number.isFinite(parsedTs) && parsedTs > 0) {
          previewSyncAt = parsedTs;
        } else {
          const parsedDate = new Date(syncAtRaw).getTime();
          if (Number.isFinite(parsedDate) && parsedDate > 0) previewSyncAt = parsedDate;
        }
      } else if (syncMinutesRaw) {
        if (syncMinutesRaw.toLowerCase() === "now") {
          previewSyncAt = Date.now();
        } else {
          const minutes = Number(syncMinutesRaw.replace(/m$/i, ""));
          if (Number.isFinite(minutes) && minutes >= 0) {
            previewSyncAt = Date.now() - (minutes * 60000);
          }
        }
      }
      return {
        authenticated: true,
        user: { email: email || "preview@simpletrackers.io" },
        preview: true,
        previewSyncAt
      };
    }

    function showAuthStatus(email) {
      if (!authStatusBar || !authStatusEmail) return;
      isSyncAuthenticated = true;
      persistAuthCache(true);
      authStatusEmail.textContent = String(email || "");
      authStatusBar.classList.remove("hidden");
      refreshSyncStatusFromStorage();
      applyHomeLinkRouting();
    }

    function formatRelativeTime(timestamp) {
      const ts = Number(timestamp);
      if (!Number.isFinite(ts) || ts <= 0) return "";
      const diffMs = Date.now() - ts;
      const diffMins = Math.max(0, Math.round(diffMs / 60000));
      if (diffMins < 1) return "just now";
      if (diffMins < 60) return `${diffMins}m ago`;
      const diffHours = Math.round(diffMins / 60);
      if (diffHours < 24) return `${diffHours}h ago`;
      const diffDays = Math.round(diffHours / 24);
      return `${diffDays}d ago`;
    }

    function setSyncStatus(text, icon = "cloud_done", tone = "text-slate-600") {
      if (!authSyncStatus) return;
      const iconEl = authSyncStatus.querySelector(".material-symbols-outlined");
      const textEl = authSyncStatus.querySelector("span:last-child");
      if (iconEl) iconEl.textContent = icon;
      if (textEl) textEl.textContent = text;
      authSyncStatus.className = `inline-flex items-center gap-1 rounded-full border border-slate-200 bg-white px-2 py-1 text-[11px] font-medium ${tone}`;
    }

    function refreshSyncStatusFromStorage() {
      const lastSyncAt = Number(localStorage.getItem(LAST_SYNC_AT_KEY) || 0);
      if (!lastSyncAt) {
        setSyncStatus("Sync not run yet", "cloud_off", "text-slate-500");
        return;
      }
      setSyncStatus(`Synced ${formatRelativeTime(lastSyncAt)}`, "cloud_done", "text-emerald-700");
    }

    async function refreshAuthStatus() {
      const preview = getPreviewAuthFromUrl();
      if (preview?.authenticated && preview?.user?.email) {
        showAuthStatus(String(preview.user.email));
        if (preview.previewSyncAt > 0) {
          setSyncStatus(`Synced ${formatRelativeTime(preview.previewSyncAt)}`, "cloud_done", "text-emerald-700");
        } else {
          setSyncStatus("Preview mode", "preview", "text-indigo-700");
        }
        return;
      }
      if (!syncApiBase) {
        hideAuthStatus();
        return;
      }
      try {
        const result = await syncApi("/auth/session", { method: "GET" });
        if (result?.authenticated && result?.user?.email) {
          showAuthStatus(String(result.user.email));
          return;
        }
      } catch {
        // Keep status hidden on network or auth errors.
      }
      hideAuthStatus();
    }

    logoutButton?.addEventListener("click", async () => {
      if (getPreviewAuthFromUrl()) {
        const url = new URL(window.location.href);
        url.searchParams.delete("previewAuth");
        url.searchParams.delete("previewauth");
        url.searchParams.delete("previewEmail");
        url.searchParams.delete("previewemail");
        url.searchParams.delete("previewSyncMinutes");
        url.searchParams.delete("previewsyncminutes");
        url.searchParams.delete("previewSync");
        url.searchParams.delete("previewSyncAt");
        url.searchParams.delete("previewsyncat");
        window.location.href = `${url.pathname}${url.search}${url.hash}`;
        return;
      }
      if (!syncApiBase) return;
      logoutButton.setAttribute("disabled", "true");
      try {
        await syncApi("/auth/logout", { method: "POST", body: JSON.stringify({}) });
      } catch {
        // Ignore and still refresh to reflect current auth state.
      } finally {
        window.location.reload();
      }
    });

    document.addEventListener("simpletrackers:sync-status", (event) => {
      const detail = event?.detail || {};
      if (detail.state === "syncing") {
        setSyncStatus("Syncing…", "sync", "text-blue-700");
        return;
      }
      if (detail.state === "queued") {
        setSyncStatus("Sync queued…", "schedule", "text-amber-700");
        return;
      }
      if (detail.state === "error") {
        setSyncStatus("Sync issue", "cloud_off", "text-red-700");
        return;
      }
      if (detail.state === "ok") {
        refreshSyncStatusFromStorage();
      }
    });

    window.setInterval(() => {
      if (!authStatusBar || authStatusBar.classList.contains("hidden")) return;
      refreshSyncStatusFromStorage();
    }, 60000);

    window.addEventListener("storage", (event) => {
      if (event.key === HOME_NAV_PREF_KEY) {
        applyHomeLinkRouting();
      }
    });

    document.addEventListener("simpletrackers:nav-home-preference-updated", applyHomeLinkRouting);

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const link = target.closest("a[data-home-link=\"true\"]");
      if (!(link instanceof HTMLAnchorElement)) return;
      if (!shouldRouteHomeToDashboard()) return;
      if (event.defaultPrevented || event.button !== 0) return;
      if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
      const href = String(link.getAttribute("href") || "");
      const isHomeHref = href === "/" || href === "";
      if (!isHomeHref) return;
      event.preventDefault();
      if (window.location.pathname === "/dashboard") return;
      window.location.assign("/dashboard");
    });

    applyHomeLinkRouting();
    void refreshAuthStatus();
  });
</script>
