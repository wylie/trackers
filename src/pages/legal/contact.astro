---
import Layout from '../../components/Layout.astro';
---

<Layout seoTitle="Contact" seoDescription="Get in touch with SimpleTrackers for support or feedback.">
  <main class="max-w-3xl mx-auto w-full px-4 py-8">
    <h1 class="text-[30px] leading-[1.2] font-extrabold text-slate-900 mb-2">Contact</h1>
    <p class="text-[18px] leading-[1.45] text-slate-600 mb-6">Questions, feedback, or support requests are welcome.</p>

    <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4">
      <p class="text-[15px] leading-7 text-slate-600">Email us at <a href="mailto:support@simpletrackers.io" class="text-blue-700 underline hover:text-blue-800">support@simpletrackers.io</a>.</p>
      <p class="text-[15px] leading-7 text-slate-600">We value your privacy and do not sell personal information.</p>
    </section>
  </main>
</Layout>
