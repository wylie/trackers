---
const { title, items = [] } = Astro.props;
const iconMap = {
  'Reading Tracker': 'menu_book',
  'Habit Tracker': 'check_circle',
  'Movie Watch Tracker': 'movie',
  'Custom Tracker': 'tune',
  'Finance Tracker': 'attach_money',
  'Health Tracker': 'favorite',
  'Video Game Tracker': 'sports_esports',
  'Workout Tracker': 'fitness_center',
  'Meal Tracker': 'restaurant',
  'Water Intake Tracker': 'water_drop',
  'Sleep Tracker': 'bed',
  'Task Tracker': 'assignment',
};
---
<section class="mb-10">
  <h2 class="text-[30px] leading-[1.2] font-extrabold mb-3 text-slate-900">{title}</h2>
  <div class="text-[18px] leading-[1.45] font-normal text-slate-600 mb-8">
    A collection of fast, lightweight trackers to help you stay organized.
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 w-full">
    {items.map((item) => {
      const icon = item.icon || iconMap[item.label] || "track_changes";
      const wrapperClass = "lg:col-span-1";
      const commonClasses = "rounded-xl border border-gray-200 bg-white shadow-sm hover:border-gray-200 hover:shadow-md transition";
      const cardClass = "p-5 text-center";
      const contentClass = "flex flex-col items-center gap-3";

      return item.url ? (
        <a href={item.url} class={`${wrapperClass} ${commonClasses} ${cardClass}`}>
          <div class={contentClass}>
            <span class="material-symbols-outlined text-blue-600" style="font-size:28px;font-variation-settings:'opsz' 24;">{icon}</span>
            <div>
              <div class="text-[16px] font-bold text-slate-900 leading-[1.25]">{item.label}</div>
              {item.description && <p class="mt-2 text-slate-600 leading-[1.35] text-[14px]">{item.description}</p>}
            </div>
          </div>
        </a>
      ) : (
        <div class={`${wrapperClass} ${commonClasses} p-5`}>
          <div class="text-[16px] text-slate-600">{item.label}</div>
        </div>
      );
    })}
  </div>
</section>
