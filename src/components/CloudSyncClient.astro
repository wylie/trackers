---
const syncApiBase = (import.meta.env.PUBLIC_SYNC_API_BASE || "").replace(/\/$/, "");
---

{syncApiBase && (
  <script define:vars={{ syncApiBase }} is:inline>
    const STORAGE_KEY = "simpletrackers.io";
    const SYNC_API_BASE = syncApiBase;
    const SYNC_EVENT = "simpletrackers:sync-data-updated";
    const AUTO_PUSH_DEBOUNCE_MS = 2500;
    let isApplyingRemote = false;
    let pushTimer = null;
    let sessionPromise = null;

    function getLocalData() {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY)) || {};
      } catch {
        return {};
      }
    }

    function setLocalData(payload) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(payload || {}));
      document.dispatchEvent(new CustomEvent(SYNC_EVENT));
    }

    function stableStringify(value) {
      try {
        return JSON.stringify(value);
      } catch {
        return "";
      }
    }

    function simpleHash(value) {
      let hash = 2166136261;
      for (let i = 0; i < value.length; i += 1) {
        hash ^= value.charCodeAt(i);
        hash = Math.imul(hash, 16777619);
      }
      return (hash >>> 0).toString(16);
    }

    function stableStringifyObject(value) {
      if (value === null || typeof value !== "object") {
        return JSON.stringify(value);
      }
      if (Array.isArray(value)) {
        return `[${value.map((item) => stableStringifyObject(item)).join(",")}]`;
      }
      const keys = Object.keys(value).sort();
      return `{${keys.map((key) => `${JSON.stringify(key)}:${stableStringifyObject(value[key])}`).join(",")}}`;
    }

    function getEntrySignature(entry) {
      if (!entry || typeof entry !== "object") return "";
      const clone = { ...entry };
      delete clone.id;
      delete clone.updatedAt;
      return `sig:${simpleHash(stableStringifyObject(clone))}`;
    }

    function getEntryIdentity(entry) {
      if (!entry || typeof entry !== "object") return "";
      const directId = String(entry.id || "").trim();
      if (directId) return `id:${directId}`;
      return getEntrySignature(entry);
    }

    function getEntryUpdatedAt(entry) {
      const explicit = Number(entry?.updatedAt);
      if (Number.isFinite(explicit) && explicit > 0) return explicit;
      const fromDate = entry?.date ? new Date(entry.date).getTime() : 0;
      return Number.isFinite(fromDate) && fromDate > 0 ? fromDate : 0;
    }

    function mergeEntryArrays(primaryEntries, secondaryEntries) {
      const byIdentity = new Map();
      const bySignature = new Map();
      for (const entry of [...(primaryEntries || []), ...(secondaryEntries || [])]) {
        const identity = getEntryIdentity(entry) || `raw:${stableStringify(entry)}`;
        const signature = getEntrySignature(entry);
        const existing = byIdentity.get(identity) || (signature ? bySignature.get(signature) : undefined);
        if (!existing) {
          byIdentity.set(identity, entry);
          if (signature) bySignature.set(signature, entry);
          continue;
        }
        const incomingUpdatedAt = getEntryUpdatedAt(entry);
        const existingUpdatedAt = getEntryUpdatedAt(existing);
        const winner = incomingUpdatedAt >= existingUpdatedAt ? entry : existing;
        byIdentity.set(identity, winner);
        if (signature) bySignature.set(signature, winner);
      }
      return Array.from(new Set(byIdentity.values()));
    }

    function mergeStores(primary, secondary) {
      const merged = { ...(primary || {}) };
      for (const [key, secondaryValue] of Object.entries(secondary || {})) {
        const primaryValue = merged[key];
        if (Array.isArray(primaryValue) && Array.isArray(secondaryValue)) {
          merged[key] = mergeEntryArrays(primaryValue, secondaryValue);
        } else if (!(key in merged)) {
          merged[key] = secondaryValue;
        }
      }
      return merged;
    }

    async function syncApi(path, options = {}) {
      const method = String(options.method || "GET").toUpperCase();
      const hasBody = Object.prototype.hasOwnProperty.call(options, "body");
      const headers = { ...(options.headers || {}) };
      if (hasBody && !headers["content-type"]) {
        headers["content-type"] = "application/json";
      }
      const response = await fetch(`${SYNC_API_BASE}${path}`, {
        credentials: "include",
        ...options,
        method,
        headers
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || data?.ok === false) {
        throw new Error(String(data?.error || `Sync request failed (${response.status})`));
      }
      return data;
    }

    async function ensureSession() {
      if (sessionPromise) return sessionPromise;
      sessionPromise = syncApi("/auth/session")
        .then((result) => Boolean(result?.authenticated))
        .catch(() => false);
      return sessionPromise;
    }

    async function autoPull() {
      const signedIn = await ensureSession();
      if (!signedIn) return;
      const result = await syncApi("/sync/export");
      const remotePayload = (result?.payload && typeof result.payload === "object" && !Array.isArray(result.payload))
        ? result.payload
        : {};
      const localPayload = getLocalData();
      const merged = mergeStores(remotePayload, localPayload);
      if (stableStringify(merged) === stableStringify(localPayload)) return;
      isApplyingRemote = true;
      setLocalData(merged);
      isApplyingRemote = false;
    }

    async function pushNow() {
      pushTimer = null;
      if (isApplyingRemote) return;
      const signedIn = await ensureSession();
      if (!signedIn) return;
      const payload = getLocalData();
      await syncApi("/sync/import", {
        method: "POST",
        body: JSON.stringify({ payload, mode: "overwrite" })
      });
    }

    function schedulePush() {
      if (isApplyingRemote) return;
      if (pushTimer) clearTimeout(pushTimer);
      pushTimer = setTimeout(() => {
        void pushNow();
      }, AUTO_PUSH_DEBOUNCE_MS);
    }

    function initAutoSync() {
      if (!SYNC_API_BASE) return;
      void autoPull();
      document.addEventListener("simpletrackers:entries-updated", () => {
        schedulePush();
      });
      window.addEventListener("online", () => {
        schedulePush();
      });
    }

    initAutoSync();
    document.addEventListener("astro:page-load", initAutoSync);
  </script>
)}
