---
import Layout from '../../components/Layout.astro';
---

<Layout seoTitle="Privacy Policy" seoDescription="How SimpleTrackers handles data, cookies, and privacy protections.">
  <main class="max-w-3xl mx-auto w-full px-4 py-8">
    <h1 class="text-[30px] leading-[1.2] font-extrabold text-slate-900 mb-2">Privacy Policy</h1>
    <p class="text-[18px] leading-[1.45] text-slate-600 mb-6">SimpleTrackers is built for privacy-first tracking in your browser.</p>

    <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-6">
      <div>
        <h2 class="text-[18px] font-bold text-slate-900 mb-2">Data Storage</h2>
        <p class="text-[15px] leading-7 text-slate-600">All tracker data is stored in your browser using localStorage. No accounts and no external database.</p>
      </div>
      <div>
        <h2 class="text-[18px] font-bold text-slate-900 mb-2">Cookies and Analytics</h2>
        <p class="text-[15px] leading-7 text-slate-600">We may use cookies for site functionality and analytics. We do not use analytics in local development environments.</p>
      </div>
      <div>
        <h2 class="text-[18px] font-bold text-slate-900 mb-2">Ads</h2>
        <p class="text-[15px] leading-7 text-slate-600">Ad placeholders are shown in development. Live ad behavior is controlled by production configuration.</p>
      </div>
      <div>
        <h2 class="text-[18px] font-bold text-slate-900 mb-2">Your Privacy</h2>
        <p class="text-[15px] leading-7 text-slate-600">No login is required. Your tracker data is not sent to our servers by default.</p>
      </div>
    </section>
  </main>
</Layout>
