---
const {
  title,
  description,
  storageKey,
  icon = 'track_changes',
  fieldNames = ["item", "notes"],
  addLabel = "Add New Item",
  itemPlaceholder = "Item",
  enableOmdbAutocomplete = false,
  omdbApiKey = "",
  autocompleteEndpoint = "",
  enableAuthorField = false,
  authorPlaceholder = "Author",
  autoPopulateAuthor = false,
  enableDirectorField = false,
  directorPlaceholder = "Director",
  autoPopulateDirector = false,
  enablePublisherField = false,
  publisherPlaceholder = "Publisher",
  autoPopulatePublisher = false
} = Astro.props;
const autocompleteEnabled = enableOmdbAutocomplete || Boolean(autocompleteEndpoint);
---

<section aria-labelledby="tracker-title" class="bg-white rounded-lg border border-gray-200 shadow-sm p-6 mb-8">
  <h2 id="tracker-title" class="flex items-center gap-2 text-lg font-semibold mb-2 text-gray-900">
    <span class="material-icons icon-blue">{icon}</span>
    <style>
      .icon-blue {
        color: #2563eb !important;
        font-size: 1.5rem;
        margin-right: 0.5rem;
      }
    </style>
    {title}
  </h2>
  <p class="text-gray-700 mb-4">{description}</p>
  <form id="tracker-form" class="flex flex-col gap-2 mb-4">
    <div class="relative">
      <input
        type="text"
        id="tracker-item"
        placeholder={itemPlaceholder}
        autocomplete={autocompleteEnabled ? "off" : "on"}
        aria-autocomplete={autocompleteEnabled ? "list" : undefined}
        aria-expanded={autocompleteEnabled ? "false" : undefined}
        class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full"
      />
      {autocompleteEnabled && (
        <div
          id="tracker-item-suggestions"
          class="hidden absolute left-0 right-0 top-[calc(100%+0.3rem)] z-20 bg-white border border-gray-200 rounded-md shadow-lg overflow-hidden"
        >
          <ul id="tracker-item-suggestions-list" class="max-h-64 overflow-y-auto py-1"></ul>
        </div>
      )}
    </div>
    {enableAuthorField && (
      <input
        type="text"
        id="tracker-author"
        placeholder={authorPlaceholder}
        class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200"
      />
    )}
    {enableDirectorField && (
      <input
        type="text"
        id="tracker-director"
        placeholder={directorPlaceholder}
        class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200"
      />
    )}
    {enablePublisherField && (
      <input
        type="text"
        id="tracker-publisher"
        placeholder={publisherPlaceholder}
        class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200"
      />
    )}
    <input type="text" id="tracker-notes" placeholder="Notes" class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
    <div class="flex items-center gap-2 mb-2">
      <label for="tracker-rating" class="text-gray-700">Rating:</label>
      <div id="tracker-rating-stars" class="flex gap-1"></div>
      <input type="hidden" id="tracker-rating" value="0" />
    </div>
    <button type="submit" class="mt-2 px-4 py-2 bg-blue-600 text-white rounded-md font-medium hover:bg-blue-700 transition">{addLabel}</button>
  </form>
  <ul id="tracker-list" class="list-none p-0 mb-4"></ul>
<style>
  :global(.star) {
    font-size: 1.3rem;
    color: #ccc !important;
    cursor: pointer;
    transition: color 0.2s;
  }
  :global(button.star) {
    width: 1.75rem;
    height: 1.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    padding: 0;
    line-height: 1;
  }
  :global(button.star:focus) {
    outline: 2px solid #93c5fd;
    outline-offset: 1px;
  }
  :global(.star.active) {
    color: #999 !important;
  }
  :global(.star.hovered) {
    color: #999 !important;
  }
  :global(.star.inactive) {
    color: #999 !important;
  }
  :global(.omdb-option) {
    width: 100%;
    border: 0;
    background: transparent;
    padding: 0.5rem 0.75rem;
    text-align: left;
    color: #1f2937;
    font-size: 0.875rem;
    line-height: 1.25rem;
    cursor: pointer;
  }
  :global(.omdb-option:hover),
  :global(.omdb-option.is-active) {
    background: #eff6ff;
    color: #1d4ed8;
  }
  :global(.omdb-option-subtitle) {
    display: block;
    color: #6b7280;
    font-size: 0.75rem;
    line-height: 1rem;
    margin-top: 0.1rem;
  }
</style>
</section>

<script define:vars={{ storageKey, enableOmdbAutocomplete, omdbApiKey, autocompleteEndpoint, enableAuthorField, autoPopulateAuthor, enableDirectorField, autoPopulateDirector, enablePublisherField, autoPopulatePublisher }}>
  const trackerType = storageKey;
  console.log(storageKey, trackerType);
  const form = document.getElementById("tracker-form");
  const itemInput = document.getElementById("tracker-item");
  const authorInput = document.getElementById("tracker-author");
  const directorInput = document.getElementById("tracker-director");
  const publisherInput = document.getElementById("tracker-publisher");
  const notesInput = document.getElementById("tracker-notes");
  const list = document.getElementById("tracker-list");
  const itemSuggestions = document.getElementById("tracker-item-suggestions");
  const itemSuggestionsList = document.getElementById("tracker-item-suggestions-list");

  function getAllEntries() {
    try {
      return JSON.parse(localStorage.getItem("simpletrackers.io")) || {};
    } catch {
      return {};
    }
  }

  function getEntries() {
    const allEntries = getAllEntries();
    return allEntries[storageKey] || [];
  }

  function saveEntries(entries) {
    const allEntries = getAllEntries();
    allEntries[storageKey] = entries;
    localStorage.setItem("simpletrackers.io", JSON.stringify(allEntries));
  }

  if ((enableOmdbAutocomplete || autocompleteEndpoint) && itemInput && itemSuggestions) {
    let autocompleteTimer = null;
    let currentSuggestions = [];
    let activeSuggestionIdx = -1;
    function normalizeSuggestion(item) {
      if (typeof item === "string") {
        return { label: item, value: item, subtitle: "", author: "", director: "", publisher: "", imdbID: "" };
      }
      if (item && typeof item === "object") {
        const value = item.value || item.label || "";
        const label = item.label || value;
        const subtitle = item.subtitle || "";
        const author = item.author || "";
        const director = item.director || "";
        const publisher = item.publisher || "";
        const imdbID = item.imdbID || "";
        if (value) {
          return { label, value, subtitle, author, director, publisher, imdbID };
        }
      }
      return null;
    }

    async function fetchOmdbDirector(imdbID) {
      if (!omdbApiKey || !imdbID) return "";
      const url = `https://www.omdbapi.com/?apikey=${encodeURIComponent(omdbApiKey)}&i=${encodeURIComponent(imdbID)}`;
      const res = await fetch(url);
      if (!res.ok) return "";
      const data = await res.json();
      if (!data || data.Response === "False") return "";
      if (!data.Director || data.Director === "N/A") return "";
      return data.Director;
    }

    async function fetchSuggestions(query) {
      if (autocompleteEndpoint) {
        const url = `${autocompleteEndpoint}?q=${encodeURIComponent(query)}`;
        const res = await fetch(url);
        if (!res.ok) return [];
        const data = await res.json();
        const raw = Array.isArray(data) ? data : (data && Array.isArray(data.suggestions) ? data.suggestions : []);
        return raw.map(normalizeSuggestion).filter(Boolean);
      }

      if (!enableOmdbAutocomplete || !omdbApiKey) return [];
      const url = `https://www.omdbapi.com/?apikey=${encodeURIComponent(omdbApiKey)}&type=movie&s=${encodeURIComponent(query)}`;
      const res = await fetch(url);
      if (!res.ok) return [];
      const data = await res.json();
      if (!data || data.Response === "False" || !Array.isArray(data.Search)) return [];
      const baseSuggestions = data.Search.slice(0, 8).map((movie) => normalizeSuggestion({
        label: `${movie.Title} (${movie.Year})`,
        value: movie.Title,
        imdbID: movie.imdbID
      })).filter(Boolean);

      if (!baseSuggestions.length) return [];

      const withDirectors = await Promise.all(
        baseSuggestions.map(async (suggestion) => {
          if (!suggestion.imdbID) return suggestion;
          const director = await fetchOmdbDirector(suggestion.imdbID);
          if (!director) return suggestion;
          return { ...suggestion, director, subtitle: director };
        })
      );
      return withDirectors;
    }

    function hideSuggestions() {
      itemSuggestions.classList.add("hidden");
      itemInput.setAttribute("aria-expanded", "false");
      activeSuggestionIdx = -1;
    }

    function showSuggestions() {
      itemSuggestions.classList.remove("hidden");
      itemInput.setAttribute("aria-expanded", "true");
    }

    function applyActiveState() {
      if (!itemSuggestionsList) return;
      const options = Array.from(itemSuggestionsList.querySelectorAll(".omdb-option"));
      options.forEach((option, idx) => {
        option.classList.toggle("is-active", idx === activeSuggestionIdx);
      });
    }

    async function chooseSuggestion(index) {
      if (index < 0 || index >= currentSuggestions.length) return;
      const suggestion = currentSuggestions[index];
      itemInput.value = suggestion.value;
      if (enableAuthorField && autoPopulateAuthor && authorInput && suggestion.author) {
        authorInput.value = suggestion.author;
      }
      if (enableDirectorField && autoPopulateDirector && directorInput) {
        if (suggestion.director) {
          directorInput.value = suggestion.director;
        } else if (suggestion.imdbID) {
          const director = await fetchOmdbDirector(suggestion.imdbID);
          if (director) {
            directorInput.value = director;
          }
        }
      }
      if (enablePublisherField && autoPopulatePublisher && publisherInput && suggestion.publisher) {
        publisherInput.value = suggestion.publisher;
      }
      hideSuggestions();
    }

    function renderSuggestions(items) {
      if (!itemSuggestionsList) return;
      itemSuggestionsList.innerHTML = "";
      currentSuggestions = items;
      activeSuggestionIdx = -1;

      items.forEach((suggestion, index) => {
        const li = document.createElement("li");
        const button = document.createElement("button");
        button.type = "button";
        button.className = "omdb-option";
        button.setAttribute("data-index", String(index));
        const subtitle = suggestion.subtitle || suggestion.author || suggestion.director || suggestion.publisher || "";
        if (subtitle) {
          button.innerHTML = `${suggestion.label}<span class="omdb-option-subtitle">${subtitle}</span>`;
        } else {
          button.textContent = suggestion.label;
        }
        li.appendChild(button);
        itemSuggestionsList.appendChild(li);
      });

      if (items.length) {
        showSuggestions();
      } else {
        hideSuggestions();
      }
    }

    itemInput.addEventListener("input", function() {
      const query = itemInput.value.trim();
      clearTimeout(autocompleteTimer);

      if (query.length < 2) {
        renderSuggestions([]);
        return;
      }

      autocompleteTimer = setTimeout(async () => {
        try {
          const suggestions = await fetchSuggestions(query);
          if (itemInput.value.trim() === query) {
            renderSuggestions(suggestions);
          }
        } catch {
          renderSuggestions([]);
        }
      }, 250);
    });

    itemInput.addEventListener("keydown", function(e) {
      if (!currentSuggestions.length) return;

      if (e.key === "ArrowDown") {
        e.preventDefault();
        activeSuggestionIdx = Math.min(activeSuggestionIdx + 1, currentSuggestions.length - 1);
        applyActiveState();
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        activeSuggestionIdx = Math.max(activeSuggestionIdx - 1, 0);
        applyActiveState();
      } else if (e.key === "Enter" && activeSuggestionIdx >= 0) {
        e.preventDefault();
        void chooseSuggestion(activeSuggestionIdx);
      } else if (e.key === "Escape") {
        hideSuggestions();
      }
    });

    if (itemSuggestionsList) {
      itemSuggestionsList.addEventListener("pointerdown", function(e) {
        const option = e.target.closest(".omdb-option");
        if (!option) return;
        e.preventDefault();
        const idx = Number(option.getAttribute("data-index"));
        if (idx >= 0) {
          void chooseSuggestion(idx);
        }
      });
    }

    document.addEventListener("pointerdown", function(e) {
      if (!itemSuggestions.contains(e.target) && e.target !== itemInput) {
        hideSuggestions();
      }
    });
  }

  function renderEntries() {
    list.innerHTML = "";
    const entries = getEntries();
    entries.forEach((entry, idx) => {
      const li = document.createElement("li");
      li.className = "mb-3";
      const authorHtml = entry.author ? `<div class=\"text-gray-600 text-sm\">by ${entry.author}</div>` : "";
      const directorHtml = entry.director ? `<div class=\"text-gray-600 text-sm\">Directed by ${entry.director}</div>` : "";
      const publisherHtml = entry.publisher ? `<div class=\"text-gray-600 text-sm\">Published by ${entry.publisher}</div>` : "";
      li.innerHTML = `
        <div class=\"bg-white rounded-lg shadow border border-gray-200 px-4 py-3 flex flex-col\">
          <div class=\"flex items-center gap-2 mb-1\">
            <span class=\"flex-1 text-gray-800 font-medium\">${entry.item}</span>
            <span class=\"text-xs text-gray-500\">${entry.date ? new Date(entry.date).toLocaleString(undefined, { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : ''}</span>
            <button class=\"px-2 py-1 text-xs bg-gray-200 rounded hover:bg-red-200 text-red-700\" aria-label=\"Delete\" data-idx=\"${idx}\">Delete</button>
          </div>
          ${authorHtml}
          ${directorHtml}
          ${publisherHtml}
          <div class=\"text-gray-700 text-sm\">${entry.notes}</div>
          <div class=\"flex items-center gap-1 mt-2\">
            ${renderStars(entry.rating || 0)}
          </div>
        </div>
      `;
      li.querySelector("button").onclick = () => {
        const entries = getEntries();
        entries.splice(idx, 1);
        saveEntries(entries);
        renderEntries();
      };
      list.appendChild(li);
    });
  }


  function renderStars(rating, hoverIdx = -1, interactive = false) {
    let starsHtml = "";
    let displayRating = hoverIdx >= 0 ? hoverIdx : rating;
    for (let i = 1; i <= 5; i++) {
      let cls = "star";
      let icon = "star_border";
      if (hoverIdx >= 0 && i <= hoverIdx) {
        cls += " hovered";
        icon = "star";
      } else if (i <= rating) {
        cls += " active";
        icon = "star";
      } else {
        cls += " inactive";
      }
      if (interactive) {
        starsHtml += `<button type="button" class="material-icons ${cls}" data-rating="${i}" aria-label="Set rating to ${i}">${icon}</button>`;
      } else {
        starsHtml += `<span class="material-icons ${cls}">${icon}</span>`;
      }
    }
    return starsHtml;
  }

  // Interactive star rating for form
  const ratingStars = document.getElementById("tracker-rating-stars");
  const ratingInput = document.getElementById("tracker-rating");
  let selectedRating = 0;
  let hoveredRating = 0;

  function ensureInteractiveStars() {
    if (!ratingStars || ratingStars.children.length === 5) return;
    ratingStars.innerHTML = "";
    for (let i = 1; i <= 5; i++) {
      const star = document.createElement("button");
      star.type = "button";
      star.className = "material-icons star inactive";
      star.dataset.rating = String(i);
      star.setAttribute("aria-label", `Set rating to ${i}`);
      star.textContent = "star_border";
      ratingStars.appendChild(star);
    }
  }

  function updateStars() {
    if (!ratingStars) return;
    ensureInteractiveStars();
    const displayRating = hoveredRating > 0 ? hoveredRating : selectedRating;
    Array.from(ratingStars.children).forEach((star, index) => {
      const starValue = index + 1;
      const isFilled = starValue <= displayRating;
      const isHovered = hoveredRating > 0 && starValue <= hoveredRating;
      star.className = `material-icons star ${isHovered ? "hovered" : isFilled ? "active" : "inactive"}`;
      star.textContent = isFilled ? "star" : "star_border";
    });
    if (ratingInput) {
      ratingInput.value = selectedRating;
    }
  }

  function getRatingFromEvent(e) {
    if (!ratingStars) return 0;
    const buttons = Array.from(ratingStars.querySelectorAll("[data-rating]"));
    if (!buttons.length) return 0;

    const targetEl = e.target instanceof Element ? e.target : e.target?.parentElement;
    const directStar = targetEl?.closest("[data-rating]");
    if (directStar) return Number(directStar.dataset.rating);

    const x = e.clientX;
    for (const button of buttons) {
      const rect = button.getBoundingClientRect();
      if (x >= rect.left && x <= rect.right) {
        return Number(button.dataset.rating);
      }
    }

    // Allow slight misses in the gap between buttons by snapping to nearest center.
    let nearest = buttons[0];
    let minDist = Infinity;
    for (const button of buttons) {
      const rect = button.getBoundingClientRect();
      const center = rect.left + rect.width / 2;
      const dist = Math.abs(x - center);
      if (dist < minDist) {
        minDist = dist;
        nearest = button;
      }
    }
    return Number(nearest.dataset.rating);
  }

  if (ratingStars) {
    updateStars();
    ratingStars.addEventListener("pointermove", function(e) {
      const rating = getRatingFromEvent(e);
      if (rating > 0) {
        hoveredRating = rating;
        updateStars();
      }
    });
    function resetHoveredStars() {
      hoveredRating = 0;
      updateStars();
    }
    ratingStars.addEventListener("mouseleave", resetHoveredStars);
    ratingStars.addEventListener("pointerleave", resetHoveredStars);
    ratingStars.addEventListener("focusout", function() {
      requestAnimationFrame(() => {
        if (!ratingStars.contains(document.activeElement)) {
          resetHoveredStars();
        }
      });
    });
    function selectFromEvent(e) {
      const rating = getRatingFromEvent(e);
      if (rating > 0) {
        selectedRating = rating;
        hoveredRating = 0;
        updateStars();
      }
    }
    ratingStars.addEventListener("pointerdown", selectFromEvent);
    ratingStars.addEventListener("click", selectFromEvent);
    ratingStars.addEventListener("keydown", function(e) {
      const star = e.target.closest("[data-rating]");
      if (star && (e.key === "Enter" || e.key === " ")) {
        e.preventDefault();
        selectedRating = Number(star.dataset.rating);
        hoveredRating = 0;
        updateStars();
      }
    });
  }

  form.onsubmit = e => {
    e.preventDefault();
    const item = itemInput.value.trim();
    const author = authorInput?.value.trim() || "";
    const director = directorInput?.value.trim() || "";
    const publisher = publisherInput?.value.trim() || "";
    const notes = notesInput.value.trim();
    const rating = parseFloat(ratingInput?.value) || 0;
    if (!item) return;
    const date = new Date().toISOString();
    const entries = getEntries();
    const nextEntry = { item, notes, rating, date };
    if (enableAuthorField) {
      nextEntry.author = author;
    }
    if (enableDirectorField) {
      nextEntry.director = director;
    }
    if (enablePublisherField) {
      nextEntry.publisher = publisher;
    }
    entries.push(nextEntry);
    saveEntries(entries);
    itemInput.value = "";
    if (authorInput) {
      authorInput.value = "";
    }
    if (directorInput) {
      directorInput.value = "";
    }
    if (publisherInput) {
      publisherInput.value = "";
    }
    notesInput.value = "";
    selectedRating = 0;
    hoveredRating = 0;
    if (ratingInput) {
      ratingInput.value = 0;
    }
    updateStars();
    renderEntries();
  };

  renderEntries();
</script>
