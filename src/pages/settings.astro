---
import Layout from '../components/Layout.astro';
import TrackerPageWrapper from '../components/TrackerPageWrapper.astro';
const syncApiBase = (import.meta.env.PUBLIC_SYNC_API_BASE || "https://trackers.wylie.workers.dev").replace(/\/$/, "");
---

<Layout seoTitle="Settings" seoDescription="Manage your local tracker data: download a backup or clear all saved data." noindex={true}>
  <TrackerPageWrapper>
    <main>
      <div class="max-w-3xl mx-auto">
        <h1 class="text-[30px] leading-[1.2] font-extrabold text-slate-900 mb-2">Settings</h1>
        <p class="text-[18px] leading-[1.45] text-slate-600 mb-6">Manage your locally saved tracker data.</p>

        <section id="cloud-sync-settings" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
          <h2 class="text-[18px] font-bold text-slate-900 mb-2">Cloud Sync (Optional)</h2>
          <p class="text-[15px] leading-7 text-slate-600 mb-4">Use magic-link sign in to sync your tracker data across devices.</p>

          <div id="sync-auth-state" class="text-sm text-slate-500 mb-4">Checking sync session...</div>

          <div id="sync-login-form" class="grid grid-cols-1 sm:grid-cols-[minmax(0,1fr)_auto] gap-2 mb-4">
            <input id="sync-email-input" type="email" placeholder="you@example.com" class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
            <button id="sync-send-link-btn" type="button" class="px-4 py-2 bg-blue-600 text-white rounded-md font-medium hover:bg-blue-700 transition">Email Sign-In Link</button>
          </div>

          <div id="sync-actions" class="grid grid-cols-1 sm:grid-cols-3 gap-2 mb-3 hidden">
            <button id="sync-pull-btn" type="button" class="w-full px-4 py-2 bg-slate-700 text-white rounded-md font-medium hover:bg-slate-800 transition">Pull From Cloud</button>
            <button id="sync-push-btn" type="button" class="w-full px-4 py-2 bg-emerald-600 text-white rounded-md font-medium hover:bg-emerald-700 transition">Push Local To Cloud</button>
            <button id="sync-signout-btn" type="button" class="w-full px-4 py-2 bg-gray-200 text-slate-800 rounded-md font-medium hover:bg-gray-300 transition">Sign Out</button>
          </div>

          <p class="text-sm text-slate-500">Local mode remains the default. Sync is only used when you sign in.</p>
          <p id="sync-message" class="mt-3 text-sm hidden"></p>
        </section>

        <section id="local-data-settings" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
          <h2 class="text-[18px] font-bold text-slate-900 mb-2">Local Data</h2>
          <p class="text-[15px] leading-7 text-slate-600 mb-4">Your entries are stored in this browser only.</p>

          <div id="data-summary" class="text-sm text-slate-500 mb-4">Checking local data...</div>

          <div class="mb-6">
            <h3 class="text-sm font-semibold text-slate-700 mb-2">Backup</h3>
            <div id="settings-backup-actions" class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              <button id="settings-download-data" type="button" class="w-full px-4 py-2 bg-blue-600 text-white rounded-md font-medium hover:bg-blue-700 transition">
                Download Data (JSON)
              </button>
              <button id="settings-upload-data" type="button" class="w-full px-4 py-2 bg-gray-700 text-white rounded-md font-medium hover:bg-gray-800 transition">
                Upload Data (Restore)
              </button>
              <input id="settings-upload-data-input" type="file" accept=".json,application/json" class="hidden" />
            </div>
            <fieldset id="settings-upload-mode" class="mt-3">
              <legend class="text-sm font-semibold text-slate-700">Upload Mode</legend>
              <div class="mt-2 flex flex-col sm:flex-row gap-3 text-sm text-slate-600">
                <label class="inline-flex items-center gap-2">
                  <input id="settings-upload-merge" type="radio" name="upload-mode" value="merge" checked />
                  Merge with existing data
                </label>
                <label class="inline-flex items-center gap-2">
                  <input id="settings-upload-overwrite" type="radio" name="upload-mode" value="overwrite" />
                  Overwrite existing data
                </label>
              </div>
            </fieldset>
            <p class="mt-2 text-sm text-slate-500">Choose merge to combine backups, or overwrite to replace all current local data.</p>
          </div>

          <div class="mb-6">
            <h3 class="text-sm font-semibold text-slate-700 mb-2">Restore Points</h3>
            <p class="text-sm text-slate-500 mb-3">Automatic local snapshots are saved when entries change. Restore any point below if you need to undo accidental edits/deletes.</p>
            <div id="settings-history-list" class="space-y-2"></div>
            <button id="settings-clear-history-btn" type="button" class="mt-3 px-3 py-1.5 text-xs font-semibold rounded-md border border-slate-300 text-slate-700 bg-white hover:bg-slate-100 transition">
              Clear Restore History
            </button>
          </div>

          <div class="mb-6">
            <h3 class="text-sm font-semibold text-slate-700 mb-2">Manage Individual Tracker Data</h3>
            <p class="text-sm text-slate-500 mb-3">Download or clear one tracker at a time while keeping everything else intact.</p>
            <div id="settings-clear-tracker-list" class="space-y-2"></div>
          </div>

          <div class="rounded-md border border-red-200 bg-red-50 p-4">
            <h3 class="text-sm font-semibold text-red-800 mb-2">Danger Zone</h3>
            <p class="text-sm text-red-700 mb-3">Permanently delete all locally saved tracker data from this browser.</p>
            <div id="settings-danger-actions" class="pt-1">
              <button id="settings-clear-all-data-btn" type="button" class="inline-flex justify-center w-full px-4 py-2 bg-red-600 text-white rounded-md font-medium hover:bg-red-700 transition">
                Clear All Data
              </button>
            </div>
          </div>

          <p class="text-sm text-slate-500 mt-4">Clear is permanent for this browser unless you restore from a backup file.</p>
          <p id="settings-message" class="mt-3 text-sm hidden"></p>
        </section>

        <section id="data-import-settings" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mt-6">
          <h2 class="text-[18px] font-bold text-slate-900 mb-2">Data Imports</h2>
          <p class="text-[15px] leading-7 text-slate-600 mb-4">Import data from other apps and sites into SimpleTrackers.</p>
          <div class="space-y-3">
            <div class="rounded-md border border-slate-200 bg-slate-50 p-3">
              <div class="flex items-center justify-between gap-3 flex-wrap">
                <div>
                  <p class="text-sm font-semibold text-slate-800">Goodreads</p>
                  <p class="text-xs text-slate-500">CSV export to Reading Tracker</p>
                </div>
                <button id="settings-import-goodreads" type="button" class="px-4 py-2 bg-emerald-600 text-white rounded-md font-medium hover:bg-emerald-700 transition">
                  Import Goodreads CSV
                </button>
                <input id="settings-import-goodreads-input" type="file" accept=".csv,text/csv" class="hidden" />
              </div>
            </div>
            <div class="rounded-md border border-slate-200 bg-slate-50 p-3">
              <div class="flex items-center justify-between gap-3 flex-wrap">
                <div>
                  <p class="text-sm font-semibold text-slate-800">WaterMinder</p>
                  <p class="text-xs text-slate-500">CSV export to Water Intake Tracker</p>
                </div>
                <button id="settings-import-waterminder" type="button" class="px-4 py-2 bg-cyan-600 text-white rounded-md font-medium hover:bg-cyan-700 transition">
                  Import WaterMinder CSV
                </button>
                <input id="settings-import-waterminder-input" type="file" accept=".csv,text/csv" class="hidden" />
              </div>
            </div>
          </div>
          <p class="mt-2 text-xs text-slate-500">Imported entries merge into your existing tracker data. More import sources can be added here over time.</p>
          <p id="settings-import-message" class="mt-3 text-sm hidden"></p>
        </section>
      </div>
    </main>
  </TrackerPageWrapper>
</Layout>

<script define:vars={{ syncApiBase }}>
  const STORAGE_KEY = "simpletrackers.io";
  const HISTORY_KEY = "simpletrackers:history";
  const SYNC_API_BASE = syncApiBase;

  function getData() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY)) || {};
    } catch {
      return {};
    }
  }

  function countEntries(data) {
    return Object.values(data).reduce((total, value) => {
      return total + (Array.isArray(value) ? value.length : 0);
    }, 0);
  }

  function getHistory() {
    try {
      const parsed = JSON.parse(localStorage.getItem(HISTORY_KEY) || "[]");
      return Array.isArray(parsed) ? parsed : [];
    } catch {
      return [];
    }
  }

  function setHistory(entries) {
    localStorage.setItem(HISTORY_KEY, JSON.stringify(Array.isArray(entries) ? entries : []));
  }

  function isQuotaExceededError(error) {
    if (!error || typeof error !== "object") return false;
    const message = String(error.message || "").toLowerCase();
    return (
      error.name === "QuotaExceededError"
      || error.code === 22
      || message.includes("quota")
      || message.includes("exceeded")
    );
  }

  function pushHistorySnapshot(beforeData, storageKey = "manual") {
    try {
      const history = getHistory();
      history.unshift({
        id: `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`,
        at: Date.now(),
        storageKey,
        payload: beforeData && typeof beforeData === "object" ? beforeData : {}
      });
      const bounded = history.slice(0, 30);
      try {
        setHistory(bounded);
        return true;
      } catch (error) {
        if (!isQuotaExceededError(error)) throw error;
        // Trim aggressively and retry.
        const trimmed = bounded.slice(0, 8);
        try {
          setHistory(trimmed);
          return true;
        } catch {
          // Last fallback: disable history rather than blocking user actions.
          try {
            localStorage.removeItem(HISTORY_KEY);
          } catch {
            // Ignore cleanup failures.
          }
          return false;
        }
      }
    } catch {
      return false;
    }
  }

  function formatHistoryTime(ts) {
    const date = new Date(Number(ts) || 0);
    if (Number.isNaN(date.getTime())) return "Unknown time";
    return date.toLocaleString(undefined, {
      year: "numeric",
      month: "short",
      day: "numeric",
      hour: "numeric",
      minute: "2-digit"
    });
  }

  function uniqueEntries(entries) {
    const seen = new Set();
    const next = [];
    for (const entry of entries) {
      const key = JSON.stringify(entry);
      if (seen.has(key)) continue;
      seen.add(key);
      next.push(entry);
    }
    return next;
  }

  function mergeData(existingData, uploadedData) {
    const merged = { ...existingData };
    for (const [trackerKey, uploadedValue] of Object.entries(uploadedData)) {
      const existingValue = merged[trackerKey];
      if (Array.isArray(existingValue) && Array.isArray(uploadedValue)) {
        merged[trackerKey] = uniqueEntries([...uploadedValue, ...existingValue]);
      } else {
        merged[trackerKey] = uploadedValue;
      }
    }
    return merged;
  }

  function detectCsvDelimiter(raw) {
    const sample = String(raw || "").split(/\r?\n/).slice(0, 5).join("\n");
    const candidates = [",", ";", "\t", "|"];
    let best = ",";
    let bestScore = -1;
    candidates.forEach((delimiter) => {
      const score = sample.split(delimiter).length - 1;
      if (score > bestScore) {
        bestScore = score;
        best = delimiter;
      }
    });
    return best;
  }

  function parseCsv(text) {
    const raw = String(text || "").replace(/^\uFEFF/, "");
    if (!raw.trim()) return [];
    const delimiter = detectCsvDelimiter(raw);
    const records = [];
    let record = [];
    let value = "";
    let inQuotes = false;

    for (let i = 0; i < raw.length; i += 1) {
      const char = raw[i];
      const next = raw[i + 1];
      if (char === "\"") {
        if (inQuotes && next === "\"") {
          value += "\"";
          i += 1;
        } else {
          inQuotes = !inQuotes;
        }
        continue;
      }
      if (char === delimiter && !inQuotes) {
        record.push(value.trim());
        value = "";
        continue;
      }
      if ((char === "\n" || char === "\r") && !inQuotes) {
        if (char === "\r" && next === "\n") i += 1;
        record.push(value.trim());
        value = "";
        if (record.some((cell) => cell !== "")) {
          records.push(record);
        }
        record = [];
        continue;
      }
      value += char;
    }

    record.push(value.trim());
    if (record.some((cell) => cell !== "")) {
      records.push(record);
    }
    if (!records.length) return [];

    const headers = records[0].map((header) => String(header || "").trim().toLowerCase());
    const rows = [];
    for (let i = 1; i < records.length; i += 1) {
      const cols = records[i];
      const row = {};
      headers.forEach((header, idx) => {
        row[header] = cols[idx] ?? "";
      });
      rows.push(row);
    }
    return rows;
  }

  function parseGoodreadsDate(value) {
    const raw = String(value || "").trim();
    if (!raw) return "";
    const isoYmd = raw.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/);
    if (isoYmd) {
      const year = Number(isoYmd[1]);
      const month = Number(isoYmd[2]);
      const day = Number(isoYmd[3]);
      if (month >= 1 && month <= 12 && day >= 1 && day <= 31 && year >= 1900) {
        return `${year}-${String(month).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
      }
    }
    const mdY = raw.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
    if (mdY) {
      const month = Number(mdY[1]);
      const day = Number(mdY[2]);
      const year = Number(mdY[3]);
      if (month >= 1 && month <= 12 && day >= 1 && day <= 31 && year >= 1900) {
        return `${year}-${String(month).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
      }
    }
    const mdYY = raw.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2})$/);
    if (mdYY) {
      const month = Number(mdYY[1]);
      const day = Number(mdYY[2]);
      const shortYear = Number(mdYY[3]);
      const year = shortYear >= 70 ? 1900 + shortYear : 2000 + shortYear;
      if (month >= 1 && month <= 12 && day >= 1 && day <= 31) {
        return `${year}-${String(month).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
      }
    }
    const parsed = new Date(raw);
    if (Number.isNaN(parsed.getTime())) return "";
    const yyyy = parsed.getFullYear();
    const mm = String(parsed.getMonth() + 1).padStart(2, "0");
    const dd = String(parsed.getDate()).padStart(2, "0");
    return `${yyyy}-${mm}-${dd}`;
  }

  function parseIntSafe(value, fallback = 0) {
    const parsed = Number.parseInt(String(value || "").trim(), 10);
    return Number.isFinite(parsed) ? parsed : fallback;
  }

  function parseFloatSafe(value, fallback = 0) {
    const parsed = Number.parseFloat(String(value || "").trim());
    return Number.isFinite(parsed) ? parsed : fallback;
  }

  function normalizeShelf(value) {
    return String(value || "").trim().toLowerCase();
  }

  function normalizeIsbn(value) {
    return String(value || "").replace(/[^0-9Xx]/g, "").toUpperCase();
  }

  function normalizeBookTitleForDedup(value) {
    const raw = String(value || "").trim().toLowerCase();
    if (!raw) return "";
    const noParens = raw
      .replace(/\s*\([^)]*\)\s*/g, " ")
      .replace(/\s*\[[^\]]*\]\s*/g, " ");
    const noSubtitle = noParens.replace(/\s*[:\-–—]\s.*$/g, " ");
    return noSubtitle.replace(/[^a-z0-9\s]/g, " ").replace(/\s+/g, " ").trim();
  }

  function normalizeAuthorForDedup(value) {
    return String(value || "")
      .trim()
      .toLowerCase()
      .replace(/[^a-z0-9\s]/g, " ")
      .replace(/\s+/g, " ")
      .trim();
  }

  function getReadingDedupKeys(entry) {
    const keys = [];
    const isbn13 = normalizeIsbn(entry?.isbn13);
    const isbn = normalizeIsbn(entry?.isbn);
    if (isbn13) keys.push(`isbn13:${isbn13}`);
    if (isbn) keys.push(`isbn:${isbn}`);
    const titleNorm = normalizeBookTitleForDedup(entry?.item);
    const authorNorm = normalizeAuthorForDedup(entry?.author);
    if (titleNorm && authorNorm) keys.push(`ta:${titleNorm}|${authorNorm}`);
    if (titleNorm && !authorNorm) keys.push(`t:${titleNorm}`);
    return keys;
  }

  function extractGoodreadsRowsToReadingEntries(rows) {
    const now = Date.now();
    const entries = [];
    let skipped = 0;
    rows.forEach((row, idx) => {
      const title = String(row["title"] || "").trim();
      if (!title) return;
      const author = String(row["author"] || "").trim();
      const publisher = String(row["publisher"] || "").trim();
      const pages = Math.max(0, parseIntSafe(row["number of pages"], 0));
      const rating = Math.max(0, Math.min(5, Math.round(parseFloatSafe(row["my rating"], 0))));
      const myReview = String(row["my review"] || "").trim();
      const privateNotes = String(row["private notes"] || "").trim();
      const notes = [myReview, privateNotes].filter(Boolean).join("\n\n").trim();
      const shelf = normalizeShelf(row["exclusive shelf"] || row["bookshelves"]);
      const imageUrl = String(row["image url"] || row["cover image"] || "").trim();
      const isbn13 = String(row["isbn13"] || row["isbn 13"] || "").trim();
      const isbn = String(row["isbn"] || "").trim();
      const dateRead = parseGoodreadsDate(row["date read"]);
      const dateStarted = parseGoodreadsDate(row["date started"]);
      const dateAdded = parseGoodreadsDate(row["date added"]);
      const isReadShelf = shelf === "read";
      const currentlyReading = shelf === "currently-reading";
      const hasGoodreadsDate = Boolean(dateRead || dateStarted || dateAdded);
      const shouldImport = (isReadShelf || currentlyReading || Boolean(dateRead)) && hasGoodreadsDate;
      if (!shouldImport) {
        skipped += 1;
        return;
      }
      const startedDate = dateStarted || (currentlyReading ? dateAdded : "");
      const finishedDate = isReadShelf ? (dateRead || "") : "";
      const entryDate = finishedDate || startedDate || dateAdded;
      if (!entryDate) {
        skipped += 1;
        return;
      }
      const isoDate = new Date(`${entryDate}T12:00:00`).toISOString();
      const updatedAt = Number.isFinite(new Date(isoDate).getTime()) ? new Date(isoDate).getTime() : now;

      entries.push({
        id: `goodreads_${updatedAt}_${idx}_${Math.random().toString(16).slice(2, 8)}`,
        date: isoDate,
        updatedAt,
        item: title,
        author,
        publisher,
        coverUrl: imageUrl,
        isbn13,
        isbn,
        notes,
        notesHistory: notes ? [{ note: notes, createdAt: updatedAt }] : [],
        rating,
        currentlyReading,
        isAudiobook: false,
        startedDate: startedDate || "",
        finishedDate,
        currentPage: currentlyReading ? 0 : (pages > 0 ? pages : 0),
        totalPages: pages > 0 ? pages : 0,
        readingSessionMinutes: 0,
        readingSessionHistory: [],
        readingActivityHistory: []
      });
    });
    return { entries, skipped };
  }

  function getCsvValue(row, keys) {
    if (!row || typeof row !== "object") return "";
    const normalized = new Map(
      Object.entries(row).map(([key, value]) => [
        String(key || "").toLowerCase().replace(/[^a-z0-9]+/g, " ").trim(),
        value
      ])
    );
    for (const key of keys) {
      const directKey = String(key || "").toLowerCase();
      const value = row[directKey];
      if (value !== undefined && value !== null && String(value).trim() !== "") {
        return String(value).trim();
      }
      const normalizedKey = directKey.replace(/[^a-z0-9]+/g, " ").trim();
      if (normalizedKey && normalized.has(normalizedKey)) {
        const normalizedValue = normalized.get(normalizedKey);
        if (normalizedValue !== undefined && normalizedValue !== null && String(normalizedValue).trim() !== "") {
          return String(normalizedValue).trim();
        }
      }
    }
    return "";
  }

  function normalizeHeaderKey(value) {
    return String(value || "").toLowerCase().replace(/[^a-z0-9]+/g, " ").trim();
  }

  function getCsvValueByHeaderHint(row, headerHints, excludeHints = []) {
    if (!row || typeof row !== "object") return "";
    const include = Array.isArray(headerHints) ? headerHints.map(normalizeHeaderKey).filter(Boolean) : [];
    const exclude = Array.isArray(excludeHints) ? excludeHints.map(normalizeHeaderKey).filter(Boolean) : [];
    if (!include.length) return "";
    const entries = Object.entries(row);
    for (const [key, value] of entries) {
      const normalizedHeader = normalizeHeaderKey(key);
      if (!normalizedHeader) continue;
      const blocked = exclude.some((hint) => normalizedHeader.includes(hint));
      if (blocked) continue;
      const matches = include.some((hint) => normalizedHeader.includes(hint));
      if (!matches) continue;
      const trimmed = String(value || "").trim();
      if (trimmed) return trimmed;
    }
    return "";
  }

  function parseImportDateTime(dateRaw, timeRaw = "") {
    const directRaw = String(dateRaw || "").trim();
    const timeText = String(timeRaw || "").trim();
    if (!directRaw) return null;

    const directParsed = new Date(directRaw);
    if (!Number.isNaN(directParsed.getTime())) return directParsed;

    const mergedRaw = timeText ? `${directRaw} ${timeText}` : directRaw;
    const mergedParsed = new Date(mergedRaw);
    if (!Number.isNaN(mergedParsed.getTime())) return mergedParsed;

    const mdY = directRaw.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})$/);
    if (mdY) {
      const month = Number(mdY[1]);
      const day = Number(mdY[2]);
      const yearRaw = Number(mdY[3]);
      const year = yearRaw < 100 ? (yearRaw >= 70 ? 1900 + yearRaw : 2000 + yearRaw) : yearRaw;
      if (month >= 1 && month <= 12 && day >= 1 && day <= 31) {
        const normalizedTime = timeText || "12:00";
        const fallback = new Date(`${year}-${String(month).padStart(2, "0")}-${String(day).padStart(2, "0")}T${normalizedTime}`);
        if (!Number.isNaN(fallback.getTime())) return fallback;
      }
    }
    return null;
  }

  function parseVolumeAmount(value) {
    const raw = String(value || "").trim();
    if (!raw) return 0;
    const cleaned = raw.replace(/,/g, "");
    const direct = Number.parseFloat(cleaned);
    if (Number.isFinite(direct)) return Math.max(0, direct);
    const match = cleaned.match(/-?\d+(\.\d+)?/);
    if (!match) return 0;
    const parsed = Number.parseFloat(match[0]);
    return Number.isFinite(parsed) ? Math.max(0, parsed) : 0;
  }

  function detectVolumeUnit(rawUnit, amountText = "") {
    const unit = String(rawUnit || "").trim().toLowerCase();
    const amount = String(amountText || "").trim().toLowerCase();
    if (unit.includes("ml") || amount.includes("ml")) return "ml";
    if (unit.includes("liter") || unit.includes("litre") || amount.includes("liter") || amount.includes("litre")) return "ml";
    if (unit.includes("l ") || unit === "l") return "ml";
    if (amount.includes("fl oz") || amount.includes("floz")) return "oz";
    if (unit.includes("oz") || amount.includes("oz")) return "oz";
    const amountValue = parseVolumeAmount(amount);
    if (amountValue >= 200) return "ml";
    return "oz";
  }

  function toOunces(value, unit) {
    const amount = Math.max(0, Number(value) || 0);
    return unit === "ml" ? amount / 29.5735 : amount;
  }

  function parseHydrationImpact(rawImpact, rawPercent) {
    const impactDirect = parseVolumeAmount(rawImpact);
    if (impactDirect > 0) {
      if (impactDirect > 1.2 && impactDirect <= 120) return Math.max(0, Math.min(1.2, impactDirect / 100));
      return Math.max(0, Math.min(1.2, impactDirect));
    }
    const percent = parseVolumeAmount(rawPercent);
    if (percent > 0) {
      if (percent > 1.2 && percent <= 120) return Math.max(0, Math.min(1.2, percent / 100));
      return Math.max(0, Math.min(1.2, percent));
    }
    return 1;
  }

  function normalizeDrinkTypeLabel(rawType) {
    const label = String(rawType || "").trim();
    if (!label) return { type: "water", label: "Water" };
    const normalized = label.toLowerCase();
    const knownMap = new Map([
      ["water", "water"],
      ["sparkling water", "sparkling-water"],
      ["tea", "tea"],
      ["coffee", "coffee"],
      ["milk", "milk"],
      ["juice", "juice"],
      ["sports drink", "sports-drink"],
      ["hot chocolate", "hot-chocolate"],
      ["soda", "soda"],
      ["beer", "beer"],
      ["wine", "wine"]
    ]);
    return {
      type: knownMap.get(normalized) || "custom",
      label
    };
  }

  function formatOuncesCompact(value) {
    const amount = Math.max(0, Number(value) || 0);
    const text = amount % 1 === 0 ? String(Math.round(amount)) : amount.toFixed(1).replace(/\.0$/, "");
    return `${text}oz`;
  }

  function buildWaterDrinkHistoryItem(item) {
    const ounces = Math.max(0, Number(item?.ounces) || 0);
    const impact = Math.max(0, Math.min(1.2, Number(item?.impact) || 1));
    const hydrationOunces = Math.max(0, Number(item?.hydrationOunces) || (ounces * impact));
    return {
      type: String(item?.type || "water").trim() || "water",
      label: String(item?.label || "Water").trim() || "Water",
      ounces,
      hydrationOunces,
      impact,
      createdAt: Number(item?.createdAt) || Date.now()
    };
  }

  function getDayKey(date) {
    const d = date instanceof Date ? date : new Date(date);
    if (Number.isNaN(d.getTime())) return "";
    const year = d.getFullYear();
    const month = String(d.getMonth() + 1).padStart(2, "0");
    const day = String(d.getDate()).padStart(2, "0");
    return `${year}-${month}-${day}`;
  }

  function extractWaterMinderRowsToEntries(rows) {
    const byDay = new Map();
    let skipped = 0;

    rows.forEach((row, idx) => {
      const dateValue = getCsvValue(row, ["date/time", "datetime", "logged at", "created at", "date", "day"])
        || getCsvValueByHeaderHint(row, ["date", "logged", "created", "time"], ["goal", "target"]);
      const timeValue = getCsvValue(row, ["time", "logged time"]);
      const parsedDate = parseImportDateTime(dateValue, timeValue);
      if (!(parsedDate instanceof Date) || Number.isNaN(parsedDate.getTime())) {
        skipped += 1;
        return;
      }
      const amountRaw = getCsvValue(
        row,
        [
          "water value(oz)",
          "water value",
          "water amount",
          "drink value(oz)",
          "drink value",
          "amount",
          "volume",
          "quantity",
          "qty",
          "size",
          "drink amount",
          "amount consumed",
          "drink size"
        ]
      )
        || getCsvValueByHeaderHint(
          row,
          ["water value", "drink value", "amount", "volume", "quantity", "qty", "drink size", "amount consumed", "serving size", "intake"],
          ["goal", "target", "daily", "total", "remaining", "left", "progress", "percent", "percentage", "hydration", "impact"]
        );
      const hydrationRaw = getCsvValue(
        row,
        ["hydration value(oz)", "hydration value", "hydration amount", "hydration"]
      ) || getCsvValueByHeaderHint(
        row,
        ["hydration value", "hydration amount"],
        ["goal", "target", "daily", "percent", "percentage", "progress"]
      );
      const amount = parseVolumeAmount(amountRaw);
      if (amount <= 0) {
        skipped += 1;
        return;
      }
      const unitRaw = getCsvValue(row, ["unit", "units", "volume unit", "measurement unit"])
        || getCsvValueByHeaderHint(row, ["unit", "measurement", "oz", "ml"], ["goal", "target", "daily", "total"]);
      const unit = detectVolumeUnit(unitRaw, amountRaw);
      const ounces = toOunces(amount, unit);
      if (ounces <= 0) {
        skipped += 1;
        return;
      }
      const drinkRaw = getCsvValue(row, ["drink type", "beverage", "drink", "type", "title", "name", "cup name"])
        || getCsvValueByHeaderHint(row, ["drink", "beverage", "type", "name"], ["goal", "target"]);
      const drink = normalizeDrinkTypeLabel(drinkRaw);
      const hydrationImpact = parseHydrationImpact(
        getCsvValue(row, ["hydration impact", "impact", "hydration factor"])
          || getCsvValueByHeaderHint(row, ["hydration impact", "hydration factor", "impact factor"], ["goal", "target", "daily", "progress"]),
        getCsvValue(row, ["hydration", "hydration %", "hydration percent"])
          || getCsvValueByHeaderHint(row, ["hydration percent", "hydration %", "hydration"], ["goal", "target", "daily", "progress", "completion"])
      );
      const hydrationValueOunces = parseVolumeAmount(hydrationRaw);
      const hydrationOunces = hydrationValueOunces > 0
        ? Math.max(0, hydrationValueOunces)
        : Math.max(0, ounces * hydrationImpact);
      const note = getCsvValue(row, ["notes", "note", "comment", "memo"]);
      const dayKey = getDayKey(parsedDate);
      if (!dayKey) {
        skipped += 1;
        return;
      }

      const current = byDay.get(dayKey) || {
        date: new Date(`${dayKey}T12:00:00`),
        latestAt: 0,
        notesHistory: [],
        drinks: []
      };
      const createdAt = parsedDate.getTime();
      current.latestAt = Math.max(current.latestAt, createdAt);
      current.drinks.push(buildWaterDrinkHistoryItem({
        type: drink.type,
        label: drink.label,
        ounces,
        hydrationOunces,
        impact: hydrationImpact,
        createdAt
      }));
      if (note) {
        current.notesHistory.push({ note, createdAt });
      }
      byDay.set(dayKey, current);
    });

    const entries = Array.from(byDay.entries()).map(([dayKey, dayData], idx) => {
      const history = Array.isArray(dayData.drinks) ? dayData.drinks : [];
      const totalOunces = history.reduce((sum, item) => sum + Math.max(0, Number(item?.ounces) || 0), 0);
      const totalHydration = history.reduce((sum, item) => sum + Math.max(0, Number(item?.hydrationOunces) || 0), 0);
      const impact = totalOunces > 0 ? Math.max(0, Math.min(1.2, totalHydration / totalOunces)) : 1;
      const distinctLabels = Array.from(new Set(history.map((item) => String(item?.label || "").trim()).filter(Boolean)));
      const singleLabel = distinctLabels.length === 1 ? distinctLabels[0] : "Mixed Drinks";
      const singleType = distinctLabels.length === 1 ? String(history[0]?.type || "water").trim() || "water" : "mixed";
      const notesHistory = Array.isArray(dayData.notesHistory) ? dayData.notesHistory : [];
      notesHistory.sort((a, b) => Number(a?.createdAt || 0) - Number(b?.createdAt || 0));
      const latestNote = notesHistory.length ? String(notesHistory[notesHistory.length - 1]?.note || "").trim() : "";
      const isoDate = new Date(`${dayKey}T12:00:00`).toISOString();
      const updatedAt = Number(dayData.latestAt) || Date.now();
      return {
        id: `waterminder_${updatedAt}_${idx}_${Math.random().toString(16).slice(2, 8)}`,
        date: isoDate,
        updatedAt,
        item: `${formatOuncesCompact(totalOunces)} ${singleLabel}`,
        notes: latestNote,
        notesHistory: notesHistory.map((noteRow) => ({
          note: String(noteRow?.note || "").trim(),
          createdAt: Number(noteRow?.createdAt) || updatedAt
        })).filter((noteRow) => noteRow.note),
        rating: 0,
        waterOunces: totalOunces,
        hydrationOunces: totalHydration,
        waterHydrationImpact: impact,
        waterDrinkType: singleType,
        waterDrinkLabel: singleLabel,
        waterVolumeUnit: "oz",
        waterDrinkHistory: history
      };
    });

    entries.sort((a, b) => Number(b?.updatedAt || 0) - Number(a?.updatedAt || 0));
    return { entries, skipped };
  }

  function mergeWaterEntriesByDay(existingEntries, importedEntries) {
    const dayMap = new Map();
    const toArray = (value) => (Array.isArray(value) ? value : []);
    const allExisting = toArray(existingEntries).map((entry) => ({ ...entry }));
    allExisting.forEach((entry) => {
      const key = getDayKey(entry?.date || "");
      if (key) dayMap.set(key, entry);
    });

    let mergedDays = 0;
    importedEntries.forEach((incomingRaw) => {
      const incoming = { ...incomingRaw };
      const key = getDayKey(incoming?.date || "");
      if (!key) return;
      const existing = dayMap.get(key);
      if (!existing) {
        dayMap.set(key, incoming);
        return;
      }
      mergedDays += 1;
      const existingHistory = Array.isArray(existing?.waterDrinkHistory) ? existing.waterDrinkHistory : [];
      const incomingHistory = Array.isArray(incoming?.waterDrinkHistory) ? incoming.waterDrinkHistory : [];
      const historySeen = new Set();
      const mergedHistory = [...existingHistory, ...incomingHistory].map((item) => buildWaterDrinkHistoryItem(item)).filter((item) => {
        const signature = `${String(item?.label || "").trim().toLowerCase()}|${Number(item?.ounces || 0)}|${Number(item?.createdAt || 0)}`;
        if (historySeen.has(signature)) return false;
        historySeen.add(signature);
        return true;
      });
      const totalOunces = mergedHistory.reduce((sum, item) => sum + Math.max(0, Number(item?.ounces) || 0), 0);
      const totalHydration = mergedHistory.reduce((sum, item) => sum + Math.max(0, Number(item?.hydrationOunces) || 0), 0);
      const impact = totalOunces > 0 ? Math.max(0, Math.min(1.2, totalHydration / totalOunces)) : 1;
      const labels = Array.from(new Set(mergedHistory.map((item) => String(item?.label || "").trim()).filter(Boolean)));
      const label = labels.length === 1 ? labels[0] : "Mixed Drinks";
      const type = labels.length === 1 ? String(mergedHistory[0]?.type || "water").trim() || "water" : "mixed";
      const existingNotes = Array.isArray(existing?.notesHistory) ? existing.notesHistory : [];
      const incomingNotes = Array.isArray(incoming?.notesHistory) ? incoming.notesHistory : [];
      const noteSeen = new Set();
      const notesHistory = [...existingNotes, ...incomingNotes]
        .map((row) => ({
          note: String(row?.note || "").trim(),
          createdAt: Number(row?.createdAt) || Date.now()
        }))
        .filter((row) => row.note)
        .filter((row) => {
          const signature = `${row.note}|${row.createdAt}`;
          if (noteSeen.has(signature)) return false;
          noteSeen.add(signature);
          return true;
        })
        .sort((a, b) => a.createdAt - b.createdAt);
      const latestNote = notesHistory.length ? notesHistory[notesHistory.length - 1].note : "";

      dayMap.set(key, {
        ...existing,
        ...incoming,
        date: existing?.date || incoming?.date || new Date(`${key}T12:00:00`).toISOString(),
        updatedAt: Math.max(Number(existing?.updatedAt) || 0, Number(incoming?.updatedAt) || 0),
        item: `${formatOuncesCompact(totalOunces)} ${label}`,
        notes: latestNote,
        notesHistory,
        rating: 0,
        waterOunces: totalOunces,
        hydrationOunces: totalHydration,
        waterHydrationImpact: impact,
        waterDrinkType: type,
        waterDrinkLabel: label,
        waterVolumeUnit: "oz",
        waterDrinkHistory: mergedHistory
      });
    });

    const mergedEntries = Array.from(dayMap.values());
    mergedEntries.sort((a, b) => {
      const aUpdated = Number(a?.updatedAt) || 0;
      const bUpdated = Number(b?.updatedAt) || 0;
      if (aUpdated !== bUpdated) return bUpdated - aUpdated;
      const aDate = Number(new Date(a?.date || 0).getTime()) || 0;
      const bDate = Number(new Date(b?.date || 0).getTime()) || 0;
      return bDate - aDate;
    });
    return { entries: mergedEntries, mergedDays };
  }

  function refreshSummary(summaryEl) {
    const data = getData();
    const trackerCount = Object.values(data).filter((value) => Array.isArray(value) && value.length > 0).length;
    const entryCount = countEntries(data);
    summaryEl.textContent = `Saved trackers: ${trackerCount} • Total entries: ${entryCount}`;
  }

  function humanizeTrackerKey(storageKey) {
    const raw = String(storageKey || "").trim();
    if (!raw) return "Unknown Tracker";
    const explicit = {
      "water-tracker-entries": "Water Intake Tracker",
      "movie-tracker-entries": "Movie Watch Tracker",
      "video-game-tracker-entries": "Video Game Tracker",
      "custom-tracker-entries": "Custom Tracker",
      "task-tracker-entries": "Task Tracker",
      "sleep-tracker-entries": "Sleep Tracker",
      "meal-tracker-entries": "Meal Tracker",
      "health-tracker-entries": "Health Tracker",
      "finance-tracker-entries": "Finance Tracker",
      "reading-tracker-entries": "Reading Tracker",
      "habit-tracker-entries": "Habit Tracker",
      "workout-tracker-entries": "Workout Tracker"
    };
    if (explicit[raw]) return explicit[raw];
    const base = raw.endsWith("-entries") ? raw.slice(0, -8) : raw;
    return base
      .split("-")
      .map((part) => part ? `${part[0].toUpperCase()}${part.slice(1)}` : "")
      .join(" ");
  }

  function csvEscape(value) {
    const text = String(value ?? "");
    if (/[",\n\r]/.test(text)) {
      return `"${text.replace(/"/g, '""')}"`;
    }
    return text;
  }

  function valueToCsvCell(value) {
    if (value === null || value === undefined) return "";
    if (Array.isArray(value)) {
      return value.map((item) => {
        if (item && typeof item === "object") return JSON.stringify(item);
        return String(item ?? "");
      }).join(" | ");
    }
    if (typeof value === "object") return JSON.stringify(value);
    return String(value);
  }

  function entriesToCsv(entries) {
    const rows = Array.isArray(entries) ? entries : [];
    if (!rows.length) return "";
    const headers = Array.from(new Set(rows.flatMap((entry) => Object.keys(entry || {}))));
    const lines = [
      headers.map(csvEscape).join(",")
    ];
    rows.forEach((entry) => {
      const line = headers
        .map((header) => csvEscape(valueToCsvCell(entry?.[header])))
        .join(",");
      lines.push(line);
    });
    return lines.join("\n");
  }

  async function syncApi(path, options = {}) {
    const method = String(options.method || "GET").toUpperCase();
    const hasBody = Object.prototype.hasOwnProperty.call(options, "body");
    const headers = {
      ...(options.headers || {})
    };
    if (hasBody && !headers["content-type"]) {
      headers["content-type"] = "application/json";
    }

    const response = await fetch(`${SYNC_API_BASE}${path}`, {
      credentials: "include",
      ...options,
      method,
      headers
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok || data?.ok === false) {
      throw new Error(String(data?.error || `Request failed (${response.status})`));
    }
    return data;
  }

  function initCloudSyncSection() {
    const root = document.getElementById("cloud-sync-settings");
    if (!root || root.dataset.bound === "true") return;

    const authState = root.querySelector("#sync-auth-state");
    const loginForm = root.querySelector("#sync-login-form");
    const emailInput = root.querySelector("#sync-email-input");
    const sendLinkBtn = root.querySelector("#sync-send-link-btn");
    const syncActions = root.querySelector("#sync-actions");
    const pullBtn = root.querySelector("#sync-pull-btn");
    const pushBtn = root.querySelector("#sync-push-btn");
    const signoutBtn = root.querySelector("#sync-signout-btn");
    const message = root.querySelector("#sync-message");
    if (!authState || !loginForm || !emailInput || !sendLinkBtn || !syncActions || !pullBtn || !pushBtn || !signoutBtn || !message) return;
    root.dataset.bound = "true";

    const setMessage = (text, isError = false) => {
      message.textContent = text;
      message.classList.remove("hidden");
      message.className = `mt-3 text-sm ${isError ? "text-red-600" : "text-green-700"}`;
    };

    const setSignedIn = (signedIn, email = "") => {
      loginForm.classList.toggle("hidden", signedIn);
      syncActions.classList.toggle("hidden", !signedIn);
      authState.textContent = signedIn ? `Signed in as ${email}` : "Not signed in. Use magic link to enable sync.";
    };

    const getPreviewAuthFromUrl = () => {
      const params = new URLSearchParams(window.location.search);
      const enabledRaw = String(params.get("previewAuth") || params.get("previewauth") || "").toLowerCase();
      const enabled = enabledRaw === "1" || enabledRaw === "true" || enabledRaw === "yes";
      if (!enabled) return null;
      const email = String(params.get("previewEmail") || params.get("previewemail") || "preview@simpletrackers.io").trim();
      return { authenticated: true, user: { email: email || "preview@simpletrackers.io" } };
    };

    const refreshSession = async () => {
      const preview = getPreviewAuthFromUrl();
      if (preview?.authenticated) {
        setSignedIn(true, String(preview.user?.email || ""));
        setMessage("Preview auth mode enabled via URL.", false);
        return;
      }
      try {
        const result = await syncApi("/auth/session", { method: "GET" });
        setSignedIn(Boolean(result?.authenticated), String(result?.user?.email || ""));
      } catch (error) {
        setSignedIn(false);
        setMessage(error instanceof Error ? error.message : "Could not reach sync API.", true);
      }
    };

    sendLinkBtn.addEventListener("click", async () => {
      const email = String(emailInput.value || "").trim();
      if (!email) {
        setMessage("Enter your email first.", true);
        return;
      }
      try {
        sendLinkBtn.disabled = true;
        await syncApi("/auth/request-link", {
          method: "POST",
          body: JSON.stringify({ email })
        });
        setMessage("Magic link sent. Check your inbox.");
      } catch (error) {
        setMessage(error instanceof Error ? error.message : "Unable to send magic link.", true);
      } finally {
        sendLinkBtn.disabled = false;
      }
    });

    pullBtn.addEventListener("click", async () => {
      try {
        const result = await syncApi("/sync/export", { method: "GET" });
        localStorage.setItem(STORAGE_KEY, JSON.stringify(result?.payload || {}));
        setMessage("Downloaded cloud data into this browser.");
      } catch (error) {
        setMessage(error instanceof Error ? error.message : "Unable to pull data.", true);
      }
    });

    pushBtn.addEventListener("click", async () => {
      try {
        const payload = getData();
        await syncApi("/sync/import", {
          method: "POST",
          body: JSON.stringify({ payload, mode: "overwrite" })
        });
        setMessage("Uploaded local data to cloud.");
      } catch (error) {
        setMessage(error instanceof Error ? error.message : "Unable to push data.", true);
      }
    });

    signoutBtn.addEventListener("click", async () => {
      try {
        await syncApi("/auth/logout", { method: "POST", body: JSON.stringify({}) });
        setSignedIn(false);
        setMessage("Signed out.");
      } catch (error) {
        setMessage(error instanceof Error ? error.message : "Unable to sign out.", true);
      }
    });

    const url = new URL(window.location.href);
    if (url.searchParams.get("sync") === "connected") {
      setMessage("Sign-in complete. You can now sync data.");
      url.searchParams.delete("sync");
      window.history.replaceState({}, "", `${url.pathname}${url.search}`);
    }

    void refreshSession();
  }

