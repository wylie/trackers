---
import StandardTrackerPage from '../../components/tracker-pages/StandardTrackerPage.astro';
import { getRelatedCalculators } from '../../data/related-calculators';

const steps = [
  "Add a new workout.",
  "Track your progress.",
  "Edit or delete workouts as needed.",
  "Your data is saved locally in your browser.",
  "No account or login required."
];
const benefits = [
  "Simple, distraction-free interface",
  "Private: your data never leaves your device",
  "No registration or login required",
  "Track your fitness journey"
];
const related = [
  { name: "Habit Tracker", url: "/habit-tracker", icon: "check_circle" },
  { name: "Health Tracker", url: "/health-tracker", icon: "favorite" },
  { name: "Meal Tracker", url: "/meal-tracker", icon: "restaurant" },
  { name: "Task Tracker", url: "/task-tracker", icon: "assignment" }
];
const workoutCategories = [
  "Strength",
  "Cardio",
  "Mobility",
  "Sports",
  "Recovery",
  "Other"
];
---

<StandardTrackerPage
  seoTitle="Workout Tracker"
  seoDescription="Track your workouts privately and easily. No login, no accounts, data stays in your browser."
  pageTitle="Workout Tracker"
  pageDescription="Track your workouts privately and easily. No login, no accounts, data stays in your browser."
  storageKey="workout-tracker-entries"
  trackerCardProps={{
    title: "Workout Log",
    description: "Log your workouts, progress, and notes.",
    icon: "fitness_center",
    itemPlaceholder: "Workout",
    enableCategoryField: true,
    categoryPlaceholder: "Workout Type",
    categoryOptions: workoutCategories,
    autocompleteEndpoint: "/api/workouts/suggest"
  }}
  steps={steps}
  benefits={benefits}
  related={related}
  relatedCalculators={getRelatedCalculators("workout-tracker")}
/>
