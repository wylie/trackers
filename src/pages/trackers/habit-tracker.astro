---
import StandardTrackerPage from '../../components/tracker-pages/StandardTrackerPage.astro';
import { getRelatedCalculators } from '../../data/related-calculators';

const steps = [
  "Add a new habit.",
  "Mark habits as complete.",
  "Edit or delete habits as needed.",
  "Your data is saved locally in your browser.",
  "No account or login required."
];
const benefits = [
  "Simple, distraction-free interface",
  "Private: your data never leaves your device",
  "No registration or login required",
  "Build better habits"
];
const related = [
  { name: "Reading Tracker", url: "/reading-tracker", icon: "menu_book" },
  { name: "Workout Tracker", url: "/workout-tracker", icon: "fitness_center" },
  { name: "Health Tracker", url: "/health-tracker", icon: "favorite" },
  { name: "Meal Tracker", url: "/meal-tracker", icon: "restaurant" }
];
---

<StandardTrackerPage
  seoTitle="Habit Tracker"
  seoDescription="Track your daily habits privately and easily. No login, no accounts, data stays in your browser."
  pageTitle="Habit Tracker"
  pageDescription="Track your daily habits privately and easily. No login, no accounts, data stays in your browser."
  storageKey="habit-tracker-entries"
  trackerCardProps={{
    title: "Habit Log",
    description: "Log your daily habits, progress, and notes.",
    icon: "check_circle",
    itemPlaceholder: "Habit"
  }}
  steps={steps}
  benefits={benefits}
  related={related}
  relatedCalculators={getRelatedCalculators("habit-tracker")}
/>
