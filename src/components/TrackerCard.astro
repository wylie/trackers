---
const {
  title,
  description,
  storageKey,
  icon = 'track_changes',
  fieldNames = ["item", "notes"],
  addLabel = "Add New Item",
  itemPlaceholder = "Item",
  enableOmdbAutocomplete = false,
  omdbApiKey = "",
  autocompleteEndpoint = "",
  enableAuthorField = false,
  authorPlaceholder = "Author",
  autoPopulateAuthor = false,
  enableDirectorField = false,
  directorPlaceholder = "Director",
  autoPopulateDirector = false,
  enablePublisherField = false,
  publisherPlaceholder = "Publisher",
  autoPopulatePublisher = false,
  enableReadingProgress = false,
  autoPopulateTotalPages = false
} = Astro.props;
const autocompleteEnabled = enableOmdbAutocomplete || Boolean(autocompleteEndpoint);
const isSleepTracker = storageKey === "sleep-tracker-entries";
const sleepHourOptions = Array.from({ length: 25 }, (_, value) => value);
const sleepMinuteOptions = Array.from({ length: 60 }, (_, value) => value);
const sleepSettingsKey = "sleep-tracker-settings";
---

<section aria-labelledby="tracker-title" class="bg-white rounded-lg border border-gray-200 shadow-sm p-6 mb-8">
  <h2 id="tracker-title" class="flex items-center gap-2 text-lg font-semibold mb-2 text-gray-900">
    <span class="material-icons icon-blue">{icon}</span>
    <style>
      .icon-blue {
        color: #2563eb !important;
        font-size: 1.5rem;
        margin-right: 0.5rem;
      }
    </style>
    {title}
  </h2>
  <p class="text-gray-700 mb-4">{description}</p>
  {isSleepTracker && (
    <div class="mb-5 rounded-lg border border-blue-100 bg-blue-50/60 p-4">
      <div class="flex flex-col gap-3">
        <div>
          <h3 class="text-sm font-semibold text-slate-900">Nightly Sleep Goal</h3>
          <p class="text-sm text-slate-600">Set your target once and each sleep entry will be graded against it.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_auto] gap-2 items-end">
          <div class="flex flex-col gap-1">
            <label for="tracker-goal-hours" class="text-sm text-gray-700">Goal Hours</label>
            <div class="relative">
              <select
                id="tracker-goal-hours"
                class="tracker-select border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full"
              >
                {sleepHourOptions.map((value) => (
                  <option value={value}>{value} {value === 1 ? "hour" : "hours"}</option>
                ))}
              </select>
              <span class="tracker-select-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
            </div>
          </div>
          <div class="flex flex-col gap-1">
            <label for="tracker-goal-minutes" class="text-sm text-gray-700">Goal Minutes</label>
            <div class="relative">
              <select
                id="tracker-goal-minutes"
                class="tracker-select border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full"
              >
                {sleepMinuteOptions.map((value) => (
                  <option value={value}>{value.toString().padStart(2, "0")} min</option>
                ))}
              </select>
              <span class="tracker-select-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
            </div>
          </div>
          <button
            id="tracker-save-goal"
            type="button"
            class="px-4 py-2 bg-slate-900 text-white rounded-md font-medium hover:bg-slate-800 transition whitespace-nowrap"
          >
            Save Goal
          </button>
        </div>
        <p id="tracker-goal-summary" class="text-sm text-slate-600"></p>
        <p id="tracker-goal-message" class="hidden text-sm font-medium text-green-700"></p>
      </div>
    </div>
  )}
  <form id="tracker-form" class="flex flex-col gap-2 mb-4">
    {isSleepTracker ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <div class="flex flex-col gap-1">
          <label for="tracker-sleep-hours" class="text-sm text-gray-700">Hours Slept</label>
          <div class="relative">
            <select
              id="tracker-sleep-hours"
              class="tracker-select border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full"
            >
              {sleepHourOptions.map((value) => (
                <option value={value}>{value} {value === 1 ? "hour" : "hours"}</option>
              ))}
            </select>
            <span class="tracker-select-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
          </div>
        </div>
        <div class="flex flex-col gap-1">
          <label for="tracker-sleep-minutes" class="text-sm text-gray-700">Minutes Slept</label>
          <div class="relative">
            <select
              id="tracker-sleep-minutes"
              class="tracker-select border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full"
            >
              {sleepMinuteOptions.map((value) => (
                <option value={value}>{value.toString().padStart(2, "0")} min</option>
              ))}
            </select>
            <span class="tracker-select-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
          </div>
        </div>
      </div>
    ) : (
      <div class="relative">
        <input
          type="text"
          id="tracker-item"
          placeholder={itemPlaceholder}
          autocomplete={autocompleteEnabled ? "off" : "on"}
          aria-autocomplete={autocompleteEnabled ? "list" : undefined}
          aria-expanded={autocompleteEnabled ? "false" : undefined}
          class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200 w-full"
        />
        {autocompleteEnabled && (
          <div
            id="tracker-item-suggestions"
            class="hidden absolute left-0 right-0 top-[calc(100%+0.3rem)] z-20 bg-white border border-gray-200 rounded-md shadow-lg overflow-hidden"
          >
            <ul id="tracker-item-suggestions-list" class="max-h-64 overflow-y-auto py-1"></ul>
          </div>
        )}
      </div>
    )}
    {enableAuthorField && (
      <input
        type="text"
        id="tracker-author"
        placeholder={authorPlaceholder}
        class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200"
      />
    )}
    {enableDirectorField && (
      <input
        type="text"
        id="tracker-director"
        placeholder={directorPlaceholder}
        class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200"
      />
    )}
    {enablePublisherField && (
      <input
        type="text"
        id="tracker-publisher"
        placeholder={publisherPlaceholder}
        class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200"
      />
    )}
    {enableReadingProgress && (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <div class="sm:col-span-2 flex items-center gap-2 mt-1">
          <input type="checkbox" id="tracker-currently-reading" class="h-4 w-4 accent-blue-600" checked />
          <label for="tracker-currently-reading" class="text-sm text-gray-700">Currently reading (not finished)</label>
        </div>
        <div id="tracker-reading-progress-fields" class="contents lg:grid lg:grid-cols-3 lg:gap-2 lg:sm:col-span-2">
          <div class="flex flex-col gap-1">
            <label for="tracker-started-date" class="text-sm text-gray-700">Started Reading</label>
            <input type="date" id="tracker-started-date" class="reading-progress-input border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
          </div>
          <div class="flex flex-col gap-1">
            <label for="tracker-current-page" class="text-sm text-gray-700">Current Page</label>
            <input type="number" min="0" step="1" id="tracker-current-page" placeholder="0" class="reading-progress-input border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
          </div>
          <div class="flex flex-col gap-1 sm:col-span-2 lg:col-span-1">
            <label for="tracker-total-pages" class="text-sm text-gray-700">Total Pages</label>
            <input type="number" min="1" step="1" id="tracker-total-pages" placeholder="0" class="reading-progress-input border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
          </div>
        </div>
        <div id="tracker-finished-fields" class="sm:col-span-2">
          <div class="flex flex-col gap-1">
            <label for="tracker-finished-date" class="text-sm text-gray-700">Finished Reading</label>
            <input type="date" id="tracker-finished-date" class="reading-progress-input border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
          </div>
        </div>
      </div>
    )}
    <input type="text" id="tracker-notes" placeholder="Notes" class="border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
    <div id="tracker-rating-row" class:list={["flex items-center gap-2 mb-2", { hidden: isSleepTracker }]}>
      <label for="tracker-rating" class="text-gray-700">Rating:</label>
      <div id="tracker-rating-stars" class="flex gap-1"></div>
      <input type="hidden" id="tracker-rating" value="0" />
    </div>
    <div class="mt-2 flex items-center gap-2">
      <button id="tracker-submit" type="submit" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-md font-medium hover:bg-blue-700 transition">{addLabel}</button>
      <button id="tracker-cancel-edit" type="button" class="hidden px-4 py-2 bg-gray-200 text-gray-700 rounded-md font-medium hover:bg-gray-300 transition">Cancel</button>
    </div>
  </form>
  <ul id="tracker-list" class="list-none p-0 mb-4"></ul>
<style>
  :global(.star) {
    font-size: 1.3rem;
    color: #ccc !important;
    cursor: default;
    transition: color 0.2s;
  }
  :global(button.star) {
    width: 1.75rem;
    height: 1.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    padding: 0;
    line-height: 1;
    cursor: pointer;
  }
  :global(button.star:focus) {
    outline: 2px solid #93c5fd;
    outline-offset: 1px;
  }
  :global(.star.active) {
    color: #999 !important;
  }
  :global(.star.hovered) {
    color: #999 !important;
  }
  :global(.star.inactive) {
    color: #999 !important;
  }
  :global(.omdb-option) {
    width: 100%;
    border: 0;
    background: transparent;
    padding: 0.5rem 0.75rem;
    text-align: left;
    color: #1f2937;
    font-size: 0.875rem;
    line-height: 1.25rem;
    cursor: pointer;
  }
  :global(.omdb-option:hover),
  :global(.omdb-option.is-active) {
    background: #eff6ff;
    color: #1d4ed8;
  }
  :global(.omdb-option-subtitle) {
    display: block;
    color: #6b7280;
    font-size: 0.75rem;
    line-height: 1rem;
    margin-top: 0.1rem;
  }
  .reading-progress-input {
    height: 44px;
  }
  .tracker-select {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    background-color: #fff;
    color: #111827;
    height: 44px;
    padding-right: 2.75rem;
  }
  .tracker-select-icon {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: #111827;
    font-size: 1.375rem;
    pointer-events: none;
  }
</style>
</section>

<script define:vars={{ storageKey, addLabel, enableOmdbAutocomplete, omdbApiKey, autocompleteEndpoint, enableAuthorField, autoPopulateAuthor, enableDirectorField, autoPopulateDirector, enablePublisherField, autoPopulatePublisher, enableReadingProgress, autoPopulateTotalPages, isSleepTracker, sleepSettingsKey }}>
  const form = document.getElementById("tracker-form");
  const itemInput = document.getElementById("tracker-item");
  const sleepHoursInput = document.getElementById("tracker-sleep-hours");
  const sleepMinutesInput = document.getElementById("tracker-sleep-minutes");
  const goalHoursInput = document.getElementById("tracker-goal-hours");
  const goalMinutesInput = document.getElementById("tracker-goal-minutes");
  const goalSaveButton = document.getElementById("tracker-save-goal");
  const goalSummary = document.getElementById("tracker-goal-summary");
  const goalMessage = document.getElementById("tracker-goal-message");
  const authorInput = document.getElementById("tracker-author");
  const directorInput = document.getElementById("tracker-director");
  const publisherInput = document.getElementById("tracker-publisher");
  const startedDateInput = document.getElementById("tracker-started-date");
  const finishedDateInput = document.getElementById("tracker-finished-date");
  const currentlyReadingInput = document.getElementById("tracker-currently-reading");
  const readingProgressFields = document.getElementById("tracker-reading-progress-fields");
  const finishedFields = document.getElementById("tracker-finished-fields");
  const ratingRow = document.getElementById("tracker-rating-row");
  const currentPageInput = document.getElementById("tracker-current-page");
  const totalPagesInput = document.getElementById("tracker-total-pages");
  const notesInput = document.getElementById("tracker-notes");
  const submitButton = document.getElementById("tracker-submit");
  const cancelEditButton = document.getElementById("tracker-cancel-edit");
  const list = document.getElementById("tracker-list");
  const itemSuggestions = document.getElementById("tracker-item-suggestions");
  const itemSuggestionsList = document.getElementById("tracker-item-suggestions-list");
  let ratingStars = null;
  let ratingInput = null;

  let editingIdx = -1;
  let selectedRating = 0;
  let hoveredRating = 0;
  let goalMessageTimer = null;

  function showSleepGoalMessage(message) {
    if (!goalMessage) return;
    goalMessage.textContent = message;
    goalMessage.classList.remove("hidden");
    clearTimeout(goalMessageTimer);
    goalMessageTimer = window.setTimeout(() => {
      goalMessage.classList.add("hidden");
    }, 2200);
  }

  function formatDurationLabel(hours, minutes) {
    const normalizedHours = Math.max(0, Number(hours) || 0);
    const normalizedMinutes = Math.max(0, Number(minutes) || 0);
    const parts = [];
    if (normalizedHours > 0) {
      parts.push(`${normalizedHours} ${normalizedHours === 1 ? "hour" : "hours"}`);
    }
    if (normalizedMinutes > 0 || !parts.length) {
      parts.push(`${normalizedMinutes} ${normalizedMinutes === 1 ? "minute" : "minutes"}`);
    }
    return parts.join(" ");
  }

  function parseSleepDuration(entry) {
    const directHours = Number(entry?.sleepHours);
    const directMinutes = Number(entry?.sleepMinutes);
    if (Number.isFinite(directHours) || Number.isFinite(directMinutes)) {
      return {
        hours: Math.max(0, Number.isFinite(directHours) ? directHours : 0),
        minutes: Math.max(0, Number.isFinite(directMinutes) ? directMinutes : 0)
      };
    }

    const rawItem = String(entry?.item || "").toLowerCase();
    const match = rawItem.match(/(?:(\d+)\s*h(?:ours?)?)?\s*(?:(\d+)\s*m(?:in(?:utes?)?)?)?/i);
    return {
      hours: Number(match?.[1] || 0),
      minutes: Number(match?.[2] || 0)
    };
  }

  function formatSleepDuration(hours, minutes) {
    return formatDurationLabel(hours, minutes);
  }

  function formatMinutesAsDuration(totalMinutes) {
    const normalizedMinutes = Math.max(0, Number(totalMinutes) || 0);
    const hours = Math.floor(normalizedMinutes / 60);
    const minutes = normalizedMinutes % 60;
    return formatDurationLabel(hours, minutes);
  }

  function getSleepGoalSettings(allEntries = getAllEntries()) {
    const settings = allEntries[sleepSettingsKey];
    if (!settings || typeof settings !== "object" || Array.isArray(settings)) {
      return { goalHours: 8, goalMinutes: 0 };
    }
    return {
      goalHours: Math.max(0, Number(settings.goalHours) || 0),
      goalMinutes: Math.max(0, Number(settings.goalMinutes) || 0)
    };
  }

  function saveSleepGoalSettings(goalHours, goalMinutes) {
    const allEntries = getAllEntries();
    allEntries[sleepSettingsKey] = {
      goalHours: Math.max(0, Number(goalHours) || 0),
      goalMinutes: Math.max(0, Number(goalMinutes) || 0)
    };
    localStorage.setItem("simpletrackers.io", JSON.stringify(allEntries));
  }

  function getSleepGrade(actualHours, actualMinutes, goalHours, goalMinutes) {
    const actualTotal = Math.max(0, Number(actualHours) || 0) * 60 + Math.max(0, Number(actualMinutes) || 0);
    const goalTotal = Math.max(0, Number(goalHours) || 0) * 60 + Math.max(0, Number(goalMinutes) || 0);
    if (goalTotal <= 0 || actualTotal <= 0) {
      return { score: null, detail: "Set a nightly goal to score entries.", stars: 0 };
    }

    const diff = Math.abs(actualTotal - goalTotal);
    const score = Math.max(0, Math.round(100 - (diff / goalTotal) * 100));
    const stars = Math.max(1, Math.min(5, Math.round(score / 20)));
    const direction = actualTotal >= goalTotal ? "over" : "under";
    return {
      score,
      detail: `${formatMinutesAsDuration(diff)} ${direction} goal`,
      stars
    };
  }

  function updateSleepGoalSummary() {
    if (!isSleepTracker || !goalSummary) return;
    const goalHours = Number(goalHoursInput?.value || 0);
    const goalMinutes = Number(goalMinutesInput?.value || 0);
    goalSummary.textContent = `Current target: ${formatDurationLabel(goalHours, goalMinutes)}`;
  }

  function setEditingMode(isEditing) {
    if (submitButton) {
      submitButton.textContent = isEditing ? "Save Changes" : addLabel;
    }
    if (cancelEditButton) {
      cancelEditButton.classList.toggle("hidden", !isEditing);
    }
  }

  function clearForm() {
    if (itemInput) itemInput.value = "";
    if (sleepHoursInput) sleepHoursInput.value = "0";
    if (sleepMinutesInput) sleepMinutesInput.value = "0";
    if (authorInput) authorInput.value = "";
    if (directorInput) directorInput.value = "";
    if (publisherInput) publisherInput.value = "";
    if (startedDateInput) startedDateInput.value = "";
    if (finishedDateInput) finishedDateInput.value = "";
    if (currentlyReadingInput) currentlyReadingInput.checked = enableReadingProgress;
    if (currentPageInput) currentPageInput.value = "";
    if (totalPagesInput) totalPagesInput.value = "";
    notesInput.value = "";
    selectedRating = 0;
    hoveredRating = 0;
    if (ratingInput) ratingInput.value = 0;
    updateStars();
    editingIdx = -1;
    setEditingMode(false);
    syncReadingModeUI();
  }

  function startEditing(idx) {
    const entries = getEntries();
    const entry = entries[idx];
    if (!entry) return;
    editingIdx = idx;
    if (itemInput) {
      itemInput.value = entry.item || "";
    }
    if (isSleepTracker) {
      const { hours, minutes } = parseSleepDuration(entry);
      if (sleepHoursInput) sleepHoursInput.value = String(hours);
      if (sleepMinutesInput) sleepMinutesInput.value = String(minutes);
    }
    if (authorInput) authorInput.value = entry.author || "";
    if (directorInput) directorInput.value = entry.director || "";
    if (publisherInput) publisherInput.value = entry.publisher || "";
    if (startedDateInput) startedDateInput.value = entry.startedDate || "";
    if (finishedDateInput) finishedDateInput.value = entry.finishedDate || "";
    if (currentlyReadingInput) currentlyReadingInput.checked = Boolean(entry.currentlyReading);
    if (currentPageInput) currentPageInput.value = entry.currentPage ?? "";
    if (totalPagesInput) totalPagesInput.value = entry.totalPages ?? "";
    notesInput.value = entry.notes || "";
    selectedRating = Number(entry.rating) || 0;
    hoveredRating = 0;
    if (ratingInput) ratingInput.value = selectedRating;
    updateStars();
    setEditingMode(true);
    syncReadingModeUI();
    if (itemInput) {
      itemInput.focus();
    } else if (sleepHoursInput) {
      sleepHoursInput.focus();
    }
  }

  function syncReadingModeUI() {
    if (!enableReadingProgress || !currentlyReadingInput) return;
    const isCurrentlyReading = currentlyReadingInput.checked;
    if (readingProgressFields) {
      readingProgressFields.classList.toggle("hidden", !isCurrentlyReading);
    }
    if (finishedFields) {
      finishedFields.classList.toggle("hidden", isCurrentlyReading);
    }
    if (ratingRow) {
      ratingRow.classList.toggle("hidden", isCurrentlyReading);
    }
    if (isCurrentlyReading) {
      if (finishedDateInput) finishedDateInput.value = "";
      selectedRating = 0;
      hoveredRating = 0;
      if (ratingInput) ratingInput.value = 0;
      updateStars();
    }
  }

  if (currentlyReadingInput) {
    currentlyReadingInput.addEventListener("change", syncReadingModeUI);
    syncReadingModeUI();
  }

  function getAllEntries() {
    try {
      return JSON.parse(localStorage.getItem("simpletrackers.io")) || {};
    } catch {
      return {};
    }
  }

  function getEntries() {
    const allEntries = getAllEntries();
    return allEntries[storageKey] || [];
  }

  function saveEntries(entries) {
    const allEntries = getAllEntries();
    allEntries[storageKey] = entries;
    localStorage.setItem("simpletrackers.io", JSON.stringify(allEntries));
  }

  if (isSleepTracker) {
    const { goalHours, goalMinutes } = getSleepGoalSettings();
    if (goalHoursInput) goalHoursInput.value = String(goalHours);
    if (goalMinutesInput) goalMinutesInput.value = String(goalMinutes);
    updateSleepGoalSummary();

    goalHoursInput?.addEventListener("change", updateSleepGoalSummary);
    goalMinutesInput?.addEventListener("change", updateSleepGoalSummary);
    goalSaveButton?.addEventListener("click", function() {
      const nextGoalHours = Number(goalHoursInput?.value || 0);
      const nextGoalMinutes = Number(goalMinutesInput?.value || 0);
      saveSleepGoalSettings(nextGoalHours, nextGoalMinutes);
      updateSleepGoalSummary();
      showSleepGoalMessage(`Saved goal: ${formatDurationLabel(nextGoalHours, nextGoalMinutes)}`);
      renderEntries();
    });
  }

  if ((enableOmdbAutocomplete || autocompleteEndpoint) && itemInput && itemSuggestions) {
    let autocompleteTimer = null;
    let currentSuggestions = [];
    let activeSuggestionIdx = -1;
    function normalizeSuggestion(item) {
      if (typeof item === "string") {
        return { label: item, value: item, subtitle: "", author: "", director: "", publisher: "", totalPages: "", imdbID: "" };
      }
      if (item && typeof item === "object") {
        const value = item.value || item.label || "";
        const label = item.label || value;
        const subtitle = item.subtitle || "";
        const author = item.author || "";
        const director = item.director || "";
        const publisher = item.publisher || "";
        const totalPages = item.totalPages || "";
        const imdbID = item.imdbID || "";
        if (value) {
          return { label, value, subtitle, author, director, publisher, totalPages, imdbID };
        }
      }
      return null;
    }

    async function fetchOmdbDirector(imdbID) {
      if (!omdbApiKey || !imdbID) return "";
      const url = `https://www.omdbapi.com/?apikey=${encodeURIComponent(omdbApiKey)}&i=${encodeURIComponent(imdbID)}`;
      const res = await fetch(url);
      if (!res.ok) return "";
      const data = await res.json();
      if (!data || data.Response === "False") return "";
      if (!data.Director || data.Director === "N/A") return "";
      return data.Director;
    }

    async function fetchSuggestions(query) {
      if (autocompleteEndpoint) {
        const url = `${autocompleteEndpoint}?q=${encodeURIComponent(query)}`;
        const res = await fetch(url);
        if (!res.ok) return [];
        const data = await res.json();
        const raw = Array.isArray(data) ? data : (data && Array.isArray(data.suggestions) ? data.suggestions : []);
        return raw.map(normalizeSuggestion).filter(Boolean);
      }

      if (!enableOmdbAutocomplete || !omdbApiKey) return [];
      const url = `https://www.omdbapi.com/?apikey=${encodeURIComponent(omdbApiKey)}&type=movie&s=${encodeURIComponent(query)}`;
      const res = await fetch(url);
      if (!res.ok) return [];
      const data = await res.json();
      if (!data || data.Response === "False" || !Array.isArray(data.Search)) return [];
      const baseSuggestions = data.Search.slice(0, 8).map((movie) => normalizeSuggestion({
        label: `${movie.Title} (${movie.Year})`,
        value: movie.Title,
        imdbID: movie.imdbID
      })).filter(Boolean);

      if (!baseSuggestions.length) return [];

      const withDirectors = await Promise.all(
        baseSuggestions.map(async (suggestion) => {
          if (!suggestion.imdbID) return suggestion;
          const director = await fetchOmdbDirector(suggestion.imdbID);
          if (!director) return suggestion;
          return { ...suggestion, director, subtitle: director };
        })
      );
      return withDirectors;
    }

    function hideSuggestions() {
      itemSuggestions.classList.add("hidden");
      itemInput.setAttribute("aria-expanded", "false");
      activeSuggestionIdx = -1;
    }

    function showSuggestions() {
      itemSuggestions.classList.remove("hidden");
      itemInput.setAttribute("aria-expanded", "true");
    }

    function applyActiveState() {
      if (!itemSuggestionsList) return;
      const options = Array.from(itemSuggestionsList.querySelectorAll(".omdb-option"));
      options.forEach((option, idx) => {
        option.classList.toggle("is-active", idx === activeSuggestionIdx);
      });
    }

    async function chooseSuggestion(index) {
      if (index < 0 || index >= currentSuggestions.length) return;
      const suggestion = currentSuggestions[index];
      itemInput.value = suggestion.value;
      if (enableAuthorField && autoPopulateAuthor && authorInput && suggestion.author) {
        authorInput.value = suggestion.author;
      }
      if (enableDirectorField && autoPopulateDirector && directorInput) {
        if (suggestion.director) {
          directorInput.value = suggestion.director;
        } else if (suggestion.imdbID) {
          const director = await fetchOmdbDirector(suggestion.imdbID);
          if (director) {
            directorInput.value = director;
          }
        }
      }
      if (enablePublisherField && autoPopulatePublisher && publisherInput && suggestion.publisher) {
        publisherInput.value = suggestion.publisher;
      }
      if (enableReadingProgress && autoPopulateTotalPages && totalPagesInput && suggestion.totalPages) {
        totalPagesInput.value = String(suggestion.totalPages);
      }
      hideSuggestions();
    }

    function renderSuggestions(items) {
      if (!itemSuggestionsList) return;
      itemSuggestionsList.innerHTML = "";
      currentSuggestions = items;
      activeSuggestionIdx = -1;

      items.forEach((suggestion, index) => {
        const li = document.createElement("li");
        const button = document.createElement("button");
        button.type = "button";
        button.className = "omdb-option";
        button.setAttribute("data-index", String(index));
        const subtitle = suggestion.subtitle || suggestion.author || suggestion.director || suggestion.publisher || "";
        if (subtitle) {
          button.innerHTML = `${suggestion.label}<span class="omdb-option-subtitle">${subtitle}</span>`;
        } else {
          button.textContent = suggestion.label;
        }
        li.appendChild(button);
        itemSuggestionsList.appendChild(li);
      });

      if (items.length) {
        showSuggestions();
      } else {
        hideSuggestions();
      }
    }

    itemInput.addEventListener("input", function() {
      const query = itemInput.value.trim();
      clearTimeout(autocompleteTimer);

      if (query.length < 2) {
        renderSuggestions([]);
        return;
      }

      autocompleteTimer = setTimeout(async () => {
        try {
          const suggestions = await fetchSuggestions(query);
          if (itemInput.value.trim() === query) {
            renderSuggestions(suggestions);
          }
        } catch {
          renderSuggestions([]);
        }
      }, 250);
    });

    itemInput.addEventListener("keydown", function(e) {
      if (!currentSuggestions.length) return;

      if (e.key === "ArrowDown") {
        e.preventDefault();
        activeSuggestionIdx = Math.min(activeSuggestionIdx + 1, currentSuggestions.length - 1);
        applyActiveState();
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        activeSuggestionIdx = Math.max(activeSuggestionIdx - 1, 0);
        applyActiveState();
      } else if (e.key === "Enter" && activeSuggestionIdx >= 0) {
        e.preventDefault();
        void chooseSuggestion(activeSuggestionIdx);
      } else if (e.key === "Escape") {
        hideSuggestions();
      }
    });

    if (itemSuggestionsList) {
      itemSuggestionsList.addEventListener("pointerdown", function(e) {
        const option = e.target.closest(".omdb-option");
        if (!option) return;
        e.preventDefault();
        const idx = Number(option.getAttribute("data-index"));
        if (idx >= 0) {
          void chooseSuggestion(idx);
        }
      });
    }

    document.addEventListener("pointerdown", function(e) {
      if (!itemSuggestions.contains(e.target) && e.target !== itemInput) {
        hideSuggestions();
      }
    });
  }

  function renderEntries() {
    list.innerHTML = "";
    const entries = getEntries();
    function formatSimpleDate(dateStr) {
      if (!dateStr) return "";
      const d = new Date(`${dateStr}T00:00:00`);
      return Number.isNaN(d.getTime())
        ? dateStr
        : d.toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" });
    }
    entries.slice().reverse().forEach((entry, displayIdx) => {
      const idx = entries.length - 1 - displayIdx;
      const li = document.createElement("li");
      li.className = "mb-3";
      const entryDate = entry.date ? new Date(entry.date) : null;
      const dateDesktop = entryDate
        ? entryDate.toLocaleString(undefined, {
            year: "numeric",
            month: "short",
            day: "numeric",
            hour: "2-digit",
            minute: "2-digit"
          })
        : "";
      const dateMobile = entryDate
        ? entryDate.toLocaleString(undefined, {
            month: "short",
            day: "numeric",
            year: "2-digit",
            hour: "numeric",
            minute: "2-digit"
          })
        : "";
      const metadataLines = [];
      if (entry.author) metadataLines.push(`<div class=\"text-gray-600 text-sm\">by ${entry.author}</div>`);
      if (entry.director) metadataLines.push(`<div class=\"text-gray-600 text-sm\">Directed by ${entry.director}</div>`);
      if (entry.publisher) metadataLines.push(`<div class=\"text-gray-600 text-sm\">Published by ${entry.publisher}</div>`);
      if (isSleepTracker) {
        const { hours, minutes } = parseSleepDuration(entry);
        const { goalHours, goalMinutes } = getSleepGoalSettings();
        const grade = getSleepGrade(hours, minutes, goalHours, goalMinutes);
        metadataLines.push(`<div class=\"text-gray-600 text-sm\">Target: ${formatDurationLabel(goalHours, goalMinutes)} • Score: <strong>${grade.score ?? "N/A"}/100</strong>${grade.score !== null ? ` (${grade.detail})` : ""}</div>`);
      }
      if (enableReadingProgress && (entry.startedDate || entry.finishedDate)) {
        const started = entry.startedDate ? `Started ${formatSimpleDate(entry.startedDate)}` : "";
        const finished = entry.currentlyReading
          ? "Currently reading"
          : (entry.finishedDate ? `Finished ${formatSimpleDate(entry.finishedDate)}` : "");
        metadataLines.push(`<div class=\"text-gray-600 text-sm\">${[started, finished].filter(Boolean).join(" • ")}</div>`);
      }
      if (enableReadingProgress && (entry.currentPage || entry.totalPages)) {
        const current = Number(entry.currentPage) || 0;
        const total = Number(entry.totalPages) || 0;
        const percent = total > 0 ? Math.min(100, Math.round((current / total) * 100)) : 0;
        const percentText = total > 0 ? ` (${percent}%)` : "";
        metadataLines.push(`<div class=\"text-gray-600 text-sm\">Progress: ${current}${total > 0 ? ` / ${total} pages` : " pages"}${percentText}</div>`);
      }
      const metadataHtml = metadataLines.length
        ? `<div class=\"mt-1 space-y-0.5\">${metadataLines.join("")}</div>`
        : "";
      const showRating = !isSleepTracker && !(enableReadingProgress && entry.currentlyReading);
      li.innerHTML = `
        <div class=\"relative bg-white rounded-lg shadow border border-gray-200 px-4 py-3 flex flex-col\">
          <div class=\"absolute top-3 right-3 flex items-center gap-1\">
            <button class=\"p-1.5 bg-gray-200 rounded hover:bg-gray-300 text-gray-700 inline-flex items-center justify-center\" aria-label=\"Edit\" data-action=\"edit\" data-idx=\"${idx}\"><span class=\"material-symbols-outlined leading-none\" style=\"font-size:20px;font-variation-settings:'opsz' 20;\" aria-hidden=\"true\">edit</span></button>
            <button class=\"p-1.5 bg-gray-200 rounded hover:bg-red-100 text-red-600 inline-flex items-center justify-center\" aria-label=\"Delete\" data-action=\"delete\" data-idx=\"${idx}\"><span class=\"material-symbols-outlined leading-none\" style=\"font-size:20px;font-variation-settings:'opsz' 20;\" aria-hidden=\"true\">delete</span></button>
          </div>
          <div class=\"mb-2 pr-12\">
            <span class=\"text-[11px] sm:text-xs text-gray-500 leading-tight\" title=\"${dateDesktop}\">${dateMobile}</span>
          </div>
          <div class=\"mb-2 pr-12\">
            <div class=\"min-w-0\">
              <span class=\"text-gray-800 font-medium leading-tight break-words\">${entry.item}</span>
              ${metadataHtml}
            </div>
          </div>
          <div class=\"text-gray-700 text-sm leading-relaxed\">${entry.notes}</div>
          ${showRating ? `<div class=\"flex items-center gap-1 mt-2\">${renderStars(entry.rating || 0)}</div>` : ""}
        </div>
      `;
      li.querySelector("[data-action=\"delete\"]").onclick = () => {
        const entries = getEntries();
        entries.splice(idx, 1);
        saveEntries(entries);
        if (editingIdx === idx) {
          clearForm();
        } else if (editingIdx > idx) {
          editingIdx -= 1;
        }
        renderEntries();
      };
      li.querySelector("[data-action=\"edit\"]").onclick = () => {
        startEditing(idx);
      };
      list.appendChild(li);
    });
  }


  function renderStars(rating, hoverIdx = -1, interactive = false) {
    let starsHtml = "";
    let displayRating = hoverIdx >= 0 ? hoverIdx : rating;
    for (let i = 1; i <= 5; i++) {
      let cls = "star";
      let icon = "star_border";
      if (hoverIdx >= 0 && i <= hoverIdx) {
        cls += " hovered";
        icon = "star";
      } else if (i <= rating) {
        cls += " active";
        icon = "star";
      } else {
        cls += " inactive";
      }
      if (interactive) {
        starsHtml += `<button type="button" class="material-icons ${cls}" data-rating="${i}" aria-label="Set rating to ${i}">${icon}</button>`;
      } else {
        starsHtml += `<span class="material-icons ${cls}">${icon}</span>`;
      }
    }
    return starsHtml;
  }

  // Interactive star rating for form
  ratingStars = document.getElementById("tracker-rating-stars");
  ratingInput = document.getElementById("tracker-rating");

  function ensureInteractiveStars() {
    if (!ratingStars || ratingStars.children.length === 5) return;
    ratingStars.innerHTML = "";
    for (let i = 1; i <= 5; i++) {
      const star = document.createElement("button");
      star.type = "button";
      star.className = "material-icons star inactive";
      star.dataset.rating = String(i);
      star.setAttribute("aria-label", `Set rating to ${i}`);
      star.textContent = "star_border";
      ratingStars.appendChild(star);
    }
  }

  function updateStars() {
    if (!ratingStars) return;
    ensureInteractiveStars();
    const displayRating = hoveredRating > 0 ? hoveredRating : selectedRating;
    Array.from(ratingStars.children).forEach((star, index) => {
      const starValue = index + 1;
      const isFilled = starValue <= displayRating;
      const isHovered = hoveredRating > 0 && starValue <= hoveredRating;
      star.className = `material-icons star ${isHovered ? "hovered" : isFilled ? "active" : "inactive"}`;
      star.textContent = isFilled ? "star" : "star_border";
    });
    if (ratingInput) {
      ratingInput.value = selectedRating;
    }
  }

  function getRatingFromEvent(e) {
    if (!ratingStars) return 0;
    const buttons = Array.from(ratingStars.querySelectorAll("[data-rating]"));
    if (!buttons.length) return 0;

    const targetEl = e.target instanceof Element ? e.target : e.target?.parentElement;
    const directStar = targetEl?.closest("[data-rating]");
    if (directStar) return Number(directStar.dataset.rating);

    const x = e.clientX;
    for (const button of buttons) {
      const rect = button.getBoundingClientRect();
      if (x >= rect.left && x <= rect.right) {
        return Number(button.dataset.rating);
      }
    }

    // Allow slight misses in the gap between buttons by snapping to nearest center.
    let nearest = buttons[0];
    let minDist = Infinity;
    for (const button of buttons) {
      const rect = button.getBoundingClientRect();
      const center = rect.left + rect.width / 2;
      const dist = Math.abs(x - center);
      if (dist < minDist) {
        minDist = dist;
        nearest = button;
      }
    }
    return Number(nearest.dataset.rating);
  }

  if (ratingStars) {
    updateStars();
    ratingStars.addEventListener("pointermove", function(e) {
      const rating = getRatingFromEvent(e);
      if (rating > 0) {
        hoveredRating = rating;
        updateStars();
      }
    });
    function resetHoveredStars() {
      hoveredRating = 0;
      updateStars();
    }
    ratingStars.addEventListener("mouseleave", resetHoveredStars);
    ratingStars.addEventListener("pointerleave", resetHoveredStars);
    ratingStars.addEventListener("focusout", function() {
      requestAnimationFrame(() => {
        if (!ratingStars.contains(document.activeElement)) {
          resetHoveredStars();
        }
      });
    });
    function selectFromEvent(e) {
      const rating = getRatingFromEvent(e);
      if (rating > 0) {
        selectedRating = rating;
        hoveredRating = 0;
        updateStars();
      }
    }
    ratingStars.addEventListener("pointerdown", selectFromEvent);
    ratingStars.addEventListener("click", selectFromEvent);
    ratingStars.addEventListener("keydown", function(e) {
      const star = e.target.closest("[data-rating]");
      if (star && (e.key === "Enter" || e.key === " ")) {
        e.preventDefault();
        selectedRating = Number(star.dataset.rating);
        hoveredRating = 0;
        updateStars();
      }
    });
  }

  if (cancelEditButton) {
    cancelEditButton.addEventListener("click", function() {
      clearForm();
    });
  }

  form.onsubmit = e => {
    e.preventDefault();
    const sleepHours = Number(sleepHoursInput?.value || 0);
    const sleepMinutes = Number(sleepMinutesInput?.value || 0);
    const item = isSleepTracker
      ? formatSleepDuration(sleepHours, sleepMinutes)
      : (itemInput?.value.trim() || "");
    const author = authorInput?.value.trim() || "";
    const director = directorInput?.value.trim() || "";
    const publisher = publisherInput?.value.trim() || "";
    const startedDate = startedDateInput?.value || "";
    const currentlyReading = enableReadingProgress && Boolean(currentlyReadingInput?.checked);
    const finishedDate = currentlyReading ? "" : (finishedDateInput?.value || "");
    const currentPage = Number(currentPageInput?.value || 0);
    const totalPages = Number(totalPagesInput?.value || 0);
    const notes = notesInput.value.trim();
    const { goalHours, goalMinutes } = isSleepTracker ? getSleepGoalSettings() : { goalHours: 0, goalMinutes: 0 };
    const sleepGrade = isSleepTracker ? getSleepGrade(sleepHours, sleepMinutes, goalHours, goalMinutes) : null;
    const rating = isSleepTracker
      ? (sleepGrade?.stars || 0)
      : (currentlyReading ? 0 : (parseFloat(ratingInput?.value) || 0));
    if (!item || (isSleepTracker && sleepHours === 0 && sleepMinutes === 0)) return;
    const entries = getEntries();
    if (editingIdx >= 0 && entries[editingIdx]) {
      const updatedEntry = {
        ...entries[editingIdx],
        item,
        notes,
        rating
      };
      if (isSleepTracker) {
        updatedEntry.sleepHours = sleepHours;
        updatedEntry.sleepMinutes = sleepMinutes;
        updatedEntry.sleepScore = sleepGrade?.score ?? null;
      }
      if (enableAuthorField) updatedEntry.author = author;
      if (enableDirectorField) updatedEntry.director = director;
      if (enablePublisherField) updatedEntry.publisher = publisher;
      if (enableReadingProgress) {
        updatedEntry.startedDate = startedDate;
        updatedEntry.finishedDate = finishedDate;
        updatedEntry.currentlyReading = currentlyReading;
        updatedEntry.currentPage = currentPage;
        updatedEntry.totalPages = totalPages;
      }
      entries[editingIdx] = updatedEntry;
    } else {
      const date = new Date().toISOString();
      const nextEntry = { item, notes, rating, date };
      if (isSleepTracker) {
        nextEntry.sleepHours = sleepHours;
        nextEntry.sleepMinutes = sleepMinutes;
        nextEntry.sleepScore = sleepGrade?.score ?? null;
      }
      if (enableAuthorField) nextEntry.author = author;
      if (enableDirectorField) nextEntry.director = director;
      if (enablePublisherField) nextEntry.publisher = publisher;
      if (enableReadingProgress) {
        nextEntry.startedDate = startedDate;
        nextEntry.finishedDate = finishedDate;
        nextEntry.currentlyReading = currentlyReading;
        nextEntry.currentPage = currentPage;
        nextEntry.totalPages = totalPages;
      }
      entries.push(nextEntry);
    }
    saveEntries(entries);
    clearForm();
    renderEntries();
  };

  renderEntries();
</script>
