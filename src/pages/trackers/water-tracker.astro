---
import StandardTrackerPage from '../../components/tracker-pages/StandardTrackerPage.astro';
import { getRelatedCalculators } from '../../data/related-calculators';

const steps = [
  "Set your daily hydration goal in oz or ml.",
  "Log each drink amount throughout the day.",
  "Track your daily hydration progress over time.",
  "Your data is saved locally in your browser.",
  "No account or login required."
];
const benefits = [
  "Simple, distraction-free hydration logging",
  "Private: your data never leaves your device",
  "No registration or login required",
  "Daily goal tracking in oz or ml"
];
const related = [
  { name: "Health Tracker", url: "/health-tracker", icon: "favorite" },
  { name: "Meal Tracker", url: "/meal-tracker", icon: "restaurant" },
  { name: "Workout Tracker", url: "/workout-tracker", icon: "fitness_center" },
  { name: "Habit Tracker", url: "/habit-tracker", icon: "check_circle" }
];
---

<StandardTrackerPage
  seoTitle="Water Intake Tracker"
  seoDescription="Track your daily hydration in oz or ml with customizable drink impact and a daily goal. Private, browser-based, and no login required."
  pageTitle="Water Intake Tracker"
  pageDescription="Track your daily hydration in oz or ml with a simple goal-based water log."
  storageKey="water-tracker-entries"
  trackerCardProps={{
    title: "Water Intake Log",
    description: "Log each drink amount in oz and track your daily goal.",
    icon: "water_drop"
  }}
  steps={steps}
  benefits={benefits}
  related={related}
  relatedCalculators={getRelatedCalculators("water-tracker")}
/>
