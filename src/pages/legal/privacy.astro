---
import Layout from '../../components/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout>
  <Header />
  <main>
    <h1>Privacy Policy</h1>
    <section>
      <p>SimpleTrackers.io does not collect, store, or share your personal data. All tracker data stays in your browser and is never sent to a server.</p>
      <ul>
        <li>No account required</li>
        <li>No cookies or tracking</li>
        <li>Data stays private</li>
      </ul>
      <p>If you have questions, contact us at <a href="mailto:support@simpletrackers.io">support@simpletrackers.io</a>.</p>
    </section>
  </main>
  <Footer />
</Layout>