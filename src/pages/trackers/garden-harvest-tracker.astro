---
import Layout from '../../components/Layout.astro';
import TrackerPageWrapper from '../../components/TrackerPageWrapper.astro';
import TrackerCard from '../../components/TrackerCard.astro';
import Introduction from '../../components/sections/Introduction.astro';
import HowToUse from '../../components/sections/HowToUse.astro';
import Benefits from '../../components/sections/Benefits.astro';
import FAQ from '../../components/sections/FAQ.astro';
import RelatedTrackers from '../../components/sections/RelatedTrackers.astro';

const steps = [
  "Add a new harvest entry.",
  "Record the type and amount.",
  "Edit or delete entries as needed.",
  "Your data is saved locally in your browser.",
  "No account or login required."
];
const benefits = [
  "Simple, distraction-free interface",
  "Private: your data never leaves your device",
  "No registration or login required",
  "Track your garden's productivity"
];
const faqs = [
  { question: "Is my data private?", answer: "Yes, all data is stored locally in your browser." },
  { question: "Do I need an account?", answer: "No, SimpleTrackers.io does not require registration or login." },
  { question: "Can I export my data?", answer: "Export functionality is coming soon!" }
];
const related = [
  { name: "Meal Tracker", url: "/meal-tracker", icon: "restaurant" },
  { name: "Health Tracker", url: "/health-tracker", icon: "favorite" },
  { name: "Habit Tracker", url: "/habit-tracker", icon: "check_circle" },
  { name: "Reading Tracker", url: "/reading-tracker", icon: "menu_book" }
];
---

<Layout>
  <TrackerPageWrapper>
    <main>
      <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Garden Harvest Tracker</h1>
        <p class="text-gray-700 text-lg mb-6">Free, private, browser-based garden harvest tracker. No login required.</p>
        <TrackerCard
          title="Garden Harvest Log"
          description="Log your garden harvests, dates, types, and notes."
          storageKey="garden-harvest-tracker-entries"
          icon="eco"
        />
        <section class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="col-span-1 md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-8">
            <HowToUse steps={steps} />
            <Benefits benefits={benefits} />
          </div>
          <div class="mt-4 col-span-1 md:col-span-2">
            <RelatedTrackers related={related} />
          </div>
        </section>
      </div>
    </main>
  </TrackerPageWrapper>
</Layout>
