---
import StandardTrackerPage from '../../components/tracker-pages/StandardTrackerPage.astro';
import { getRelatedCalculators } from '../../data/related-calculators';

const steps = [
  "Enter the transaction details (amount, category, date, etc.)",
  "Click 'Add Entry' to log your transaction.",
  "Your data is saved locally in your browser.",
  "No account or login required."
];
const benefits = [
  "Simple, distraction-free interface",
  "Private: your data never leaves your device",
  "No registration or login required",
  "Track spending and savings easily"
];
const related = [
  { name: "Health Tracker", url: "/health-tracker", icon: "favorite" },
  { name: "Meal Tracker", url: "/meal-tracker", icon: "restaurant" },
  { name: "Habit Tracker", url: "/habit-tracker", icon: "check_circle" },
  { name: "Task Tracker", url: "/task-tracker", icon: "assignment" }
];
const financeCategories = [
  "Housing",
  "Food",
  "Transportation",
  "Utilities",
  "Health",
  "Insurance",
  "Debt",
  "Savings",
  "Income",
  "Entertainment",
  "Shopping",
  "Education",
  "Travel",
  "Other"
];
---

<StandardTrackerPage
  seoTitle="Finance Tracker"
  seoDescription="Track your finances privately and easily. No login, no accounts, data stays in your browser."
  pageTitle="Finance Tracker"
  pageDescription="Track your finances privately and easily. No login, no accounts, data stays in your browser."
  storageKey="finance-tracker-entries"
  trackerCardProps={{
    description: "Log your expenses, income, and notes.",
    title: "Finance Log",
    icon: "attach_money",
    itemPlaceholder: "Transaction",
    enableCategoryField: true,
    categoryPlaceholder: "Category",
    categoryOptions: financeCategories
  }}
  steps={steps}
  benefits={benefits}
  related={related}
  relatedCalculators={getRelatedCalculators("finance-tracker")}
/>
